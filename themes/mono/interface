                        <div class="flex justify-between"><span>Subtotal</span><span id="chk-subtotal" class="text-neutral-900">$0.00</span></div>
                        <div class="flex justify-between text-neutral-900 font-bold pt-3 border-t border-neutral-200 text-sm"><span>Total</span><span id="chk-total">$0.00</span></div>
