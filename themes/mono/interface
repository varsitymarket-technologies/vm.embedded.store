<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MONO // Premium Fashion & Essentials</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #FFFFFF; color: #111111; }
        .font-serif { font-family: 'Playfair Display', serif; }
        .view-section { display: none; }
        .view-section.active { display: block; }
        
        /* Shopify style input focus overrides */
        .shopify-input { 
            border: 1px solid #E5E5E5; 
            transition: border-color 0.2s ease;
        }
        .shopify-input:focus { 
            outline: none; 
            border-color: #111111; 
        }
        
        /* Smooth product card transitions */
        .product-card img {
            transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .product-card:hover img {
            transform: scale(1.04);
        }
    </style>

    <!-- D.3.x: customer auth helper (vm-customer.js from same dir as api.php) -->
    <script src="vm-customer.js" defer></script>
    <script>
        window.addEventListener('vm:customer-loaded', function () {
            document.body.dataset.customer = 'logged-in';
            if (window.app && app.auth && typeof app.auth.updateIcon === 'function') app.auth.updateIcon();
        });
        window.addEventListener('vm:customer-login', function () {
            document.body.dataset.customer = 'logged-in';
            if (window.app && app.auth && typeof app.auth.updateIcon === 'function') app.auth.updateIcon();
        });
        window.addEventListener('vm:customer-logout', function () {
            document.body.dataset.customer = 'logged-out';
            if (window.app && app.auth && typeof app.auth.updateIcon === 'function') app.auth.updateIcon();
        });
    </script>
</head>
<body class="antialiased min-h-screen flex flex-col justify-between selection:bg-neutral-900 selection:text-white">

    <div class="bg-neutral-900 text-white py-2 text-xs font-medium tracking-wider text-center uppercase px-4">
        Complimentary worldwide shipping on all orders over $150
    </div>

    <header class="sticky top-0 bg-white/95 backdrop-blur-md z-40 border-b border-neutral-100">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between">
            
            <nav class="hidden md:flex items-center space-x-8 text-xs font-medium tracking-widest uppercase text-neutral-600">
                <a href="#shop" onclick="app.router.navigate('shop')" class="hover:text-black transition-colors">Shop Collection</a>
                <a href="#about" onclick="app.router.navigate('about')" class="hover:text-black transition-colors">Our Story</a>
            </nav>

            <a href="#home" onclick="app.router.navigate('home')" class="font-serif text-2xl font-medium tracking-tight text-neutral-900">
                MONO STUDIO
            </a>

            <div class="flex items-center space-x-4 sm:space-x-6">
                <button class="p-2 text-neutral-600 hover:text-black transition-colors" onclick="app.ui.toggleSearchOverlay()" aria-label="Search Store">
                    <i data-lucide="search" class="w-5 h-5 stroke-[1.5]"></i>
                </button>
                <button id="auth-icon-btn" class="p-2 text-neutral-600 hover:text-black transition-colors flex items-center" onclick="app.auth.iconClick()" aria-label="Account">
                    <span class="sr-only" id="auth-icon-label">Account</span>
                    <i data-lucide="user" class="w-5 h-5 stroke-[1.5]"></i>
                </button>
                <button class="p-2 text-neutral-600 hover:text-black transition-colors relative flex items-center" onclick="app.ui.toggleCartDrawer()" aria-label="Open Cart">
                    <i data-lucide="shopping-bag" class="w-5 h-5 stroke-[1.5]"></i>
                    <span id="global-cart-count" class="absolute -top-1 -right-1 text-[10px] font-bold text-white bg-neutral-900 w-4 h-4 rounded-full flex items-center justify-center transition-all transform scale-0">0</span>
                </button>
            </div>
        </div>
    </header>

    <main class="flex-grow">

        <section id="view-home" class="view-section active">
            <div class="relative bg-neutral-50 border-b border-neutral-100 overflow-hidden">
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 lg:grid-cols-12 items-center min-h-[calc(100vh-10rem)] py-12 lg:py-0">
                    <div class="lg:col-span-5 space-y-6 z-10 text-center lg:text-left">
                        <span class="text-xs font-semibold tracking-widest uppercase text-neutral-400">The New Season Collection</span>
                        <h1 class="font-serif text-4xl sm:text-5xl lg:text-6xl text-neutral-900 leading-tight">
                            Timeless silhouettes, crafted for modern life.
                        </h1>
                        <p class="text-neutral-500 text-sm max-w-md mx-auto lg:mx-0 font-light leading-relaxed">
                            A curated capsule series stripping away the noise to emphasize premium premium textiles, tailored structural fits, and clean minimalism.
                        </p>
                        <div class="pt-4">
                            <button onclick="app.router.navigate('shop')" class="bg-neutral-900 text-white text-xs font-semibold tracking-widest uppercase px-8 py-4 hover:bg-neutral-800 transition-colors rounded-none">
                                Shop New Arrivals
                            </button>
                        </div>
                    </div>
                    <div class="lg:col-span-7 mt-8 lg:mt-0 h-[400px] sm:h-[550px] lg:h-[650px] w-full">
                        <img src="https://images.unsplash.com/photo-1542291026-7eec264c27ff?q=80&w=1200&auto=format&fit=crop" class="w-full h-full object-cover rounded-none" alt="Premium Lookbook Model Feature">
                    </div>
                </div>
            </div>

            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 grid grid-cols-1 md:grid-cols-2 gap-8">
                <div onclick="app.router.navigate('shop', {category: 'STRUCTURE'})" class="relative group cursor-pointer overflow-hidden aspect-[4/3] bg-neutral-100">
                    <img src="https://images.unsplash.com/photo-1508296695146-257a814070b4?q=80&w=800&auto=format&fit=crop" class="w-full h-full object-cover group-hover:scale-102 transition-transform duration-700">
                    <div class="absolute inset-0 bg-black/10 transition-colors group-hover:bg-black/20"></div>
                    <div class="absolute bottom-6 left-6 text-white">
                        <h3 class="font-serif text-2xl">Premium Apparel &rarr;</h3>
                    </div>
                </div>
                <div onclick="app.router.navigate('shop', {category: 'HARDWARE'})" class="relative group cursor-pointer overflow-hidden aspect-[4/3] bg-neutral-100">
                    <img src="https://images.unsplash.com/photo-1553062407-98eeb64c6a62?q=80&w=800&auto=format&fit=crop" class="w-full h-full object-cover group-hover:scale-102 transition-transform duration-700">
                    <div class="absolute inset-0 bg-black/10 transition-colors group-hover:bg-black/20"></div>
                    <div class="absolute bottom-6 left-6 text-white">
                        <h3 class="font-serif text-2xl">Utility Accessories &rarr;</h3>
                    </div>
                </div>
            </div>
        </section>

        <section id="view-shop" class="view-section max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <div class="flex flex-col sm:flex-row sm:items-baseline justify-between border-b border-neutral-200 pb-5 mb-10">
                <div>
                    <h2 class="font-serif text-3xl text-neutral-900 tracking-tight">All Collections</h2>
                    <p id="catalog-count-string" class="text-neutral-400 text-xs mt-1">Loading store items...</p>
                </div>
                <div class="mt-4 sm:mt-0 flex items-center space-x-4">
                    <label for="catalog-sort" class="text-xs text-neutral-400 uppercase tracking-wider font-medium">Sort by:</label>
                    <select id="catalog-sort" onchange="app.store.sortCatalog(this.value)" class="text-xs uppercase tracking-wider bg-transparent border border-neutral-200 text-neutral-800 rounded-none py-2 px-3 focus:outline-none focus:border-black">
                        <option value="featured">Featured Items</option>
                        <option value="price-low">Price: Low to High</option>
                        <option value="price-high">Price: High to Low</option>
                    </select>
                </div>
            </div>

            <div id="shop-items-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-y-12 gap-x-6">
                </div>
        </section>

        <section id="view-product" class="view-section max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <div id="product-detail-target" class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">
                </div>
        </section>

        <section id="view-about" class="view-section max-w-3xl mx-auto px-4 py-16 space-y-8 text-center">
            <div class="space-y-3">
                <span class="text-xs text-neutral-400 font-semibold tracking-widest uppercase">// Established 2018</span>
                <h2 class="font-serif text-3xl sm:text-4xl text-neutral-900">Crafting sustainable, luxury mainstays.</h2>
                <p class="text-neutral-500 text-sm font-light leading-relaxed">MONO STUDIO was founded on a simple premise: create high-end garments and functional goods built to last past seasonal trends, reducing consumer waste through pristine craftsmanship.</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-left pt-6">
                <div class="p-6 bg-neutral-50 space-y-2 border border-neutral-100">
                    <h3 class="text-neutral-900 text-xs font-semibold uppercase tracking-wider">Ethical Sourcing</h3>
                    <p class="text-neutral-500 text-xs leading-relaxed">We trace every yarn variant back to carbon-certified organic farms, prioritizing regional standard fair-wage labor above all else.</p>
                </div>
                <div class="p-6 bg-neutral-50 space-y-2 border border-neutral-100">
                    <h3 class="text-neutral-900 text-xs font-semibold uppercase tracking-wider">Circular Lifecycle</h3>
                    <p class="text-neutral-500 text-xs leading-relaxed">All active components are eligible for our store trade-in initiative programs, supporting continuous environmental recovery loops.</p>
                </div>
            </div>
        </section>

        <section id="view-faq" class="view-section max-w-2xl mx-auto px-4 py-16 space-y-8">
            <div class="text-center space-y-1">
                <h2 class="font-serif text-3xl text-neutral-900">Customer Support</h2>
                <p class="text-neutral-400 text-xs">Frequently asked order answers and policies</p>
            </div>
            <div class="border-t border-neutral-200 divide-y divide-neutral-100">
                <div class="py-4">
                    <button onclick="app.ui.toggleAccordion(this)" class="w-full flex justify-between items-center text-left py-2 font-medium text-sm text-neutral-800 focus:outline-none">
                        <span>When will my order ship?</span>
                        <i data-lucide="chevron-down" class="w-4 h-4 text-neutral-400 transform transition-transform"></i>
                    </button>
                    <div class="max-h-0 overflow-hidden transition-all duration-300 ease-in-out text-neutral-500 text-xs leading-relaxed">
                        <p class="py-3 pr-4">Orders typically process within 1-2 business days. Standard domestic shipping takes 3-5 business days, while international transit timelines can span 7-14 business days depending on customs processing.</p>
                    </div>
                </div>
                <div class="py-4">
                    <button onclick="app.ui.toggleAccordion(this)" class="w-full flex justify-between items-center text-left py-2 font-medium text-sm text-neutral-800 focus:outline-none">
                        <span>What is your returns policy?</span>
                        <i data-lucide="chevron-down" class="w-4 h-4 text-neutral-400 transform transition-transform"></i>
                    </button>
                    <div class="max-h-0 overflow-hidden transition-all duration-300 ease-in-out text-neutral-500 text-xs leading-relaxed">
                        <p class="py-3 pr-4">We accept returns of unworn, unwashed merchandise with all native tags attached within 14 days of delivery. Return shipments can easily be initiated through our automated online self-service support dashboard.</p>
                    </div>
                </div>
            </div>
        </section>

        <section id="view-contact" class="view-section max-w-4xl mx-auto px-4 py-16">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12 bg-neutral-50 p-8 sm:p-12 border border-neutral-100">
                <div class="space-y-6 flex flex-col justify-between">
                    <div class="space-y-3">
                        <h2 class="font-serif text-3xl text-neutral-900">Get In Touch</h2>
                        <p class="text-neutral-500 text-xs leading-relaxed">Have questions regarding fit specifications, order logistics or custom product batches? Drop our concierge agents a detailed brief.</p>
                    </div>
                    <div class="space-y-1 text-xs text-neutral-400">
                        <p>Support Matrix Email: assistance@monostudio.com</p>
                        <p>Corporate Fulfillment Hub: NY District Office, NY 10013</p>
                    </div>
                </div>
                <form onsubmit="app.ui.handleContactSubmit(event)" class="space-y-4">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <input type="text" required placeholder="Your Name" class="w-full p-3.5 text-xs bg-white shopify-input">
                        <input type="email" required placeholder="Email Address" class="w-full p-3.5 text-xs bg-white shopify-input">
                    </div>
                    <textarea required rows="5" placeholder="How can we help you?" class="w-full p-3.5 text-xs bg-white shopify-input"></textarea>
                    <button type="submit" class="w-full bg-neutral-900 text-white py-3.5 text-xs font-semibold tracking-widest uppercase hover:bg-neutral-800 transition-colors rounded-none">Send Message</button>
                </form>
            </div>
        </section>

        <!-- D.3.x: account view -->
        <section id="view-account" class="view-section max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <div class="flex items-center justify-between mb-12">
                <div>
                    <p class="text-[11px] uppercase tracking-widest text-neutral-500">Account</p>
                    <h1 id="acc-greeting" class="font-serif text-4xl text-neutral-900 mt-2 tracking-tight">Welcome</h1>
                </div>
                <button onclick="app.auth.doLogout()" class="text-[11px] uppercase tracking-widest text-neutral-500 hover:text-black font-medium">Sign Out</button>
            </div>

            <div class="flex space-x-8 border-b border-neutral-100 mb-8">
                <button id="acc-tab-overview" onclick="app.auth.activateTab('overview')" class="acc-tab pb-3 text-[11px] uppercase tracking-widest font-medium">Overview</button>
                <button id="acc-tab-profile"  onclick="app.auth.activateTab('profile')"  class="acc-tab pb-3 text-[11px] uppercase tracking-widest font-medium">Profile</button>
                <button id="acc-tab-orders"   onclick="app.auth.activateTab('orders')"   class="acc-tab pb-3 text-[11px] uppercase tracking-widest font-medium">Orders</button>
                <button id="acc-tab-password" onclick="app.auth.activateTab('password')" class="acc-tab pb-3 text-[11px] uppercase tracking-widest font-medium">Password</button>
            </div>

            <div id="acc-panel-overview" class="acc-panel">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
                    <div><p class="text-[11px] uppercase tracking-widest text-neutral-500">Name</p><p id="acc-ov-name" class="text-sm text-neutral-900 mt-2">—</p></div>
                    <div><p class="text-[11px] uppercase tracking-widest text-neutral-500">Email</p><p id="acc-ov-email" class="text-sm text-neutral-900 mt-2">—</p></div>
                    <div><p class="text-[11px] uppercase tracking-widest text-neutral-500">Member Since</p><p id="acc-ov-joined" class="text-sm text-neutral-900 mt-2">—</p></div>
                </div>
                <button onclick="app.auth.activateTab('profile')" class="text-[11px] uppercase tracking-widest text-black border-b border-black pb-0.5 font-medium">Edit profile</button>
            </div>

            <div id="acc-panel-profile" class="acc-panel hidden">
                <form onsubmit="event.preventDefault(); app.auth.saveProfile()" class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div><label class="block text-[11px] uppercase tracking-widest text-neutral-500 mb-2">First Name</label>
                             <input type="text" id="acc-fname" class="w-full bg-white border border-neutral-200 px-4 py-3 text-neutral-900 focus:outline-none focus:border-black"></div>
                        <div><label class="block text-[11px] uppercase tracking-widest text-neutral-500 mb-2">Last Name</label>
                             <input type="text" id="acc-lname" class="w-full bg-white border border-neutral-200 px-4 py-3 text-neutral-900 focus:outline-none focus:border-black"></div>
                    </div>
                    <div><label class="block text-[11px] uppercase tracking-widest text-neutral-500 mb-2">Email</label>
                         <input type="email" id="acc-email" readonly title="Email is the account identifier and cannot be changed here" class="w-full bg-neutral-50 border border-neutral-200 px-4 py-3 text-neutral-500 cursor-not-allowed"></div>
                    <div><label class="block text-[11px] uppercase tracking-widest text-neutral-500 mb-2">Phone (optional)</label>
                         <input type="tel" id="acc-phone" class="w-full bg-white border border-neutral-200 px-4 py-3 text-neutral-900 focus:outline-none focus:border-black"></div>
                    <button type="submit" class="w-full bg-black text-white py-3 text-[11px] uppercase tracking-widest font-medium hover:bg-neutral-800 transition-colors">Save</button>
                </form>
            </div>

            <div id="acc-panel-orders" class="acc-panel hidden">
                <div id="acc-orders-list">
                    <p class="text-[11px] uppercase tracking-widest text-neutral-500 py-12 text-center">Loading…</p>
                </div>
            </div>

            <div id="acc-panel-password" class="acc-panel hidden">
                <form onsubmit="event.preventDefault(); app.auth.changePassword()" class="space-y-6">
                    <div><label class="block text-[11px] uppercase tracking-widest text-neutral-500 mb-2">Current Password</label>
                         <input type="password" id="acc-pw-cur" required class="w-full bg-white border border-neutral-200 px-4 py-3 text-neutral-900 focus:outline-none focus:border-black"></div>
                    <div><label class="block text-[11px] uppercase tracking-widest text-neutral-500 mb-2">New Password</label>
                         <input type="password" id="acc-pw-new" required minlength="8" class="w-full bg-white border border-neutral-200 px-4 py-3 text-neutral-900 focus:outline-none focus:border-black"></div>
                    <div><label class="block text-[11px] uppercase tracking-widest text-neutral-500 mb-2">Confirm New Password</label>
                         <input type="password" id="acc-pw-conf" required minlength="8" class="w-full bg-white border border-neutral-200 px-4 py-3 text-neutral-900 focus:outline-none focus:border-black"></div>
                    <button type="submit" class="w-full bg-black text-white py-3 text-[11px] uppercase tracking-widest font-medium hover:bg-neutral-800 transition-colors">Change Password</button>
                </form>
            </div>
        </section>

        <style>
            .acc-tab { color: rgb(115 115 115); border-bottom: 1px solid transparent; transition: all 0.3s; }
            .acc-tab.active { color: #000; border-bottom-color: #000; }
        </style>

        <!-- D.3.x: Auth modal overlay -->
        <div id="auth-modal" class="fixed inset-0 bg-white z-50 hidden flex-col items-center justify-start overflow-y-auto p-6">
            <div class="w-full max-w-md mx-auto pt-12 pb-24">
                <div class="flex items-center justify-between mb-12">
                    <span class="font-serif text-2xl font-medium tracking-tight text-neutral-900">MONO STUDIO</span>
                    <button onclick="app.auth.close()" aria-label="Close" class="text-neutral-500 hover:text-black transition-colors">
                        <i data-lucide="x" class="w-5 h-5"></i>
                    </button>
                </div>

                <div class="flex space-x-8 border-b border-neutral-100 mb-8">
                    <button id="auth-tab-login"    onclick="app.auth.switchTab('login')"    class="auth-tab pb-3 text-[11px] uppercase tracking-widest font-medium">Sign In</button>
                    <button id="auth-tab-register" onclick="app.auth.switchTab('register')" class="auth-tab pb-3 text-[11px] uppercase tracking-widest font-medium">Create</button>
                    <button id="auth-tab-forgot"   onclick="app.auth.switchTab('forgot')"   class="auth-tab pb-3 text-[11px] uppercase tracking-widest font-medium">Forgot</button>
                </div>

                <div id="auth-panel-login" class="auth-panel">
                    <form onsubmit="event.preventDefault(); app.auth.submitLogin()" class="space-y-6">
                        <div><label class="block text-[11px] uppercase tracking-widest text-neutral-500 mb-2">Email</label>
                            <input type="email" id="auth-login-email" required class="w-full bg-white border border-neutral-200 px-4 py-3 text-neutral-900 focus:outline-none focus:border-black"></div>
                        <div><label class="block text-[11px] uppercase tracking-widest text-neutral-500 mb-2">Password</label>
                            <input type="password" id="auth-login-pass" required class="w-full bg-white border border-neutral-200 px-4 py-3 text-neutral-900 focus:outline-none focus:border-black"></div>
                        <div id="auth-login-error" class="hidden text-[11px] text-red-600 mt-2"></div>
                        <button type="submit" class="w-full bg-black text-white py-3 text-[11px] uppercase tracking-widest font-medium hover:bg-neutral-800 transition-colors">Sign In</button>
                    </form>
                </div>

                <div id="auth-panel-register" class="auth-panel hidden">
                    <form onsubmit="event.preventDefault(); app.auth.submitRegister()" class="space-y-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div><label class="block text-[11px] uppercase tracking-widest text-neutral-500 mb-2">First Name</label>
                                 <input type="text" id="auth-reg-fname" required class="w-full bg-white border border-neutral-200 px-4 py-3 text-neutral-900 focus:outline-none focus:border-black"></div>
                            <div><label class="block text-[11px] uppercase tracking-widest text-neutral-500 mb-2">Last Name</label>
                                 <input type="text" id="auth-reg-lname" class="w-full bg-white border border-neutral-200 px-4 py-3 text-neutral-900 focus:outline-none focus:border-black"></div>
                        </div>
                        <div><label class="block text-[11px] uppercase tracking-widest text-neutral-500 mb-2">Email</label>
                             <input type="email" id="auth-reg-email" required class="w-full bg-white border border-neutral-200 px-4 py-3 text-neutral-900 focus:outline-none focus:border-black"></div>
                        <div><label class="block text-[11px] uppercase tracking-widest text-neutral-500 mb-2">Password</label>
                             <input type="password" id="auth-reg-pass" required minlength="8" class="w-full bg-white border border-neutral-200 px-4 py-3 text-neutral-900 focus:outline-none focus:border-black"></div>
                        <div><label class="block text-[11px] uppercase tracking-widest text-neutral-500 mb-2">Confirm Password</label>
                             <input type="password" id="auth-reg-pass2" required minlength="8" class="w-full bg-white border border-neutral-200 px-4 py-3 text-neutral-900 focus:outline-none focus:border-black"></div>
                        <div id="auth-reg-error" class="hidden text-[11px] text-red-600 mt-2"></div>
                        <button type="submit" class="w-full bg-black text-white py-3 text-[11px] uppercase tracking-widest font-medium hover:bg-neutral-800 transition-colors">Create Account</button>
                    </form>
                </div>

                <div id="auth-panel-forgot" class="auth-panel hidden">
                    <form onsubmit="event.preventDefault(); app.auth.submitForgot()" class="space-y-6">
                        <p class="text-sm text-neutral-500 leading-relaxed">Enter the email associated with your account and we'll send a reset link when this feature becomes available.</p>
                        <div><label class="block text-[11px] uppercase tracking-widest text-neutral-500 mb-2">Email</label>
                             <input type="email" id="auth-forgot-email" required class="w-full bg-white border border-neutral-200 px-4 py-3 text-neutral-900 focus:outline-none focus:border-black"></div>
                        <button type="submit" class="w-full bg-black text-white py-3 text-[11px] uppercase tracking-widest font-medium hover:bg-neutral-800 transition-colors">Send Reset</button>
                    </form>
                </div>
            </div>
        </div>

        <style>
            .auth-tab { color: rgb(115 115 115); border-bottom: 1px solid transparent; transition: all 0.3s; }
