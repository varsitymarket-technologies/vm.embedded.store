    </main>

    <div id="cart-drawer-overlay" class="fixed inset-0 bg-neutral-900/40 backdrop-blur-xs z-50 pointer-events-none opacity-0 transition-all duration-300" onclick="app.ui.toggleCartDrawer()">
        <div class="absolute right-0 top-0 h-full w-full max-w-md bg-white p-6 sm:p-8 flex flex-col justify-between pointer-events-auto transform translate-x-full transition-transform duration-300 ease-in-out" onclick="event.stopPropagation()">
            <div class="flex flex-col min-h-0 flex-grow">
                <div class="flex items-center justify-between border-b border-neutral-100 pb-4 mb-6">
                    <h3 class="text-xs font-bold uppercase tracking-widest text-neutral-900">Your Shopping Bag</h3>
                    <button onclick="app.ui.toggleCartDrawer()" class="p-1 text-neutral-400 hover:text-black transition-colors"><i data-lucide="x" class="w-5 h-5"></i></button>
