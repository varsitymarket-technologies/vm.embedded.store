<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PTV STUDIO | Urban Armor</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-raw: #0A0A0A;
            --bg-surface: #121212;
            --text-clean: #FFFFFF;
            --text-dim: #707070;
            --bg-volt: #CCFF00;
            --border-heavy: #222222;
        }
        
        body { 
            font-family: 'Space Mono', monospace; 
            background-color: var(--bg-raw); 
            color: var(--text-clean); 
            -webkit-font-smoothing: antialiased;
        }
        .font-impact { font-family: 'Oswald', sans-serif; text-transform: uppercase; }
        
        .view-section { display: none; }
        .view-section.active { display: block; animation: glitchedFade 0.4s steps(4, end) forwards; }
        
        @keyframes glitchedFade {
            from { opacity: 0; transform: translateY(4px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Industrial Inputs */
        .PTV-input { 
            border: 2px solid var(--border-heavy); 
            background-color: #000000;
            color: var(--text-clean);
            border-radius: 0px;
            padding: 16px;
            font-size: 13px;
            transition: all 0.2s cubic-bezier(0.19, 1, 0.22, 1);
        }
        .PTV-input:focus { 
            outline: none; 
            border-color: var(--bg-volt);
        }
        
        /* Tactical Buttons */
        .btn-volt {
            background-color: var(--bg-volt);
            color: #000000;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            transition: all 0.2s ease;
            border-radius: 0px;
        }
        .btn-volt:hover {
            background-color: #FFFFFF;
            box-shadow: 0 0 15px var(--bg-volt);
        }

        .btn-black-ops {
            border: 2px solid var(--border-heavy);
            background-color: transparent;
            color: var(--text-clean);
            text-transform: uppercase;
            transition: all 0.2s ease;
            border-radius: 0px;
        }
        .btn-black-ops:hover {
            border-color: #FFFFFF;
            background-color: #FFFFFF;
            color: #000000;
        }

        /* Custom Scrollbar styling */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: var(--bg-raw); }
        ::-webkit-scrollbar-thumb { background: var(--border-heavy); }
        ::-webkit-scrollbar-thumb:hover { background: var(--bg-volt); }
    </style>

    <!-- D.3.x: customer auth helper (vm-customer.js from same dir as api.php) -->
    <script src="vm-customer.js" defer></script>
    <script>
        window.addEventListener('vm:customer-loaded', function () {
            document.body.dataset.customer = 'logged-in';
            if (window.app && app.auth && typeof app.auth.updateIcon === 'function') app.auth.updateIcon();
        });
        window.addEventListener('vm:customer-login', function () {
            document.body.dataset.customer = 'logged-in';
            if (window.app && app.auth && typeof app.auth.updateIcon === 'function') app.auth.updateIcon();
        });
        window.addEventListener('vm:customer-logout', function () {
            document.body.dataset.customer = 'logged-out';
            if (window.app && app.auth && typeof app.auth.updateIcon === 'function') app.auth.updateIcon();
        });
    </script>
</head>
<body class="min-h-screen flex flex-col justify-between selection:bg-[#CCFF00] selection:text-black">

    <div class="bg-[var(--bg-volt)] text-black text-center py-2 text-xs font-bold tracking-tight uppercase px-4 flex items-center justify-center gap-6 overflow-hidden">
        <span>[DROP 04 / NEO-METROPOLIS ARCHIVE OUT NOW]</span>
        <span class="hidden md:inline">• PTV GLOBAL UNDERGROUND LOGISTICS ENABLED</span>
        <span class="hidden lg:inline">• QUANTITIES CRITICALLY LIMITED</span>
    </div>

    <header class="sticky top-0 bg-[var(--bg-raw)]/95 backdrop-blur-md z-40 border-b-2 border-[var(--border-heavy)]">
        <div class="max-w-7xl mx-auto px-4 h-20 flex items-center justify-between">
            
            <nav class="hidden md:flex items-center space-x-8 text-xs font-bold uppercase tracking-wider">
                <a href="#shop" onclick="app.router.navigate('shop')" class="hover:text-[var(--bg-volt)] transition-colors">/The_Drop</a>
                <a href="#about" onclick="app.router.navigate('about')" class="hover:text-[var(--bg-volt)] transition-colors">/Manifesto</a>
            </nav>

            <a href="#home" onclick="app.router.navigate('home')" class="text-center group">
                <span class="font-impact text-4xl tracking-tighter text-[var(--text-clean)] block group-hover:text-[var(--bg-volt)] transition-colors">PTV STUDIO</span>
            </a>

            <div class="flex items-center space-x-6">
                <button class="hover:text-[var(--bg-volt)] transition-colors" onclick="app.ui.toggleSearchOverlay()" aria-label="Search Inventory">
                    <i data-lucide="terminal" class="w-5 h-5"></i>
                </button>
                <button id="auth-icon-btn" class="hover:text-[var(--bg-volt)] transition-colors flex items-center" onclick="app.auth.iconClick()" aria-label="Account">
                    <span class="sr-only" id="auth-icon-label">Account</span>
                    <i data-lucide="user" class="w-5 h-5"></i>
                </button>
                <button class="hover:text-[var(--bg-volt)] transition-colors flex items-center relative" onclick="app.ui.toggleCartDrawer()" aria-label="Open Inventory Box">
                    <i data-lucide="package" class="w-5 h-5"></i>
                    <span id="global-cart-count" class="absolute -top-2 -right-2 text-[10px] bg-[var(--bg-volt)] text-black w-4.5 h-4.5 flex items-center justify-center opacity-0 transition-opacity font-bold">0</span>
                </button>
            </div>
        </div>
    </header>

    <main class="flex-grow">

        <section id="view-home" class="view-section active">
            <div class="max-w-7xl mx-auto px-4 py-4">
                <div class="relative w-full h-[72vh] min-h-[500px] bg-neutral-900 border-2 border-[var(--border-heavy)] overflow-hidden flex items-end">
                    <img src="https://images.unsplash.com/photo-1552374196-1ab2a1c593e8?q=80&w=1600&auto=format&fit=crop" class="absolute inset-0 w-full h-full object-cover object-center filter grayscale contrast-125 mix-blend-luminosity" alt="Streetwear Editorial Background">
                    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent"></div>
                    
                    <div class="relative z-10 p-6 md:p-12 w-full max-w-3xl">
                        <span class="text-xs font-bold uppercase tracking-widest text-[var(--bg-volt)] px-2 py-1 bg-black border border-[var(--border-heavy)] inline-block mb-4">SYSTEM DROP: LOCALLY CONSTRUCTED</span>
                        <h1 class="font-impact text-5xl sm:text-7xl leading-[0.85] text-white mb-6">ARMOR FOR THE SOUL.</h1>
                        <p class="text-[var(--text-dim)] text-xs sm:text-sm leading-relaxed mb-8 max-w-md font-mono">PTV loops subcultural energy from Yaba and Braamfontein straight into high-grade utility garments. Designed without compromise. Issued in sets.</p>
                        <button onclick="app.router.navigate('shop')" class="px-8 py-4 btn-volt text-xs font-bold">
                            Initialize Cargo Access
                        </button>
                    </div>
                </div>
            </div>

            <div class="max-w-7xl mx-auto px-4 my-16 grid grid-cols-1 md:grid-cols-3 gap-4">
                <div class="border-2 border-[var(--border-heavy)] p-6 bg-[var(--bg-surface)]">
                    <div class="text-[var(--bg-volt)] font-bold mb-2">// 01 / HIGH DENSITY TECH</div>
                    <p class="text-[var(--text-dim)] text-xs leading-relaxed">Heavyweight raw cotton components and custom tactical hardware matrices assembled to secure prolonged product architecture.</p>
                </div>
                <div class="border-2 border-[var(--border-heavy)] p-6 bg-[var(--bg-surface)]">
                    <div class="text-[var(--bg-volt)] font-bold mb-2">// 02 / ZERO INTERMEDIARY</div>
                    <p class="text-[var(--text-dim)] text-xs leading-relaxed">Direct pipeline ecosystem fueling modern underground designers and localized manufacturing spaces across West and Southern Africa.</p>
                </div>
                <div class="border-2 border-[var(--border-heavy)] p-6 bg-[var(--bg-surface)]">
                    <div class="text-[var(--bg-volt)] font-bold mb-2">// 03 / FINITE DISPERSAL</div>
                    <p class="text-[var(--text-dim)] text-xs leading-relaxed">Once allocations hit structural depletion bounds, blueprints are immediately digitalized or permanently archived. No re-prints.</p>
                </div>
            </div>
        </section>

        <section id="view-shop" class="view-section max-w-7xl mx-auto px-4 py-8">
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-baseline mb-8 border-b-2 border-[var(--border-heavy)] pb-4 gap-4">
                <div>
                    <h2 class="font-impact text-3xl">ACTIVE ALLOCATIONS</h2>
                    <p class="text-[var(--text-dim)] text-xs mt-1">Filter catalog parameters to isolate tactical configurations.</p>
                </div>
                <select id="catalog-sort" onchange="app.store.sortCatalog(this.value)" class="bg-black border-2 border-[var(--border-heavy)] p-2 text-xs font-bold uppercase tracking-wider text-[var(--bg-volt)] focus:outline-none cursor-pointer">
                    <option value="featured">SYS_DEFAULT_SORT</option>
                    <option value="price-low">PRICE_VAL // MIN</option>
                    <option value="price-high">PRICE_VAL // MAX</option>
                </select>
            </div>

            <div id="shop-items-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
                </div>
        </section>

        <section id="view-product" class="view-section max-w-7xl mx-auto px-4 py-8">
            <div id="product-detail-target" class="grid grid-cols-1 lg:grid-cols-12 gap-8">
                </div>
        </section>

        <section id="view-about" class="view-section max-w-4xl mx-auto px-4 py-16 text-left">
            <span class="text-[var(--bg-volt)] text-xs font-bold block mb-2">// MISSION PROTOCOL: RADICAL GENERATION</span>
            <h2 class="font-impact text-4xl sm:text-5xl mb-6">WE ARE THE SYSTEM UPGRADE.</h2>
            <div class="space-y-6 text-[var(--text-dim)] text-xs sm:text-sm leading-relaxed font-mono">
                <p>PTV operates as a premium brutalist streetwear framework focused on decentralizing apparel trade routes. We stand as a platform for radical youth enterprise, ensuring 100% trace-integrity back to independent production nodes in Lagos, Johannesburg, and Nairobi.</p>
                <p>By routing high-velocity capsule sales capital straight to our operational units, we support tech-literacy programs and sustainable fabrication environments across the continent. This is not fast fashion. This is urban infrastructure.</p>
            </div>
            <div class="mt-12 grid grid-cols-2 sm:grid-cols-4 gap-4">
                <div class="border border-[var(--border-heavy)] p-4 bg-black text-center"><div class="font-impact text-2xl text-[var(--text-clean)]">94%</div><div class="text-[9px] text-[var(--text-dim)] uppercase mt-1">Direct Return Margins</div></div>
                <div class="border border-[var(--border-heavy)] p-4 bg-black text-center"><div class="font-impact text-2xl text-[var(--bg-volt)]">04</div><div class="text-[9px] text-[var(--text-dim)] uppercase mt-1">Active Hub Cities</div></div>
                <div class="border border-[var(--border-heavy)] p-4 bg-black text-center"><div class="font-impact text-2xl text-[var(--text-clean)]">14oz</div><div class="text-[9px] text-[var(--text-dim)] uppercase mt-1">Min Denim Spec</div></div>
                <div class="border border-[var(--border-heavy)] p-4 bg-black text-center"><div class="font-impact text-2xl text-[var(--bg-volt)]">100%</div><div class="text-[9px] text-[var(--text-dim)] uppercase mt-1">Independent Led</div></div>
            </div>
        </section>

        <!-- D.3.x: account view -->
        <section id="view-account" class="view-section max-w-5xl mx-auto px-4 py-8">
            <div class="flex items-center justify-between mb-12">
                <div>
                    <p class="text-[10px] uppercase tracking-widest text-[var(--bg-volt)] font-bold">/Account</p>
                    <h1 id="acc-greeting" class="font-impact text-4xl text-[var(--text-clean)] mt-2 tracking-tighter">Welcome</h1>
                </div>
                <button onclick="app.auth.doLogout()" class="text-[10px] uppercase tracking-widest text-[var(--text-dim)] hover:text-[var(--bg-volt)] font-bold">/Sign_Out</button>
            </div>

            <div class="flex space-x-8 border-b-2 border-[var(--border-heavy)] mb-8">
                <button id="acc-tab-overview" onclick="app.auth.activateTab('overview')" class="acc-tab pb-3 text-[11px] uppercase tracking-widest font-bold">Overview</button>
                <button id="acc-tab-profile"  onclick="app.auth.activateTab('profile')"  class="acc-tab pb-3 text-[11px] uppercase tracking-widest font-bold">Profile</button>
                <button id="acc-tab-orders"   onclick="app.auth.activateTab('orders')"   class="acc-tab pb-3 text-[11px] uppercase tracking-widest font-bold">Orders</button>
                <button id="acc-tab-password" onclick="app.auth.activateTab('password')" class="acc-tab pb-3 text-[11px] uppercase tracking-widest font-bold">Password</button>
            </div>

            <div id="acc-panel-overview" class="acc-panel">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
                    <div><p class="text-[10px] uppercase tracking-widest text-[var(--text-dim)] font-bold">Name</p><p id="acc-ov-name" class="text-sm text-[var(--text-clean)] mt-2">—</p></div>
                    <div><p class="text-[10px] uppercase tracking-widest text-[var(--text-dim)] font-bold">Email</p><p id="acc-ov-email" class="text-sm text-[var(--text-clean)] mt-2">—</p></div>
                    <div><p class="text-[10px] uppercase tracking-widest text-[var(--text-dim)] font-bold">Member Since</p><p id="acc-ov-joined" class="text-sm text-[var(--text-clean)] mt-2">—</p></div>
                </div>
                <button onclick="app.auth.activateTab('profile')" class="text-[10px] uppercase tracking-widest text-[var(--bg-volt)] border-b border-[var(--bg-volt)] pb-0.5 font-bold">/Edit_Profile</button>
            </div>

            <div id="acc-panel-profile" class="acc-panel hidden">
                <form onsubmit="event.preventDefault(); app.auth.saveProfile()" class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div><label class="block text-[10px] uppercase tracking-widest text-[var(--text-dim)] mb-2 font-bold">First Name</label>
                             <input type="text" id="acc-fname" class="w-full bg-[var(--bg-surface)] border-2 border-[var(--border-heavy)] px-4 py-3 text-[var(--text-clean)] focus:outline-none focus:border-[var(--bg-volt)]"></div>
                        <div><label class="block text-[10px] uppercase tracking-widest text-[var(--text-dim)] mb-2 font-bold">Last Name</label>
                             <input type="text" id="acc-lname" class="w-full bg-[var(--bg-surface)] border-2 border-[var(--border-heavy)] px-4 py-3 text-[var(--text-clean)] focus:outline-none focus:border-[var(--bg-volt)]"></div>
                    </div>
                    <div><label class="block text-[10px] uppercase tracking-widest text-[var(--text-dim)] mb-2 font-bold">Email</label>
                         <input type="email" id="acc-email" readonly title="Email is the account identifier and cannot be changed here" class="w-full bg-[var(--bg-raw)] border-2 border-[var(--border-heavy)] px-4 py-3 text-[var(--text-dim)] cursor-not-allowed"></div>
                    <div><label class="block text-[10px] uppercase tracking-widest text-[var(--text-dim)] mb-2 font-bold">Phone (optional)</label>
                         <input type="tel" id="acc-phone" class="w-full bg-[var(--bg-surface)] border-2 border-[var(--border-heavy)] px-4 py-3 text-[var(--text-clean)] focus:outline-none focus:border-[var(--bg-volt)]"></div>
                    <button type="submit" class="w-full bg-[var(--bg-volt)] text-black py-3 text-[11px] uppercase tracking-widest font-bold hover:bg-white transition-colors">/Save</button>
                </form>
            </div>

            <div id="acc-panel-orders" class="acc-panel hidden">
                <div id="acc-orders-list">
                    <p class="text-[10px] uppercase tracking-widest text-[var(--text-dim)] py-12 text-center font-bold">/Loading…</p>
                </div>
            </div>

            <div id="acc-panel-password" class="acc-panel hidden">
                <form onsubmit="event.preventDefault(); app.auth.changePassword()" class="space-y-6">
                    <div><label class="block text-[10px] uppercase tracking-widest text-[var(--text-dim)] mb-2 font-bold">Current Password</label>
                         <input type="password" id="acc-pw-cur" required class="w-full bg-[var(--bg-surface)] border-2 border-[var(--border-heavy)] px-4 py-3 text-[var(--text-clean)] focus:outline-none focus:border-[var(--bg-volt)]"></div>
                    <div><label class="block text-[10px] uppercase tracking-widest text-[var(--text-dim)] mb-2 font-bold">New Password</label>
                         <input type="password" id="acc-pw-new" required minlength="8" class="w-full bg-[var(--bg-surface)] border-2 border-[var(--border-heavy)] px-4 py-3 text-[var(--text-clean)] focus:outline-none focus:border-[var(--bg-volt)]"></div>
                    <div><label class="block text-[10px] uppercase tracking-widest text-[var(--text-dim)] mb-2 font-bold">Confirm New Password</label>
                         <input type="password" id="acc-pw-conf" required minlength="8" class="w-full bg-[var(--bg-surface)] border-2 border-[var(--border-heavy)] px-4 py-3 text-[var(--text-clean)] focus:outline-none focus:border-[var(--bg-volt)]"></div>
                    <button type="submit" class="w-full bg-[var(--bg-volt)] text-black py-3 text-[11px] uppercase tracking-widest font-bold hover:bg-white transition-colors">/Change_Password</button>
                </form>
            </div>
        </section>

        <style>
            .acc-tab { color: var(--text-dim); border-bottom: 2px solid transparent; transition: all 0.3s; margin-bottom: -2px; }
            .acc-tab.active { color: var(--text-clean); border-bottom-color: var(--bg-volt); }
        </style>

        <!-- D.3.x: Auth modal overlay -->
        <div id="auth-modal" class="fixed inset-0 bg-[var(--bg-raw)] z-50 hidden flex-col items-center justify-start overflow-y-auto p-6">
            <div class="w-full max-w-md mx-auto pt-12 pb-24">
                <div class="flex items-center justify-between mb-12">
                    <span class="font-impact text-4xl tracking-tighter text-[var(--text-clean)]">PTV STUDIO</span>
                    <button onclick="app.auth.close()" aria-label="Close" class="text-[var(--text-dim)] hover:text-[var(--bg-volt)] transition-colors">
                        <i data-lucide="x" class="w-5 h-5"></i>
                    </button>
                </div>

                <div class="flex space-x-8 border-b-2 border-[var(--border-heavy)] mb-8">
                    <button id="auth-tab-login"    onclick="app.auth.switchTab('login')"    class="auth-tab pb-3 text-[11px] uppercase tracking-widest font-bold">Sign In</button>
                    <button id="auth-tab-register" onclick="app.auth.switchTab('register')" class="auth-tab pb-3 text-[11px] uppercase tracking-widest font-bold">Create</button>
                    <button id="auth-tab-forgot"   onclick="app.auth.switchTab('forgot')"   class="auth-tab pb-3 text-[11px] uppercase tracking-widest font-bold">Forgot</button>
                </div>

                <div id="auth-panel-login" class="auth-panel">
                    <form onsubmit="event.preventDefault(); app.auth.submitLogin()" class="space-y-6">
                        <div><label class="block text-[10px] uppercase tracking-widest text-[var(--text-dim)] mb-2 font-bold">Email</label>
                            <input type="email" id="auth-login-email" required class="w-full bg-[var(--bg-surface)] border-2 border-[var(--border-heavy)] px-4 py-3 text-[var(--text-clean)] focus:outline-none focus:border-[var(--bg-volt)]"></div>
                        <div><label class="block text-[10px] uppercase tracking-widest text-[var(--text-dim)] mb-2 font-bold">Password</label>
                            <input type="password" id="auth-login-pass" required class="w-full bg-[var(--bg-surface)] border-2 border-[var(--border-heavy)] px-4 py-3 text-[var(--text-clean)] focus:outline-none focus:border-[var(--bg-volt)]"></div>
                        <div id="auth-login-error" class="hidden text-[11px] text-red-500 mt-2 font-bold"></div>
                        <button type="submit" class="w-full bg-[var(--bg-volt)] text-black py-3 text-[11px] uppercase tracking-widest font-bold hover:bg-white transition-colors">/Sign_In</button>
                    </form>
                </div>

                <div id="auth-panel-register" class="auth-panel hidden">
                    <form onsubmit="event.preventDefault(); app.auth.submitRegister()" class="space-y-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div><label class="block text-[10px] uppercase tracking-widest text-[var(--text-dim)] mb-2 font-bold">First Name</label>
                                 <input type="text" id="auth-reg-fname" required class="w-full bg-[var(--bg-surface)] border-2 border-[var(--border-heavy)] px-4 py-3 text-[var(--text-clean)] focus:outline-none focus:border-[var(--bg-volt)]"></div>
                            <div><label class="block text-[10px] uppercase tracking-widest text-[var(--text-dim)] mb-2 font-bold">Last Name</label>
                                 <input type="text" id="auth-reg-lname" class="w-full bg-[var(--bg-surface)] border-2 border-[var(--border-heavy)] px-4 py-3 text-[var(--text-clean)] focus:outline-none focus:border-[var(--bg-volt)]"></div>
                        </div>
                        <div><label class="block text-[10px] uppercase tracking-widest text-[var(--text-dim)] mb-2 font-bold">Email</label>
                             <input type="email" id="auth-reg-email" required class="w-full bg-[var(--bg-surface)] border-2 border-[var(--border-heavy)] px-4 py-3 text-[var(--text-clean)] focus:outline-none focus:border-[var(--bg-volt)]"></div>
                        <div><label class="block text-[10px] uppercase tracking-widest text-[var(--text-dim)] mb-2 font-bold">Password</label>
                             <input type="password" id="auth-reg-pass" required minlength="8" class="w-full bg-[var(--bg-surface)] border-2 border-[var(--border-heavy)] px-4 py-3 text-[var(--text-clean)] focus:outline-none focus:border-[var(--bg-volt)]"></div>
                        <div><label class="block text-[10px] uppercase tracking-widest text-[var(--text-dim)] mb-2 font-bold">Confirm Password</label>
                             <input type="password" id="auth-reg-pass2" required minlength="8" class="w-full bg-[var(--bg-surface)] border-2 border-[var(--border-heavy)] px-4 py-3 text-[var(--text-clean)] focus:outline-none focus:border-[var(--bg-volt)]"></div>
                        <div id="auth-reg-error" class="hidden text-[11px] text-red-500 mt-2 font-bold"></div>
                        <button type="submit" class="w-full bg-[var(--bg-volt)] text-black py-3 text-[11px] uppercase tracking-widest font-bold hover:bg-white transition-colors">/Create_Account</button>
                    </form>
                </div>

                <div id="auth-panel-forgot" class="auth-panel hidden">
                    <form onsubmit="event.preventDefault(); app.auth.submitForgot()" class="space-y-6">
                        <p class="text-sm text-[var(--text-dim)] leading-relaxed">Enter the email associated with your account and we'll send a reset link when this feature becomes available.</p>
                        <div><label class="block text-[10px] uppercase tracking-widest text-[var(--text-dim)] mb-2 font-bold">Email</label>
                             <input type="email" id="auth-forgot-email" required class="w-full bg-[var(--bg-surface)] border-2 border-[var(--border-heavy)] px-4 py-3 text-[var(--text-clean)] focus:outline-none focus:border-[var(--bg-volt)]"></div>
                        <button type="submit" class="w-full bg-[var(--bg-volt)] text-black py-3 text-[11px] uppercase tracking-widest font-bold hover:bg-white transition-colors">/Send_Reset</button>
                    </form>
                </div>
            </div>
