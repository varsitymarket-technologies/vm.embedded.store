<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ANTI CLOTHING</title>
    
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'brand-bg': '#050505',
                        'brand-card': '#111111',
                        'brand-border': '#222222',
                        'brand-text': '#E5E5E5',
                        'brand-mute': '#888888',
                    },
                    fontFamily: {
                        sans: ['Inter', 'system-ui', 'sans-serif'],
                    },
                }
            }
        }
    </script>

    <style type="text/css">
        body { 
            background-color: #050505; 
            color: #E5E5E5;
            -webkit-font-smoothing: antialiased;
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #050505; }
        ::-webkit-scrollbar-thumb { background: #222; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: #333; }

        /* Cart Drawer Animation */
        .cart-drawer {
            transform: translateX(100%);
            transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .cart-drawer.open {
            transform: translateX(0);
        }

        /* Modal Blur */
        .modal-overlay {
            backdrop-filter: blur(8px);
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
        }
        .modal-overlay.open {
            opacity: 1;
            pointer-events: auto;
        }

        /* Hover Zoom */
        .img-zoom:hover img {
            transform: scale(1.08);
        }

        /* Button Pulse */
        .btn-active:active {
            transform: scale(0.96);
        }

        /* View Toggling */
        .view { display: block; animation: fadeIn 0.4s ease; }
        .view.hidden { display: none; }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body class="font-sans antialiased">

    <!-- NAVIGATION -->
    <nav class="fixed top-0 w-full z-50 border-b border-brand-border bg-brand-bg/80 backdrop-blur-md">
        <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
            <a href="#" class="text-xl font-bold tracking-tighter text-white">ANTI<span class="text-white/40">.CLOTHING</span></a>
            
            <div class="flex items-center gap-8 text-sm font-medium">
                <a href="#" onclick="showView('search')" class="hover:text-white transition-colors" title="Search">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                </a>
                <a href="#" onclick="showView('shop')" class="hover:text-white transition-colors hidden md:block" id="nav-shop">Home</a>
                <a href="#" onclick="showView('collection')" class="hover:text-white transition-colors">Catalog</a>
                <a href="#" onclick="showView('blog')" class="hidden md:block hover:text-white transition-colors">Journal</a>
                <a href="#" onclick="handleAccountClick()" id="nav-account" class="hover:text-white transition-colors">Account</a>
                <button onclick="toggleCart()" class="relative group">
                    <span class="hover:text-white transition-colors">Cart</span>
                    <span id="cart-dot" class="absolute -top-1 -right-3 w-4 h-4 bg-white text-black text-[10px] font-bold rounded-full flex items-center justify-center transform scale-0 transition-transform duration-300">0</span>
                </button>
            </div>
        </div>
    </nav>

    <!-- MAIN CONTENT VIEWS -->
    <div id="view-shop" class="view">
        <!-- HERO -->
        <header class="pt-40 pb-20 px-6 max-w-7xl mx-auto">
            <div class="max-w-2xl">
                <h1 class="text-6xl md:text-8xl font-bold tracking-tight leading-none text-white mb-6">ESSENTIALS FOR THE MODERN ERA.</h1>
                <p class="text-lg text-brand-mute leading-relaxed max-w-md">Precision crafted, minimalist essentials designed to elevate your digital and physical space.</p>
            </div>
        </header>

        <!-- PRODUCT GRID -->
        <main id="shop" class="max-w-7xl mx-auto px-6 pb-40">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6" id="catalog-container">
                <!-- Products injected by JS -->
            </div>
        </main>
    </div>

    <!-- ACCOUNT/LOGIN VIEW -->
    <div id="view-account" class="view hidden pt-40 pb-40 px-6 max-w-lg mx-auto text-center">
        <h1 class="text-4xl font-bold text-white mb-4">Welcome</h1>
        <p class="text-brand-mute mb-10">Sign in to manage your orders and preferences.</p>
        <div class="bg-brand-card border border-brand-border p-8 rounded-2xl shadow-2xl">
            <input type="email" id="login-email" placeholder="Email Address" class="w-full bg-brand-bg border border-brand-border p-4 rounded-xl text-white outline-none focus:border-white transition-colors mb-4">
            <button onclick="login()" class="w-full bg-white text-black font-bold py-4 rounded-xl hover:bg-gray-200 transition-colors mb-4 transform active:scale-[0.98]">Login to Account</button>
            <p class="text-[10px] text-brand-mute uppercase tracking-widest">Secure 1-click access</p>
        </div>
    </div>

    <!-- DASHBOARD VIEW -->
    <div id="view-dashboard" class="view hidden pt-40 pb-40 px-6 max-w-7xl mx-auto">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 border-b border-brand-border pb-8">
            <div>
                <h1 class="text-4xl md:text-6xl font-bold text-white mb-2">Welcome back.</h1>
                <p class="text-xl text-brand-mute" id="dash-user-email">guest</p>
            </div>
            <button onclick="logout()" class="text-sm font-semibold uppercase tracking-widest text-brand-mute hover:text-white mt-4 md:mt-0">Sign Out</button>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
            <div class="bg-brand-card border border-brand-border p-8 rounded-2xl shadow-xl transition-all hover:border-white/20">
                <p class="text-[10px] font-bold uppercase tracking-widest text-brand-mute mb-2">Total Orders</p>
                <p class="text-4xl font-bold text-white" id="dash-total-orders">0</p>
            </div>
            <div class="bg-brand-card border border-brand-border p-8 rounded-2xl shadow-xl transition-all hover:border-white/20">
                <p class="text-[10px] font-bold uppercase tracking-widest text-brand-mute mb-2">Total Spent</p>
                <p class="text-4xl font-bold text-white" id="dash-total-spent">$0.00</p>
            </div>
            <div class="bg-brand-card border border-brand-border p-8 rounded-2xl shadow-xl relative overflow-hidden transition-all hover:border-white/20">
                <div class="absolute -right-4 -bottom-4 w-32 h-32 bg-white/5 rounded-full blur-2xl"></div>
                <p class="text-[10px] font-bold uppercase tracking-widest text-brand-mute mb-2">Member Status</p>
                <p class="text-4xl font-bold text-white" id="dash-member-status">VIP</p>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
            <div class="lg:col-span-2">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-2xl font-bold text-white">Recent Orders</h2>
                    <button onclick="showView('orders')" class="text-sm font-medium text-brand-mute hover:text-white transition-colors">View All &rarr;</button>
                </div>
                <div id="dash-recent-orders" class="space-y-4">
                    <!-- Injected via JS -->
                </div>
            </div>
            <div>
                <h2 class="text-2xl font-bold text-white mb-6">Support & Service</h2>
                <div class="bg-brand-card border border-brand-border p-8 rounded-2xl shadow-xl space-y-6">
                    <div>
                        <h3 class="text-white font-medium mb-1">Need help with an order?</h3>
                        <p class="text-sm text-brand-mute mb-6">Our premium support team is available 24/7 to assist you.</p>
                        <button onclick="alert('Support initiated. A representative will contact you via email shortly.')" class="w-full bg-brand-bg border border-brand-border text-white py-4 rounded-xl hover:border-white transition-colors text-sm font-semibold active:scale-[0.98]">Contact Concierge</button>
                    </div>
                    <hr class="border-brand-border">
                    <div class="space-y-4">
                        <h3 class="text-[10px] font-bold uppercase tracking-widest text-brand-mute">Self-Service</h3>
                        <a href="#" class="block text-sm text-brand-mute hover:text-white transition-colors">Track a Package</a>
                        <a href="#" class="block text-sm text-brand-mute hover:text-white transition-colors">Start a Return</a>
                        <a href="#" class="block text-sm text-brand-mute hover:text-white transition-colors">Warranty Policy</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ORDERS VIEW -->
    <div id="view-orders" class="view hidden pt-40 pb-40 px-6 max-w-5xl mx-auto">
        <div class="flex items-center gap-6 mb-12">
            <button onclick="showView('dashboard')" class="w-12 h-12 rounded-full border border-brand-border flex items-center justify-center bg-brand-card hover:bg-white hover:text-black transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
            </button>
            <h1 class="text-4xl md:text-5xl font-bold text-white">Order History</h1>
        </div>
        <div id="orders-list" class="space-y-4">
            <!-- Injected via JS -->
        </div>
    </div>

    <!-- ORDER DETAIL VIEW -->
    <div id="view-order-detail" class="view hidden pt-40 pb-40 px-6 max-w-5xl mx-auto">
        <div class="flex justify-between items-start mb-12 border-b border-brand-border pb-8">
            <div class="flex items-center gap-6">
                <button onclick="showView('orders')" class="w-12 h-12 rounded-full border border-brand-border flex items-center justify-center bg-brand-card hover:bg-white hover:text-black transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
                </button>
                <div>
                    <h1 class="text-4xl md:text-5xl font-bold text-white">Order #<span id="detail-id"></span></h1>
                    <p class="text-brand-mute mt-2">Placed on <span id="detail-date" class="text-white"></span></p>
                </div>
            </div>
            <button onclick="reorderCurrent()" class="hidden md:flex bg-white text-black font-bold py-4 px-8 rounded-full hover:bg-gray-200 transition-colors items-center gap-3 active:scale-[0.98]">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                Reorder All
            </button>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
            <div class="md:col-span-2">
                <h3 class="text-xs font-bold uppercase tracking-widest text-brand-mute mb-6">Items</h3>
                <div id="detail-items" class="space-y-4">
                    <!-- Injected via JS -->
                </div>
            </div>
            <div>
                <div class="bg-brand-card border border-brand-border p-8 rounded-2xl shadow-xl mb-6">
                    <h3 class="text-xs font-bold uppercase tracking-widest text-brand-mute mb-6">Summary</h3>
                    <div class="space-y-4 mb-8">
                        <div class="flex justify-between text-sm"><span class="text-brand-mute">Subtotal</span><span class="text-white font-medium" id="detail-subtotal">$0.00</span></div>
                        <div class="flex justify-between text-sm"><span class="text-brand-mute">Shipping</span><span class="text-white font-medium">FREE</span></div>
                    </div>
                    <div class="pt-6 border-t border-brand-border flex justify-between items-center text-xl font-bold text-white">
                        <span>Total</span><span id="detail-total">$0.00</span>
                    </div>
                </div>
                <div class="bg-brand-card border border-brand-border p-8 rounded-2xl shadow-xl">
                    <h3 class="text-xs font-bold uppercase tracking-widest text-brand-mute mb-4">Status</h3>
                    <p class="text-3xl font-bold text-white tracking-tight" id="detail-status">Processing</p>
                    <div class="mt-6 w-full bg-brand-bg rounded-full h-2 overflow-hidden border border-brand-border">
                        <div class="bg-white h-full w-1/3 rounded-full"></div>
                    </div>
                    <p class="text-xs text-brand-mute mt-4">We are preparing your order. You will receive an update shortly.</p>
                </div>
            </div>
        </div>
        
        <button onclick="reorderCurrent()" class="w-full mt-10 md:hidden bg-white text-black font-bold py-5 rounded-full shadow-2xl active:scale-[0.98] transition-transform flex justify-center items-center gap-2">
            Reorder All
        </button>
    </div>

    <!-- PRODUCT PDP VIEW -->
    <div id="view-product" class="view hidden pt-32 pb-40 px-6 max-w-7xl mx-auto">
        <div class="flex items-center gap-6 mb-8 text-sm text-brand-mute font-medium">
            <a href="#" onclick="showView('collection')" class="hover:text-white transition-colors">Catalog</a>
            <span>/</span>
            <span class="text-white" id="pdp-category">Category</span>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-16 mb-20">
            <div class="bg-brand-card rounded-3xl overflow-hidden aspect-square border border-brand-border">
                <img id="pdp-img" src="" class="w-full h-full object-cover">
            </div>
            <div class="flex flex-col justify-center">
                <h1 id="pdp-name" class="text-5xl font-bold text-white mb-4">Product Name</h1>
                <p id="pdp-price" class="text-2xl text-brand-mute mb-8">$0.00</p>
                <div class="mb-8">
                    <p class="text-xs font-bold uppercase tracking-widest text-brand-mute mb-3">Color Options</p>
                    <div class="flex gap-3">
                        <button class="w-10 h-10 rounded-full bg-[#111111] border-2 border-brand-border hover:border-white focus:border-white focus:scale-110 transition-all"></button>
                        <button class="w-10 h-10 rounded-full bg-[#444444] border-2 border-brand-border hover:border-white focus:border-white focus:scale-110 transition-all"></button>
                        <button class="w-10 h-10 rounded-full bg-[#E5E5E5] border-2 border-brand-border hover:border-white focus:border-white focus:scale-110 transition-all"></button>
                    </div>
                </div>
                <div class="mb-10">
                    <p class="text-xs font-bold uppercase tracking-widest text-brand-mute mb-3">Quantity</p>
                    <div class="flex items-center gap-6 bg-brand-bg w-max px-2 py-2 rounded-full border border-brand-border shadow-inner">
                        <button onclick="changePdpQty(-1)" class="w-10 h-10 rounded-full flex items-center justify-center hover:bg-brand-card transition-colors text-white"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"></line></svg></button>
                        <span id="pdp-qty" class="text-lg font-bold text-white w-4 text-center">1</span>
                        <button onclick="changePdpQty(1)" class="w-10 h-10 rounded-full flex items-center justify-center hover:bg-brand-card transition-colors text-white"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg></button>
                    </div>
                </div>
                <button id="pdp-add" onclick="addPdpToCart()" class="w-full bg-white text-black font-bold py-5 rounded-full hover:bg-gray-200 transition-transform active:scale-[0.98] mb-12 shadow-2xl">
                    Add to Bag
                </button>
                <div class="space-y-6 bg-brand-card border border-brand-border p-8 rounded-3xl">
                    <h3 class="text-sm font-bold uppercase tracking-widest text-white">Details</h3>
                    <p id="pdp-desc" class="text-brand-mute leading-relaxed text-sm">...</p>
                </div>
            </div>
        </div>
        <div class="border-t border-brand-border pt-20">
            <h2 class="text-3xl font-bold text-white mb-10">Customer Insights</h2>
            <div id="pdp-reviews" class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <!-- Injected via JS -->
            </div>
        </div>
    </div>

    <!-- COLLECTION VIEW -->
    <div id="view-collection" class="view hidden pt-40 pb-40 px-6 max-w-7xl mx-auto">
        <h1 class="text-5xl md:text-7xl font-bold text-white mb-6">The Collection</h1>
        <p class="text-lg text-brand-mute mb-12 max-w-2xl">Browse our entire range of premium, minimalist essentials curated for modern life.</p>
        
        <div class="flex gap-4 mb-12 overflow-x-auto pb-4 no-scrollbar border-b border-brand-border" id="collection-filters">
            <button onclick="filterCollection('all')" id="filter-all" class="filter-btn text-white font-bold border-b-2 border-white pb-3 whitespace-nowrap">All Items</button>
            <button onclick="filterCollection('Tech')" id="filter-Tech" class="filter-btn text-brand-mute hover:text-white pb-3 whitespace-nowrap transition-colors border-b-2 border-transparent hover:border-brand-mute">Tech</button>
            <button onclick="filterCollection('Accessories')" id="filter-Accessories" class="filter-btn text-brand-mute hover:text-white pb-3 whitespace-nowrap transition-colors border-b-2 border-transparent hover:border-brand-mute">Accessories</button>
            <button onclick="filterCollection('Home')" id="filter-Home" class="filter-btn text-brand-mute hover:text-white pb-3 whitespace-nowrap transition-colors border-b-2 border-transparent hover:border-brand-mute">Home Office</button>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-x-6 gap-y-12" id="collection-grid">
            <!-- Injected via JS -->
        </div>
    </div>

    <!-- ABOUT VIEW -->
    <div id="view-about" class="view hidden pt-40 pb-40 px-6 max-w-4xl mx-auto text-center">
        <h1 class="text-5xl md:text-7xl font-bold text-white mb-8">Our Philosophy</h1>
        <img src="https://images.unsplash.com/photo-1553062407-98eeb64c6a62?q=80&w=1200&auto=format&fit=crop" class="w-full h-[400px] object-cover rounded-3xl mb-12 grayscale-[0.2]">
        <div class="text-left space-y-6 text-lg text-brand-mute leading-relaxed">
            <p><strong class="text-white">ANTI.CLOTHING</strong> was founded on a simple principle: technology and daily essentials should blend seamlessly into our environments without fighting for attention.</p>
            <p>Every product in our collection is carefully selected or crafted to meet rigorous standards of minimalism, utility, and longevity. We strip away the unnecessary so you can focus on what matters.</p>
        </div>
    </div>

    <!-- CONTACT VIEW -->
    <div id="view-contact" class="view hidden pt-40 pb-40 px-6 max-w-3xl mx-auto">
        <h1 class="text-5xl font-bold text-white mb-4">Get in Touch</h1>
        <p class="text-xl text-brand-mute mb-12">Our concierge team is available worldwide.</p>
        <form onsubmit="event.preventDefault(); alert('Message sent!'); showView('shop');" class="bg-brand-card border border-brand-border p-10 rounded-3xl space-y-8 shadow-2xl">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-xs font-bold uppercase tracking-widest text-brand-mute mb-3">Name</label>
                    <input type="text" required class="w-full bg-brand-bg border border-brand-border p-4 rounded-xl text-white outline-none focus:border-white transition-colors">
                </div>
                <div>
                    <label class="block text-xs font-bold uppercase tracking-widest text-brand-mute mb-3">Email</label>
                    <input type="email" required class="w-full bg-brand-bg border border-brand-border p-4 rounded-xl text-white outline-none focus:border-white transition-colors">
                </div>
            </div>
            <div>
                <label class="block text-xs font-bold uppercase tracking-widest text-brand-mute mb-3">Inquiry Type</label>
                <select class="w-full bg-brand-bg border border-brand-border p-4 rounded-xl text-white outline-none focus:border-white transition-colors appearance-none">
                    <option>Order Support</option>
                    <option>Product Question</option>
                    <option>Press & Media</option>
                </select>
            </div>
            <div>
                <label class="block text-xs font-bold uppercase tracking-widest text-brand-mute mb-3">Message</label>
                <textarea required rows="5" class="w-full bg-brand-bg border border-brand-border p-4 rounded-xl text-white outline-none focus:border-white transition-colors"></textarea>
            </div>
            <button class="w-full bg-white text-black font-bold py-5 rounded-full hover:bg-gray-200 transition-transform active:scale-[0.98]">Send Message</button>
        </form>
    </div>

    <!-- FAQ VIEW -->
    <div id="view-faq" class="view hidden pt-40 pb-40 px-6 max-w-3xl mx-auto">
        <h1 class="text-5xl font-bold text-white mb-12">FAQ</h1>
        <div class="space-y-4">
            <div class="bg-brand-card border border-brand-border p-8 rounded-3xl shadow-xl">
                <h3 class="text-lg font-bold text-white mb-2">What is your return policy?</h3>
                <p class="text-brand-mute">We accept returns within 30 days of standard delivery. Items must be in original condition and packaging. Customized items are final sale.</p>
            </div>
            <div class="bg-brand-card border border-brand-border p-8 rounded-3xl shadow-xl">
                <h3 class="text-lg font-bold text-white mb-2">How long does shipping take?</h3>
                <p class="text-brand-mute">Premium Express ensures delivery within 1-2 business days. Standard Delivery takes 3-5 business days depending on location.</p>
            </div>
            <div class="bg-brand-card border border-brand-border p-8 rounded-3xl shadow-xl">
                <h3 class="text-lg font-bold text-white mb-2">Do you ship internationally?</h3>
                <p class="text-brand-mute">Yes, we deliver worldwide across 150+ countries. International shipping rates and relevant duties are calculated securely at checkout.</p>
            </div>
        </div>
    </div>

    <!-- POLICIES VIEW -->
    <div id="view-policies" class="view hidden pt-40 pb-40 px-6 max-w-4xl mx-auto">
        <h1 class="text-5xl font-bold text-white mb-12">Legal Policies</h1>
        <div class="space-y-12 text-brand-mute">
            <section class="space-y-4 bg-brand-card p-10 rounded-3xl border border-brand-border">
                <h2 class="text-2xl font-bold text-white">Terms of Service</h2>
                <p>Welcome to ANTI CLOTHING. By accessing this premium storefront, you agree to our standard terms and conditions regarding digital commerce.</p>
                <p>All content remains the intellectual property of VMTECH. Unauthorized reproduction of our minimalist assets is explicitly prohibited.</p>
            </section>
