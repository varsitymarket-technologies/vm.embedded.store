<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CROWN | Luxury Hair & Wigs</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lato:wght@300;400;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
    <style>
        :root {
            --cr-bg: #FCFBFA; /* Soft cream/nude */
            --cr-text: #2A2A2A; /* Charcoal */
            --cr-gold: #C5A059; /* Champagne Gold */
            --cr-gold-light: #E8D5A5;
            --cr-border: #EAE6DF;
            --cr-white: #FFFFFF;
        }
        
        body { 
            font-family: 'Lato', sans-serif; 
            background-color: var(--cr-bg); 
            color: var(--cr-text); 
            -webkit-font-smoothing: antialiased;
        }
        
        .font-serif-elegant { 
            font-family: 'Playfair Display', serif; 
        }

        .view-section { display: none; }
        .view-section.active { display: block; animation: softFade 0.5s ease-in-out forwards; }
        
        @keyframes softFade {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Elegant Inputs */
        .cr-input { 
            border: 1px solid var(--cr-border); 
            background-color: var(--cr-white);
            color: var(--cr-text);
            padding: 14px 16px;
            font-size: 14px;
            transition: all 0.3s ease;
        }
        .cr-input:focus { 
            outline: none; 
            border-color: var(--cr-gold);
            box-shadow: 0 0 0 1px var(--cr-gold);
        }
        
        /* Luxury Buttons */
        .btn-gold {
            background-color: var(--cr-gold);
            color: var(--cr-white);
            font-weight: 400;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            transition: all 0.3s ease;
        }
        .btn-gold:hover {
            background-color: #A98746;
            box-shadow: 0 4px 15px rgba(197, 160, 89, 0.3);
        }

        .btn-outline {
            border: 1px solid var(--cr-text);
            background-color: transparent;
            color: var(--cr-text);
            text-transform: uppercase;
            letter-spacing: 0.1em;
            transition: all 0.3s ease;
        }
        .btn-outline:hover {
            background-color: var(--cr-text);
            color: var(--cr-white);
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: var(--cr-bg); }
        ::-webkit-scrollbar-thumb { background: #D1D1D1; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--cr-gold); }

        /* Soft Image Hover */
        .img-soft {
            transition: transform 0.7s ease, filter 0.7s ease;
        }
        .group:hover .img-soft {
            transform: scale(1.03);
        }
    </style>

    <!-- D.3.x: customer auth helper (vm-customer.js from same dir as api.php) -->
    <script src="vm-customer.js" defer></script>
    <script>
        window.addEventListener('vm:customer-loaded', function () {
            document.body.dataset.customer = 'logged-in';
            if (window.app && app.auth && typeof app.auth.updateIcon === 'function') app.auth.updateIcon();
        });
        window.addEventListener('vm:customer-login', function () {
            document.body.dataset.customer = 'logged-in';
            if (window.app && app.auth && typeof app.auth.updateIcon === 'function') app.auth.updateIcon();
        });
        window.addEventListener('vm:customer-logout', function () {
            document.body.dataset.customer = 'logged-out';
            if (window.app && app.auth && typeof app.auth.updateIcon === 'function') app.auth.updateIcon();
        });
    </script>
</head>
<body class="min-h-screen flex flex-col justify-between selection:bg-[var(--cr-gold-light)] selection:text-[var(--cr-text)]">

    <div class="bg-[var(--cr-text)] text-[var(--cr-white)] text-center py-2 text-[10px] font-bold tracking-[0.2em] uppercase px-4">
        <span>Free Worldwide Shipping on all Wig & Bundle Orders over $200</span>
    </div>

    <header class="sticky top-0 bg-[var(--cr-white)]/95 backdrop-blur-md z-40 border-b border-[var(--cr-border)] shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between">
            
            <nav class="hidden md:flex items-center space-x-8 text-xs font-bold uppercase tracking-widest text-gray-500">
                <a href="#shop" onclick="app.router.navigate('shop', {filter: 'wigs'})" class="hover:text-[var(--cr-gold)] transition-colors">HD Wigs</a>
                <a href="#shop" onclick="app.router.navigate('shop', {filter: 'bundles'})" class="hover:text-[var(--cr-gold)] transition-colors">Raw Bundles</a>
            </nav>

            <a href="#home" onclick="app.router.navigate('home')" class="text-center absolute left-1/2 -translate-x-1/2">
                <span class="font-serif-elegant text-3xl md:text-4xl text-[var(--cr-text)] tracking-wider">CROWN.</span>
            </a>

            <div class="flex items-center space-x-5 text-gray-600">
                <button class="hover:text-[var(--cr-gold)] transition-colors" onclick="app.ui.toggleSearchOverlay()" aria-label="Search">
                    <i data-lucide="search" class="w-5 h-5 stroke-[1.5]"></i>
                </button>
                <button id="auth-icon-btn" class="hover:text-[var(--cr-gold)] transition-colors flex items-center" onclick="app.auth.iconClick()" aria-label="Account">
                    <span class="sr-only" id="auth-icon-label">Account</span>
                    <i data-lucide="user" class="w-5 h-5 stroke-[1.5]"></i>
                </button>
                <button class="hover:text-[var(--cr-gold)] transition-colors flex items-center relative" onclick="app.ui.toggleCartDrawer()" aria-label="Cart">
                    <i data-lucide="shopping-bag" class="w-5 h-5 stroke-[1.5]"></i>
                    <span id="global-cart-count" class="absolute -top-1.5 -right-2 text-[9px] bg-[var(--cr-gold)] text-white w-4 h-4 flex items-center justify-center rounded-full opacity-0 font-bold">0</span>
                </button>
            </div>
        </div>
    </header>

    <main class="flex-grow">

        <section id="view-home" class="view-section active">
            <div class="relative w-full h-[80vh] min-h-[600px] bg-[#E8E4DF] overflow-hidden flex items-center">
                <img src="https://images.unsplash.com/photo-1595959183082-7b570b7e08e2?q=80&w=1600&auto=format&fit=crop" class="absolute inset-0 w-full h-full object-cover object-[50%_30%] opacity-90" alt="Beautiful woman with flawless hair">
                <div class="absolute inset-0 bg-gradient-to-r from-black/40 to-transparent"></div>
                
                <div class="relative z-10 p-8 md:p-16 w-full max-w-2xl text-[var(--cr-white)]">
                    <span class="text-xs font-bold uppercase tracking-[0.2em] mb-4 block">The Signature Collection</span>
                    <h1 class="font-serif-elegant text-5xl sm:text-7xl leading-tight mb-6">Flawless from <br>root to tip.</h1>
                    <p class="text-sm md:text-base leading-relaxed mb-10 max-w-md font-light text-gray-100">Experience 100% raw virgin hair. Pre-plucked HD lace fronts designed to melt seamlessly into your skin.</p>
                    <button onclick="app.router.navigate('shop')" class="px-10 py-4 bg-[var(--cr-white)] text-[var(--cr-text)] text-xs font-bold uppercase tracking-widest hover:bg-[var(--cr-gold)] hover:text-white transition-colors duration-300">
                        Shop The Look
                    </button>
                </div>
            </div>

            <div class="max-w-7xl mx-auto px-4 py-16 grid grid-cols-2 md:grid-cols-4 gap-8 text-center border-b border-[var(--cr-border)]">
                <div class="space-y-3">
                    <i data-lucide="sparkles" class="w-6 h-6 mx-auto text-[var(--cr-gold)] stroke-[1.5]"></i>
                    <h3 class="font-serif-elegant text-lg">100% Virgin Hair</h3>
                    <p class="text-xs text-gray-500 leading-relaxed">Cuticle aligned, completely unprocessed human hair.</p>
                </div>
                <div class="space-y-3">
                    <i data-lucide="scissors" class="w-6 h-6 mx-auto text-[var(--cr-gold)] stroke-[1.5]"></i>
                    <h3 class="font-serif-elegant text-lg">Pre-Plucked Hairlines</h3>
                    <p class="text-xs text-gray-500 leading-relaxed">Ready to wear out of the box with natural baby hairs.</p>
                </div>
                <div class="space-y-3">
                    <i data-lucide="eye" class="w-6 h-6 mx-auto text-[var(--cr-gold)] stroke-[1.5]"></i>
                    <h3 class="font-serif-elegant text-lg">Invisible HD Lace</h3>
                    <p class="text-xs text-gray-500 leading-relaxed">Ultra-thin Swiss lace that melts into all skin tones.</p>
                </div>
                <div class="space-y-3">
                    <i data-lucide="truck" class="w-6 h-6 mx-auto text-[var(--cr-gold)] stroke-[1.5]"></i>
                    <h3 class="font-serif-elegant text-lg">Express Shipping</h3>
                    <p class="text-xs text-gray-500 leading-relaxed">Fast, reliable delivery straight to your doorstep.</p>
                </div>
            </div>

            <div class="max-w-7xl mx-auto px-4 py-20 text-center">
                <h2 class="font-serif-elegant text-4xl mb-4">Trending Styles</h2>
                <p class="text-sm text-gray-500 mb-12">The pieces everyone is wearing this season.</p>
                <div id="featured-items-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 text-left">
                    </div>
                <button onclick="app.router.navigate('shop')" class="mt-12 px-12 py-4 btn-outline text-xs font-bold tracking-widest">
                    View Entire Collection
                </button>
            </div>
        </section>

        <section id="view-shop" class="view-section max-w-7xl mx-auto px-4 py-12">
            <div class="flex flex-col md:flex-row justify-between items-center mb-12 gap-6">
                <h2 class="font-serif-elegant text-4xl">The Boutique</h2>
                <div class="flex gap-4">
                    <button onclick="app.store.filterCatalog('all')" class="text-xs font-bold uppercase tracking-widest text-gray-400 hover:text-[var(--cr-text)] focus:text-[var(--cr-text)] pb-1 border-b-2 border-transparent focus:border-[var(--cr-gold)] transition-all">All</button>
                    <button onclick="app.store.filterCatalog('Wigs')" class="text-xs font-bold uppercase tracking-widest text-gray-400 hover:text-[var(--cr-text)] focus:text-[var(--cr-text)] pb-1 border-b-2 border-transparent focus:border-[var(--cr-gold)] transition-all">HD Wigs</button>
                    <button onclick="app.store.filterCatalog('Bundles')" class="text-xs font-bold uppercase tracking-widest text-gray-400 hover:text-[var(--cr-text)] focus:text-[var(--cr-text)] pb-1 border-b-2 border-transparent focus:border-[var(--cr-gold)] transition-all">Bundles</button>
                </div>
            </div>

            <div id="shop-items-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-x-6 gap-y-12">
                </div>
        </section>

        <section id="view-product" class="view-section max-w-7xl mx-auto px-4 py-12">
            <div id="product-detail-target" class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
                </div>
        </section>

        <!-- D.3.x: account view -->
        <section id="view-account" class="view-section max-w-5xl mx-auto px-4 py-12">
            <div class="flex items-center justify-between mb-12">
                <div>
                    <p class="text-[11px] uppercase tracking-[0.2em] text-gray-500">Account</p>
                    <h1 id="acc-greeting" class="font-serif-elegant text-4xl text-[var(--cr-text)] mt-2">Welcome</h1>
                </div>
                <button onclick="app.auth.doLogout()" class="text-[11px] uppercase tracking-[0.15em] text-gray-500 hover:text-[var(--cr-text)]">Sign Out</button>
            </div>

            <div class="flex space-x-8 border-b border-[var(--cr-border)] mb-8">
                <button id="acc-tab-overview" onclick="app.auth.activateTab('overview')" class="acc-tab pb-3 text-[11px] uppercase tracking-[0.15em]">Overview</button>
                <button id="acc-tab-profile"  onclick="app.auth.activateTab('profile')"  class="acc-tab pb-3 text-[11px] uppercase tracking-[0.15em]">Profile</button>
                <button id="acc-tab-orders"   onclick="app.auth.activateTab('orders')"   class="acc-tab pb-3 text-[11px] uppercase tracking-[0.15em]">Orders</button>
                <button id="acc-tab-password" onclick="app.auth.activateTab('password')" class="acc-tab pb-3 text-[11px] uppercase tracking-[0.15em]">Password</button>
            </div>

            <div id="acc-panel-overview" class="acc-panel">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
                    <div><p class="text-[11px] uppercase tracking-[0.15em] text-gray-500">Name</p><p id="acc-ov-name" class="text-sm text-[var(--cr-text)] mt-2">—</p></div>
                    <div><p class="text-[11px] uppercase tracking-[0.15em] text-gray-500">Email</p><p id="acc-ov-email" class="text-sm text-[var(--cr-text)] mt-2">—</p></div>
                    <div><p class="text-[11px] uppercase tracking-[0.15em] text-gray-500">Member Since</p><p id="acc-ov-joined" class="text-sm text-[var(--cr-text)] mt-2">—</p></div>
                </div>
                <button onclick="app.auth.activateTab('profile')" class="text-[11px] uppercase tracking-[0.15em] text-[var(--cr-text)] border-b border-[var(--cr-text)] pb-0.5">Edit profile</button>
            </div>

            <div id="acc-panel-profile" class="acc-panel hidden">
                <form onsubmit="event.preventDefault(); app.auth.saveProfile()" class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div><label class="block text-[11px] uppercase tracking-[0.15em] text-gray-500 mb-2">First Name</label>
                             <input type="text" id="acc-fname" class="cr-input w-full"></div>
                        <div><label class="block text-[11px] uppercase tracking-[0.15em] text-gray-500 mb-2">Last Name</label>
                             <input type="text" id="acc-lname" class="cr-input w-full"></div>
                    </div>
                    <div><label class="block text-[11px] uppercase tracking-[0.15em] text-gray-500 mb-2">Email</label>
                         <input type="email" id="acc-email" readonly title="Email is the account identifier and cannot be changed here" class="cr-input w-full bg-gray-100 cursor-not-allowed"></div>
                    <div><label class="block text-[11px] uppercase tracking-[0.15em] text-gray-500 mb-2">Phone (optional)</label>
                         <input type="tel" id="acc-phone" class="cr-input w-full"></div>
                    <button type="submit" class="btn-gold w-full py-3 text-sm">Save</button>
                </form>
            </div>

            <div id="acc-panel-orders" class="acc-panel hidden">
                <div id="acc-orders-list">
                    <p class="text-[11px] uppercase tracking-[0.15em] text-neutral-500 py-12 text-center">Loading…</p>
                </div>
            </div>

            <div id="acc-panel-password" class="acc-panel hidden">
                <form onsubmit="event.preventDefault(); app.auth.changePassword()" class="space-y-6">
                    <div><label class="block text-[11px] uppercase tracking-[0.15em] text-gray-500 mb-2">Current Password</label>
                         <input type="password" id="acc-pw-cur" required class="cr-input w-full"></div>
                    <div><label class="block text-[11px] uppercase tracking-[0.15em] text-gray-500 mb-2">New Password</label>
                         <input type="password" id="acc-pw-new" required minlength="8" class="cr-input w-full"></div>
                    <div><label class="block text-[11px] uppercase tracking-[0.15em] text-gray-500 mb-2">Confirm New Password</label>
                         <input type="password" id="acc-pw-conf" required minlength="8" class="cr-input w-full"></div>
                    <button type="submit" class="btn-gold w-full py-3 text-sm">Change Password</button>
                </form>
            </div>
        </section>

        <style>
            .acc-tab { color: rgb(115 115 115); border-bottom: 1px solid transparent; transition: all 0.3s; }
            .acc-tab.active { color: var(--cr-text); border-bottom-color: var(--cr-text); }
        </style>

        <!-- D.3.x: Auth modal overlay -->
        <div id="auth-modal" class="fixed inset-0 bg-[var(--cr-bg)] z-50 hidden flex-col items-center justify-start overflow-y-auto p-6">
            <div class="w-full max-w-md mx-auto pt-12 pb-24">
                <div class="flex items-center justify-between mb-12">
                    <span class="font-serif-elegant text-2xl text-[var(--cr-text)]">CROWN.</span>
                    <button onclick="app.auth.close()" aria-label="Close" class="text-gray-500 hover:text-[var(--cr-text)] transition-colors">
                        <i data-lucide="x" class="w-5 h-5"></i>
                    </button>
                </div>

                <div class="flex space-x-8 border-b border-[var(--cr-border)] mb-8">
                    <button id="auth-tab-login"    onclick="app.auth.switchTab('login')"    class="auth-tab pb-3 text-[11px] uppercase tracking-[0.15em]">Sign In</button>
                    <button id="auth-tab-register" onclick="app.auth.switchTab('register')" class="auth-tab pb-3 text-[11px] uppercase tracking-[0.15em]">Create</button>
                    <button id="auth-tab-forgot"   onclick="app.auth.switchTab('forgot')"   class="auth-tab pb-3 text-[11px] uppercase tracking-[0.15em]">Forgot</button>
                </div>

                <div id="auth-panel-login" class="auth-panel">
                    <form onsubmit="event.preventDefault(); app.auth.submitLogin()" class="space-y-6">
                        <div>
                            <label class="block text-[11px] uppercase tracking-[0.15em] text-gray-500 mb-2">Email</label>
                            <input type="email" id="auth-login-email" required class="cr-input w-full">
                        </div>
                        <div>
                            <label class="block text-[11px] uppercase tracking-[0.15em] text-gray-500 mb-2">Password</label>
                            <input type="password" id="auth-login-pass" required class="cr-input w-full">
                        </div>
                        <div id="auth-login-error" class="hidden text-[11px] text-red-600 mt-2"></div>
                        <button type="submit" class="btn-gold w-full py-3 text-sm">Sign In</button>
                    </form>
                </div>

                <div id="auth-panel-register" class="auth-panel hidden">
                    <form onsubmit="event.preventDefault(); app.auth.submitRegister()" class="space-y-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div><label class="block text-[11px] uppercase tracking-[0.15em] text-gray-500 mb-2">First Name</label>
                                 <input type="text" id="auth-reg-fname" required class="cr-input w-full"></div>
                            <div><label class="block text-[11px] uppercase tracking-[0.15em] text-gray-500 mb-2">Last Name</label>
                                 <input type="text" id="auth-reg-lname" class="cr-input w-full"></div>
                        </div>
                        <div><label class="block text-[11px] uppercase tracking-[0.15em] text-gray-500 mb-2">Email</label>
                             <input type="email" id="auth-reg-email" required class="cr-input w-full"></div>
                        <div><label class="block text-[11px] uppercase tracking-[0.15em] text-gray-500 mb-2">Password</label>
                             <input type="password" id="auth-reg-pass" required minlength="8" class="cr-input w-full"></div>
                        <div><label class="block text-[11px] uppercase tracking-[0.15em] text-gray-500 mb-2">Confirm Password</label>
                             <input type="password" id="auth-reg-pass2" required minlength="8" class="cr-input w-full"></div>
                        <div id="auth-reg-error" class="hidden text-[11px] text-red-600 mt-2"></div>
                        <button type="submit" class="btn-gold w-full py-3 text-sm">Create Account</button>
                    </form>
                </div>

                <div id="auth-panel-forgot" class="auth-panel hidden">
                    <form onsubmit="event.preventDefault(); app.auth.submitForgot()" class="space-y-6">
                        <p class="text-sm text-gray-500 leading-relaxed">Enter the email associated with your account and we'll send a reset link when this feature becomes available.</p>
                        <div><label class="block text-[11px] uppercase tracking-[0.15em] text-gray-500 mb-2">Email</label>
                             <input type="email" id="auth-forgot-email" required class="cr-input w-full"></div>
                        <button type="submit" class="btn-gold w-full py-3 text-sm">Send Reset</button>
                    </form>
                </div>
            </div>
        </div>

        <style>
            .auth-tab { color: rgb(115 115 115); border-bottom: 1px solid transparent; transition: all 0.3s; }
            .auth-tab.active { color: var(--cr-text); border-bottom-color: var(--cr-text); }
            #auth-modal.is-open { display: flex; }
        </style>

        <section id="view-checkout" class="view-section max-w-5xl mx-auto px-4 py-12">
            <div class="text-center mb-10">
                <h2 class="font-serif-elegant text-4xl mb-2">Secure Checkout</h2>
                <p class="text-gray-500 text-sm">Almost yours.</p>
            </div>
            
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
                <div class="lg:col-span-7">
                    <div class="flex items-center justify-center space-x-6 text-xs font-bold uppercase tracking-widest mb-10 border-b border-[var(--cr-border)] pb-4">
                        <span id="step-nav-1" class="text-[var(--cr-gold)] border-b border-[var(--cr-gold)] pb-1">1. Shipping</span>
                        <span class="text-gray-300">/</span>
                        <span id="step-nav-2" class="text-gray-400">2. Payment</span>
                    </div>

                    <form id="checkout-form" onsubmit="app.checkout.handleStepSubmit(event)" class="space-y-6">
                        <div id="checkout-step-container" class="space-y-4 min-h-[300px]"></div>
                        
                        <div class="flex justify-between items-center pt-8 border-t border-[var(--cr-border)]">
                            <a href="#shop" onclick="app.router.navigate('shop')" class="text-xs uppercase tracking-widest text-gray-500 hover:text-[var(--cr-text)]">Return to Cart</a>
                            <button type="submit" class="px-10 py-4 btn-gold text-xs tracking-widest">
                                Continue
                            </button>
                        </div>
                    </form>
                </div>
                
                <div class="lg:col-span-5 bg-[var(--cr-white)] p-8 border border-[var(--cr-border)] shadow-sm h-fit">
                    <h3 class="font-serif-elegant text-2xl mb-6 border-b border-[var(--cr-border)] pb-4">Order Summary</h3>
                    <div id="checkout-summary-items" class="space-y-4 max-h-[300px] overflow-y-auto mb-6"></div>
                    <div class="space-y-3 text-sm text-gray-600">
                        <div class="flex justify-between"><span>Subtotal</span><span id="chk-sub">$0.00</span></div>
                        <div class="flex justify-between"><span>Shipping</span><span class="text-[var(--cr-gold)]">Calculated at next step</span></div>
                        <div class="flex justify-between items-center pt-6 text-lg border-t border-[var(--cr-border)] text-[var(--cr-text)] font-serif-elegant">
                            <span>Total</span>
                            <span id="chk-total">$0.00</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

    </main>

    <div id="cart-drawer-overlay" class="fixed inset-0 bg-black/40 backdrop-blur-sm z-50 pointer-events-none opacity-0 transition-opacity duration-300" onclick="app.ui.toggleCartDrawer()">
        <div class="absolute right-0 top-0 h-full w-full max-w-[450px] bg-[var(--cr-white)] shadow-2xl flex flex-col justify-between pointer-events-auto transform translate-x-full transition-transform duration-500 ease-in-out" onclick="event.stopPropagation()">
            
            <div class="p-6 md:p-8 border-b border-[var(--cr-border)] flex items-center justify-between">
                <h3 class="font-serif-elegant text-2xl">Your Cart</h3>
                <button onclick="app.ui.toggleCartDrawer()" class="text-gray-400 hover:text-[var(--cr-text)] transition-colors">
                    <i data-lucide="x" class="w-6 h-6 stroke-[1.5]"></i>
                </button>
