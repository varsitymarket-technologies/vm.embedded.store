<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KINETIC - High-Performance Streetwear & Gear</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@500;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: #0B0B0C; color: #F3F4F6; }
        .font-display { font-family: 'Syne', sans-serif; }
        .view-section { display: none; }
        .view-section.active { display: block; }
        
        /* Shopify style high-octane focus states */
        .shopify-input { 
            border: 2px solid #27272A; 
            background-color: #121214;
            color: #FFFFFF;
            transition: all 0.2s ease;
        }
        .shopify-input:focus { 
            outline: none; 
            border-color: #CCFF00; 
        }
        
        /* Fast scaling product card behaviors */
        .product-card img {
            transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
        }
        .product-card:hover img {
            transform: scale(1.05);
        }
    </style>

    <!-- D.3.x: customer auth helper (vm-customer.js from same dir as api.php) -->
    <script src="vm-customer.js" defer></script>
    <script>
        window.addEventListener('vm:customer-loaded', function () {
            document.body.dataset.customer = 'logged-in';
            if (window.app && app.auth && typeof app.auth.updateIcon === 'function') app.auth.updateIcon();
        });
        window.addEventListener('vm:customer-login', function () {
            document.body.dataset.customer = 'logged-in';
            if (window.app && app.auth && typeof app.auth.updateIcon === 'function') app.auth.updateIcon();
        });
        window.addEventListener('vm:customer-logout', function () {
            document.body.dataset.customer = 'logged-out';
            if (window.app && app.auth && typeof app.auth.updateIcon === 'function') app.auth.updateIcon();
        });
    </script>
</head>
<body class="antialiased min-h-screen flex flex-col justify-between selection:bg-[#CCFF00] selection:text-black">

    <div class="bg-[#CCFF00] text-black py-2.5 text-xs font-extrabold tracking-widest text-center uppercase px-4 overflow-hidden whitespace-nowrap">
        DROP 04 IS LIVE-SIMULTANEOUS INTERNATIONAL SHIPPING PATHWAYS ACTIVATED
    </div>

    <header class="sticky top-0 bg-[#0B0B0C]/90 backdrop-blur-md z-40 border-b-2 border-zinc-900">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between">
            
            <nav class="hidden md:flex items-center space-x-8 text-xs font-bold tracking-wider uppercase">
                <a href="#shop" onclick="app.router.navigate('shop')" class="text-zinc-400 hover:text-[#CCFF00] transition-colors">All Drops</a>
                <a href="#about" onclick="app.router.navigate('about')" class="text-zinc-400 hover:text-[#CCFF00] transition-colors">Our Labs</a>
            </nav>

            <a href="#home" onclick="app.router.navigate('home')" class="font-display text-2xl font-extrabold tracking-tighter text-white hover:opacity-90 transition-opacity">
                KINETIC-LABS
            </a>

            <div class="flex items-center space-x-4">
                <button class="p-2 text-zinc-400 hover:text-white transition-colors" onclick="app.ui.toggleSearchOverlay()" aria-label="Search Vault">
                    <i data-lucide="search" class="w-5 h-5 stroke-[2]"></i>
                </button>
                <button id="auth-icon-btn" class="p-2 text-zinc-400 hover:text-white transition-colors flex items-center" onclick="app.auth.iconClick()" aria-label="Account">
                    <span class="sr-only" id="auth-icon-label">Account</span>
                    <i data-lucide="user" class="w-5 h-5 stroke-[2]"></i>
                </button>
                <button class="p-2 text-zinc-400 hover:text-white transition-colors relative flex items-center" onclick="app.ui.toggleCartDrawer()" aria-label="Open Loadout Bags">
                    <i data-lucide="shopping-cart" class="w-5 h-5 stroke-[2]"></i>
                    <span id="global-cart-count" class="absolute -top-1 -right-1 text-[10px] font-black text-black bg-[#CCFF00] w-4 h-4 rounded-none flex items-center justify-center transition-all transform scale-0">0</span>
                </button>
            </div>
        </div>
    </header>

    <main class="flex-grow">

        <section id="view-home" class="view-section active">
            <div class="relative min-h-[calc(100vh-10rem)] flex items-center bg-radial from-zinc-900 via-[#0B0B0C] to-[#0B0B0C] border-b-2 border-zinc-900">
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 grid grid-cols-1 lg:grid-cols-12 items-center gap-12 w-full">
                    <div class="lg:col-span-6 space-y-6 text-center lg:text-left z-10">
                        <span class="inline-block bg-zinc-900 text-[#CCFF00] text-[10px] font-black tracking-widest uppercase px-3 py-1 border border-zinc-800">SYSTEM REBOOT RELEASE</span>
                        <h1 class="font-display text-4xl sm:text-6xl lg:text-7xl font-black text-white leading-none uppercase tracking-tighter">
                            ZERO RESISTANCE. <br><span class="text-[#CCFF00]">PURE PERFORMANCE.</span>
                        </h1>
                        <p class="text-zinc-400 text-sm max-w-md mx-auto lg:mx-0 font-medium leading-relaxed">
                            Engineered for high-output urban environments. Technical hydrophobic shells meeting ultra-heavy loopback athletic cotton weaves.
                        </p>
                        <div class="pt-4 flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
                            <button onclick="app.router.navigate('shop')" class="bg-[#CCFF00] text-black text-xs font-black tracking-widest uppercase px-10 py-4 hover:bg-white hover:text-black transition-colors rounded-none">
                                View Current Manifest
                            </button>
                        </div>
                    </div>
                    <div class="lg:col-span-6 border-2 border-zinc-800 p-3 bg-zinc-900/40 backdrop-blur-md">
                        <div class="aspect-[4/3] w-full bg-zinc-900 overflow-hidden relative">
                            <img src="https://images.unsplash.com/photo-1542291026-7eec264c27ff?q=80&w=1200&auto=format&fit=crop" class="w-full h-full object-cover grayscale opacity-90 contrast-115" alt="Kinetic dynamic footwear profile asset">
                        </div>
                    </div>
                </div>
            </div>

            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 grid grid-cols-1 md:grid-cols-2 gap-6">
                <div onclick="app.router.navigate('shop', {category: 'TECH-SHELL'})" class="relative group cursor-pointer border-2 border-zinc-900 p-2 bg-zinc-950 hover:border-[#CCFF00] transition-colors">
                    <div class="overflow-hidden aspect-[16/9] bg-zinc-900">
                        <img src="https://images.unsplash.com/photo-1508296695146-257a814070b4?q=80&w=800&auto=format&fit=crop" class="w-full h-full object-cover group-hover:scale-102 transition-transform duration-500 opacity-60">
                    </div>
                    <div class="flex justify-between items-center mt-4 px-2">
                        <h3 class="font-display font-extrabold uppercase text-lg text-white">01 / Technical Outerwear</h3>
                        <span class="text-[#CCFF00] font-black">&rarr;</span>
                    </div>
                </div>
                <div onclick="app.router.navigate('shop', {category: 'HARDWARE'})" class="relative group cursor-pointer border-2 border-zinc-900 p-2 bg-zinc-950 hover:border-[#CCFF00] transition-colors">
                    <div class="overflow-hidden aspect-[16/9] bg-zinc-900">
                        <img src="https://images.unsplash.com/photo-1553062407-98eeb64c6a62?q=80&w=800&auto=format&fit=crop" class="w-full h-full object-cover group-hover:scale-102 transition-transform duration-500 opacity-60">
                    </div>
                    <div class="flex justify-between items-center mt-4 px-2">
                        <h3 class="font-display font-extrabold uppercase text-lg text-white">02 / Heavy Load Utilities</h3>
                        <span class="text-[#CCFF00] font-black">&rarr;</span>
                    </div>
                </div>
            </div>
        </section>

        <section id="view-shop" class="view-section max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <div class="flex flex-col md:flex-row md:items-end justify-between border-b-2 border-zinc-900 pb-6 mb-12 gap-4">
                <div>
                    <h2 class="font-display text-4xl font-black uppercase text-white tracking-tight">Active Deployments</h2>
                    <p id="catalog-count-string" class="text-zinc-500 text-xs mt-1 font-bold tracking-widest uppercase">Initializing inventory pathways...</p>
                </div>
                <div class="flex items-center space-x-3">
                    <span class="text-xs text-zinc-500 uppercase font-black tracking-wider">Sequence:</span>
                    <select id="catalog-sort" onchange="app.store.sortCatalog(this.value)" class="text-xs font-bold uppercase tracking-wider bg-zinc-900 border-2 border-zinc-800 text-white rounded-none py-3 px-4 focus:outline-none focus:border-[#CCFF00]">
                        <option value="featured">Curated Drops</option>
                        <option value="price-low">Price-Baseline to Peak</option>
                        <option value="price-high">Price-Peak to Baseline</option>
                    </select>
                </div>
            </div>

            <div id="shop-items-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                </div>
        </section>

        <section id="view-product" class="view-section max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <div id="product-detail-target" class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">
                </div>
        </section>

        <section id="view-about" class="view-section max-w-4xl mx-auto px-4 py-16 space-y-12">
            <div class="text-center space-y-4">
                <span class="text-[#CCFF00] text-xs font-black tracking-widest uppercase">// SYSTEM SPECIFICATION DIRECTIVES</span>
                <h2 class="font-display text-4xl sm:text-5xl font-black uppercase text-white">We develop physical extensions for performance acceleration.</h2>
                <p class="text-zinc-400 text-sm font-medium max-w-2xl mx-auto leading-relaxed">KINETIC LABS serves as an advanced design vector creating durable, climate-adaptive garments. Our materials undergo severe multi-climate friction tracking to achieve absolute field synchronization pathways before scaling production outputs.</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-6">
                <div class="p-8 bg-zinc-950 border-2 border-zinc-900 space-y-3">
                    <h3 class="text-white text-xs font-black uppercase tracking-widest">Abrasion Shield Optimization</h3>
                    <p class="text-zinc-500 text-xs leading-relaxed font-medium">All stress zones feature cross-hatched reinforcement bindings to prevent composite degradation sequences over decades of real-world use.</p>
                </div>
                <div class="p-8 bg-zinc-950 border-2 border-zinc-900 space-y-3">
                    <h3 class="text-white text-xs font-black uppercase tracking-widest">Carbon Neutral Verification</h3>
                    <p class="text-zinc-500 text-xs leading-relaxed font-medium">We offset 100% of transport friction logs through direct investment pipelines targeting urban ecological recovery zones.</p>
                </div>
            </div>
        </section>

        <section id="view-faq" class="view-section max-w-2xl mx-auto px-4 py-16 space-y-8">
            <div class="text-center space-y-2">
                <h2 class="font-display text-3xl font-black uppercase text-white">Support Framework</h2>
                <p class="text-zinc-500 text-xs font-bold uppercase tracking-widest">Operational dispatch procedures and guidelines</p>
            </div>
            <div class="border-t-2 border-zinc-900 divide-y divide-zinc-900">
                <div class="py-5">
                    <button onclick="app.ui.toggleAccordion(this)" class="w-full flex justify-between items-center text-left py-2 text-sm font-bold text-white uppercase tracking-wider focus:outline-none group">
                        <span class="group-hover:text-[#CCFF00] transition-colors">Fulfillment processing timelines?</span>
                        <i data-lucide="chevron-right" class="w-4 h-4 text-zinc-500 transform transition-transform"></i>
                    </button>
                    <div class="max-h-0 overflow-hidden transition-all duration-300 ease-in-out text-zinc-400 text-xs leading-relaxed font-medium">
                        <p class="py-4 pr-4">Orders enter automated packing streams instantly. Logistics tracking parameters broadcast out within 24 working hours from initial load sequences. Standard transit patterns clock 2-4 days domestically.</p>
                    </div>
                </div>
                <div class="py-5">
                    <button onclick="app.ui.toggleAccordion(this)" class="w-full flex justify-between items-center text-left py-2 text-sm font-bold text-white uppercase tracking-wider focus:outline-none group">
                        <span class="group-hover:text-[#CCFF00] transition-colors">Exchange logistics protocol metrics?</span>
                        <i data-lucide="chevron-right" class="w-4 h-4 text-zinc-500 transform transition-transform"></i>
                    </button>
                    <div class="max-h-0 overflow-hidden transition-all duration-300 ease-in-out text-zinc-400 text-xs leading-relaxed font-medium">
                        <p class="py-4 pr-4">We authorize returns on unmodified cargo packaging structures up to 30 intervals post delivery arrivals. Access the processing terminal directly through your security account logs to secure freight routing stamps.</p>
                    </div>
                </div>
            </div>
        </section>

        <section id="view-contact" class="view-section max-w-4xl mx-auto px-4 py-16">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 bg-zinc-950 p-8 sm:p-12 border-2 border-zinc-900">
                <div class="space-y-6 flex flex-col justify-between">
                    <div class="space-y-4">
                        <h2 class="font-display text-4xl font-black uppercase text-white tracking-tight">Signal Agent Pod</h2>
                        <p class="text-zinc-400 text-xs leading-relaxed font-medium">Need precision dimension scaling metrics or custom institutional supply batching tokens? Route your data files directly to our engineering coordinators.</p>
                    </div>
                    <div class="text-xs text-zinc-600 font-bold tracking-widest uppercase space-y-1">
                        <p>Secure Interface: support@kineticlabs.io</p>
                        <p>Terminal Matrix Code: [SEC-CON-994]</p>
                    </div>
                </div>
                <form onsubmit="app.ui.handleContactSubmit(event)" class="space-y-4">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <input type="text" required placeholder="IDENTIFIER NAME" class="w-full p-4 text-xs font-bold uppercase tracking-wider shopify-input">
                        <input type="email" required placeholder="EMAIL ROUTING NODE" class="w-full p-4 text-xs font-bold uppercase tracking-wider shopify-input">
                    </div>
                    <textarea required rows="4" placeholder="TRANSMIT REQUEST DETAILS..." class="w-full p-4 text-xs font-bold uppercase tracking-wider shopify-input"></textarea>
                    <button type="submit" class="w-full bg-[#CCFF00] text-black py-4 text-xs font-black tracking-widest uppercase hover:bg-white hover:text-black transition-colors rounded-none">Broadcast Signal</button>
                </form>
            </div>
        </section>

        <!-- D.3.x: account view -->
        <section id="view-account" class="view-section max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <div class="flex items-center justify-between mb-12">
                <div>
                    <p class="text-[10px] uppercase tracking-widest text-zinc-500 font-bold">Account</p>
                    <h1 id="acc-greeting" class="font-display text-4xl font-extrabold text-white mt-2 tracking-tighter uppercase">Welcome</h1>
                </div>
                <button onclick="app.auth.doLogout()" class="text-[10px] uppercase tracking-widest text-zinc-500 hover:text-[#CCFF00] font-bold">Sign Out</button>
            </div>

            <div class="flex space-x-8 border-b-2 border-zinc-900 mb-8">
                <button id="acc-tab-overview" onclick="app.auth.activateTab('overview')" class="acc-tab pb-3 text-[11px] uppercase tracking-widest font-bold">Overview</button>
                <button id="acc-tab-profile"  onclick="app.auth.activateTab('profile')"  class="acc-tab pb-3 text-[11px] uppercase tracking-widest font-bold">Profile</button>
                <button id="acc-tab-orders"   onclick="app.auth.activateTab('orders')"   class="acc-tab pb-3 text-[11px] uppercase tracking-widest font-bold">Orders</button>
                <button id="acc-tab-password" onclick="app.auth.activateTab('password')" class="acc-tab pb-3 text-[11px] uppercase tracking-widest font-bold">Password</button>
            </div>

            <div id="acc-panel-overview" class="acc-panel">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
                    <div><p class="text-[10px] uppercase tracking-widest text-zinc-500 font-bold">Name</p><p id="acc-ov-name" class="text-sm text-white mt-2">—</p></div>
                    <div><p class="text-[10px] uppercase tracking-widest text-zinc-500 font-bold">Email</p><p id="acc-ov-email" class="text-sm text-white mt-2">—</p></div>
                    <div><p class="text-[10px] uppercase tracking-widest text-zinc-500 font-bold">Member Since</p><p id="acc-ov-joined" class="text-sm text-white mt-2">—</p></div>
                </div>
                <button onclick="app.auth.activateTab('profile')" class="text-[10px] uppercase tracking-widest text-[#CCFF00] border-b border-[#CCFF00] pb-0.5 font-bold">Edit profile</button>
            </div>

            <div id="acc-panel-profile" class="acc-panel hidden">
                <form onsubmit="event.preventDefault(); app.auth.saveProfile()" class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div><label class="block text-[10px] uppercase tracking-widest text-zinc-500 mb-2 font-bold">First Name</label>
                             <input type="text" id="acc-fname" class="w-full bg-zinc-950 border-2 border-zinc-900 px-4 py-3 text-white focus:outline-none focus:border-[#CCFF00] font-bold"></div>
                        <div><label class="block text-[10px] uppercase tracking-widest text-zinc-500 mb-2 font-bold">Last Name</label>
                             <input type="text" id="acc-lname" class="w-full bg-zinc-950 border-2 border-zinc-900 px-4 py-3 text-white focus:outline-none focus:border-[#CCFF00] font-bold"></div>
                    </div>
                    <div><label class="block text-[10px] uppercase tracking-widest text-zinc-500 mb-2 font-bold">Email</label>
                         <input type="email" id="acc-email" readonly title="Email is the account identifier and cannot be changed here" class="w-full bg-zinc-900 border-2 border-zinc-900 px-4 py-3 text-zinc-500 cursor-not-allowed font-bold"></div>
                    <div><label class="block text-[10px] uppercase tracking-widest text-zinc-500 mb-2 font-bold">Phone (optional)</label>
                         <input type="tel" id="acc-phone" class="w-full bg-zinc-950 border-2 border-zinc-900 px-4 py-3 text-white focus:outline-none focus:border-[#CCFF00] font-bold"></div>
                    <button type="submit" class="w-full bg-[#CCFF00] text-black py-3 text-[11px] uppercase tracking-widest font-extrabold hover:bg-white transition-colors">Save</button>
                </form>
            </div>

            <div id="acc-panel-orders" class="acc-panel hidden">
                <div id="acc-orders-list">
                    <p class="text-[10px] uppercase tracking-widest text-zinc-500 py-12 text-center font-bold">Loading…</p>
                </div>
            </div>

            <div id="acc-panel-password" class="acc-panel hidden">
                <form onsubmit="event.preventDefault(); app.auth.changePassword()" class="space-y-6">
                    <div><label class="block text-[10px] uppercase tracking-widest text-zinc-500 mb-2 font-bold">Current Password</label>
                         <input type="password" id="acc-pw-cur" required class="w-full bg-zinc-950 border-2 border-zinc-900 px-4 py-3 text-white focus:outline-none focus:border-[#CCFF00] font-bold"></div>
                    <div><label class="block text-[10px] uppercase tracking-widest text-zinc-500 mb-2 font-bold">New Password</label>
                         <input type="password" id="acc-pw-new" required minlength="8" class="w-full bg-zinc-950 border-2 border-zinc-900 px-4 py-3 text-white focus:outline-none focus:border-[#CCFF00] font-bold"></div>
                    <div><label class="block text-[10px] uppercase tracking-widest text-zinc-500 mb-2 font-bold">Confirm New Password</label>
                         <input type="password" id="acc-pw-conf" required minlength="8" class="w-full bg-zinc-950 border-2 border-zinc-900 px-4 py-3 text-white focus:outline-none focus:border-[#CCFF00] font-bold"></div>
                    <button type="submit" class="w-full bg-[#CCFF00] text-black py-3 text-[11px] uppercase tracking-widest font-extrabold hover:bg-white transition-colors">Change Password</button>
                </form>
            </div>
        </section>

        <style>
            .acc-tab { color: #71717a; border-bottom: 2px solid transparent; transition: all 0.3s; margin-bottom: -2px; }
            .acc-tab.active { color: #fff; border-bottom-color: #CCFF00; }
        </style>

        <!-- D.3.x: Auth modal overlay -->
        <div id="auth-modal" class="fixed inset-0 bg-[#0B0B0C] z-50 hidden flex-col items-center justify-start overflow-y-auto p-6">
            <div class="w-full max-w-md mx-auto pt-12 pb-24">
                <div class="flex items-center justify-between mb-12">
                    <span class="font-display text-2xl font-extrabold tracking-tighter text-white">KINETIC-LABS</span>
                    <button onclick="app.auth.close()" aria-label="Close" class="text-zinc-500 hover:text-white transition-colors">
                        <i data-lucide="x" class="w-5 h-5"></i>
                    </button>
                </div>

                <div class="flex space-x-8 border-b-2 border-zinc-900 mb-8">
                    <button id="auth-tab-login"    onclick="app.auth.switchTab('login')"    class="auth-tab pb-3 text-[11px] uppercase tracking-widest font-bold">Sign In</button>
                    <button id="auth-tab-register" onclick="app.auth.switchTab('register')" class="auth-tab pb-3 text-[11px] uppercase tracking-widest font-bold">Create</button>
                    <button id="auth-tab-forgot"   onclick="app.auth.switchTab('forgot')"   class="auth-tab pb-3 text-[11px] uppercase tracking-widest font-bold">Forgot</button>
                </div>

                <div id="auth-panel-login" class="auth-panel">
                    <form onsubmit="event.preventDefault(); app.auth.submitLogin()" class="space-y-6">
                        <div>
                            <label class="block text-[10px] uppercase tracking-widest text-zinc-500 mb-2 font-bold">Email</label>
                            <input type="email" id="auth-login-email" required class="w-full bg-zinc-950 border-2 border-zinc-900 px-4 py-3 text-white focus:outline-none focus:border-[#CCFF00] font-bold">
                        </div>
                        <div>
                            <label class="block text-[10px] uppercase tracking-widest text-zinc-500 mb-2 font-bold">Password</label>
                            <input type="password" id="auth-login-pass" required class="w-full bg-zinc-950 border-2 border-zinc-900 px-4 py-3 text-white focus:outline-none focus:border-[#CCFF00] font-bold">
                        </div>
                        <div id="auth-login-error" class="hidden text-[11px] text-red-500 mt-2 font-bold"></div>
                        <button type="submit" class="w-full bg-[#CCFF00] text-black py-3 text-[11px] uppercase tracking-widest font-extrabold hover:bg-white transition-colors">Sign In</button>
                    </form>
                </div>

                <div id="auth-panel-register" class="auth-panel hidden">
                    <form onsubmit="event.preventDefault(); app.auth.submitRegister()" class="space-y-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div><label class="block text-[10px] uppercase tracking-widest text-zinc-500 mb-2 font-bold">First Name</label>
                                 <input type="text" id="auth-reg-fname" required class="w-full bg-zinc-950 border-2 border-zinc-900 px-4 py-3 text-white focus:outline-none focus:border-[#CCFF00] font-bold"></div>
