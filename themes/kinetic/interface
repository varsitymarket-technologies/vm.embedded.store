    <script>
        /**
         * Dynamic technical streetwear dataset records
         */
        const __SEED = [
            { id: 'kin-01', name: 'Alpha Hydrophobic Cargo Parka X-1', price: 380.00, category: 'TECH-SHELL', images: ['https://images.unsplash.com/photo-1542291026-7eec264c27ff?q=80&w=600&auto=format&fit=crop'], desc: 'High-density, laser-fused technical shell layout treating double-layered advanced windproof membranes. Outfitted with heavy magnetic locking utility clasps and deep-profile custom storm shield hoods.' },
            { id: 'kin-02', name: 'Modular Multi-Fit Grid Loadout Rig', price: 185.00, category: 'HARDWARE', images: ['https://images.unsplash.com/photo-1553062407-98eeb64c6a62?q=80&w=600&auto=format&fit=crop'], desc: 'Heavyweight military-spec canvas architecture hosting detachable tactical accessory holsters. Engineered with dual compression harness tracking straps for stable, fluid urban carry navigation.' },
            { id: 'kin-03', name: '460GSM Loopback Track Pullover Hoodie', price: 160.00, category: 'TECH-SHELL', images: ['https://images.unsplash.com/photo-1508296695146-257a814070b4?q=80&w=600&auto=format&fit=crop'], desc: 'An ultra-dense structural jersey layer engineered out of premium long-staple ring-spun brushed raw cotton blends. Cut with relaxed drop shoulders, seamless ribbed edges, and clean tonal stitching layouts.' },
            { id: 'kin-04', name: 'Element Vector Waterproof Duffel Bag', price: 210.00, category: 'HARDWARE', images: ['https://images.unsplash.com/photo-1522312346375-d1a52e2b99b3?q=80&w=600&auto=format&fit=crop'], desc: 'A completely submersible gear travel cell engineered from rugged welded matte TPU canvas lines. Featuring weatherized airtight zippers and smart modular backpack shoulder swap-bindings.' }
        ];

        /* ════════════════════
           CANONICAL DATA LAYER — fetchStore → api.php?state=X, getMockData fallback, MOCK shape
        ════════════════════ */
        const __CATS = [...new Set(__SEED.map(p => p.category).filter(Boolean))].map((name, i) => ({ id: i + 1, name }));
        const MOCK = {
            site: { name: "KINETIC", currency: "R", domain: window.location.hostname },
            categories: __CATS,
            products: __SEED.map((p, i) => ({
                ...p,
                id: p.id != null ? p.id : i + 1,
                image: p.image || (Array.isArray(p.images) ? p.images[0] : "") || "",
                description: p.description || p.desc || "",
                stock: p.stock != null ? p.stock : 12,
                category_id: (__CATS.find(c => c.name === p.category) || {}).id || null
            })),
            discounts: [
                { id: 1, code: "WELCOME10", percentage: 10, active: 1 },
                { id: 2, code: "DROP20", percentage: 20, active: 1 }
            ]
        };

        async function fetchStore(state, params = {}) {
            const url = new URL("api.php", window.location.href);
            url.searchParams.set("state", state);
            for (const [k, v] of Object.entries(params)) url.searchParams.set(k, v);
            try {
                const res = await fetch(url, { signal: AbortSignal.timeout(4000) });
                if (!res.ok) throw new Error(res.status);
                return await res.json();
            } catch {
                return getMockData(state, params);
            }
        }

        function getMockData(state, params = {}) {
            switch (state) {
                case "site": return MOCK.site;
                case "products": return MOCK.products;
                case "product": return MOCK.products.find(p => p.id == params.id) || null;
                case "categories": return MOCK.categories;
                case "products_by_category": return MOCK.products.filter(p => p.category_id == params.category_id);
                case "search": {
                    const q = (params.q || "").toLowerCase();
                    return MOCK.products.filter(p => (p.name || "").toLowerCase().includes(q) || (p.description || "").toLowerCase().includes(q));
                }
                case "discounts": return MOCK.discounts;
                case "orders": return [];
                default: return [];
            }
        }

        let INVENTORY_DB = [];

        const app = {
            state: { cart: [], activeFilter: 'all', currentSort: 'featured', activeCheckoutStep: 1 },
            init: async function() {
                const __d = await fetchStore('products');
                INVENTORY_DB = __d.map(p => ({ ...p, images: p.images || (p.image ? [p.image] : []), desc: p.desc || p.description || '', category: p.category || ((MOCK.categories.find(c => c.id == p.category_id) || {}).name) || '' }));
                this.router.init(); this.store.renderCatalog(); this.cart.loadAndSync(); lucide.createIcons();
            }
        };

        // --- SINGLE PAGE APPLICATION NAVIGATION ENGINE ROUTER ---
        app.router = {
            init: function() {
                window.addEventListener('popstate', () => this.evalRoute(window.location.hash));
                this.evalRoute(window.location.hash || '#home');
            },
            navigate: function(view, params = null) {
                let hash = `#${view}`;
                if (params) hash += `?${new URLSearchParams(params).toString()}`;
                history.pushState(null, null, hash);
                this.evalRoute(hash);
            },
            evalRoute: function(hashString) {
                const parts = hashString.split('?');
                const view = parts[0] || '#home';
                const queryParams = parts[1] ? Object.fromEntries(new URLSearchParams(parts[1])) : {};
                document.querySelectorAll('.view-section').forEach(el => el.classList.remove('active'));
                const targetView = document.getElementById(`view-${view.replace('#', '')}`);
                if (targetView) targetView.classList.add('active');
                if (view === '#shop') { app.store.filterCatalog(queryParams.category || 'all'); } else if (view === '#product' && queryParams.id) { app.store.renderProductDetail(queryParams.id); } else if (view === '#checkout') { app.checkout.renderCurrentStep(); }
                else if (view === '#account') {
                    if (!app.auth || !app.auth.isLoggedIn()) {
                        if (app.auth) app.auth.open('login');
                        const homeView = document.getElementById('view-home');
                        if (targetView) targetView.classList.remove('active');
                        if (homeView) homeView.classList.add('active');
                    } else {
                        app.auth.renderDashboard();
                    }
                }
                window.scrollTo({top:0});
            }
        };

        // --- HIGH CONVERSION SHOP TILES RENDERING SYSTEM ---
        app.store = {
            renderCatalog: function(itemsToRender = INVENTORY_DB) {
                const grid = document.getElementById('shop-items-grid');
                if (!grid) return;
                grid.innerHTML = itemsToRender.map(item => `
                    <div class="product-card flex flex-col justify-between border-2 border-zinc-900 p-3 bg-zinc-950 cursor-pointer group hover:border-white transition-colors" onclick="app.router.navigate('product', {id: '${item.id}'})">
                        <div class="aspect-square w-full overflow-hidden bg-zinc-900 mb-4 relative border border-zinc-900">
                            <img src="${item.images[0]}" alt="${item.name}" class="w-full h-full object-cover grayscale brightness-90 group-hover:grayscale-0 transition-all duration-300">
                        </div>
                        <div class="space-y-2 uppercase">
                            <div class="flex justify-between items-start text-xs font-bold text-white gap-2">
                                <h3 class="font-display group-hover:text-[#CCFF00] tracking-tight leading-snug">${item.name}</h3>
                                <p class="font-mono text-[#CCFF00] whitespace-nowrap font-bold">$${item.price.toFixed(2)}</p>
                            </div>
                            <p class="text-[9px] font-black tracking-widest text-zinc-600">${item.category}-UNIT</p>
                        </div>
                    </div>`).join('');
                document.getElementById('catalog-count-string').innerText = `Displaying ${itemsToRender.length} tactical deployment items`;
            },
            filterCatalog: function(cat) { app.state.activeFilter = cat; this.renderCatalog(cat === 'all' ? INVENTORY_DB : INVENTORY_DB.filter(i => i.category === cat)); },
            sortCatalog: function(criteria) {
                let sorted = [...INVENTORY_DB].filter(i => app.state.activeFilter === 'all' || i.category === app.state.activeFilter);
                if (criteria === 'price-low') sorted.sort((a,b) => a.price - b.price);
                if (criteria === 'price-high') sorted.sort((a,b) => b.price - a.price);
                this.renderCatalog(sorted);
            },
            renderProductDetail: function(id) {
                const item = INVENTORY_DB.find(p => p.id === id);
                if (!item) return;
                document.getElementById('product-detail-target').innerHTML = `
                    <div class="lg:col-span-7 aspect-square w-full bg-zinc-950 border-2 border-zinc-900 p-3 overflow-hidden">
                        <img src="${item.images[0]}" alt="${item.name}" class="w-full h-full object-cover grayscale brightness-95">
                    </div>
                    <div class="lg:col-span-5 flex flex-col space-y-6 py-2">
                        <div class="border-b border-zinc-900 pb-5 space-y-2 uppercase">
                            <span class="text-[9px] text-[#CCFF00] font-black tracking-widest">${item.category} MODULAR SPECIFICATION</span>
                            <h1 class="font-display text-3xl font-black text-white tracking-tight">${item.name}</h1>
                            <p class="text-xl font-mono text-[#CCFF00] font-bold mt-2">$${item.price.toFixed(2)}</p>
                        </div>
                        <p class="text-zinc-400 text-xs leading-relaxed font-medium normal-case">${item.desc}</p>
                        <div class="pt-4">
                            <button onclick="app.cart.addItem('${item.id}')" class="w-full py-4.5 bg-[#CCFF00] text-black text-xs font-black uppercase tracking-widest hover:bg-white transition-colors rounded-none">Deploy to Loadout Bag</button>
                        </div>
                        <div class="text-[10px] font-bold uppercase tracking-wider text-zinc-600 border-t border-zinc-900 pt-4 space-y-2">
                            <p>&bull; Integrated tracked global transit processing authorized.</p>
                            <p>&bull; Rapid 30-interval environmental exchange allowance lines apply.</p>
                        </div>
                    </div>`;
            },
            handleSearch: function(term) {
                const out = document.getElementById('search-results-output');
                if (!term) { out.innerHTML = ''; return; }
                out.innerHTML = INVENTORY_DB.filter(i => i.name.toLowerCase().includes(term.toLowerCase())).map(i => `
                    <div onclick="app.ui.toggleSearchOverlay(); app.router.navigate('product', {id: '${i.id}'})" class="p-4 bg-zinc-950 border-2 border-zinc-900 flex items-center justify-between cursor-pointer hover:border-[#CCFF00] transition-colors">
                        <div class="flex items-center space-x-3">
                            <img src="${i.images[0]}" class="w-10 h-10 object-cover border border-zinc-900 grayscale">
                            <span class="text-xs font-bold text-white uppercase font-display">${i.name}</span>
                        </div>
                        <span class="text-xs font-mono font-bold text-[#CCFF00]">$${i.price}</span>
                    </div>`).join('');
            }
        };

        // --- STABLE APPLICATION LOCALSTORAGE CART CORE ENGINE ---
        app.cart = {
            loadAndSync: function() { const stored = localStorage.getItem('kinetic_loadout_cart'); if (stored) app.state.cart = JSON.parse(stored); this.updateUI(); },
            addItem: function(id) {
                const prod = INVENTORY_DB.find(p => p.id === id);
                const exist = app.state.cart.find(item => item.product.id === id);
                if (exist) exist.qty += 1; else app.state.cart.push({ product: prod, qty: 1 });
                this.sync(); app.ui.triggerToast(`Loadout metrics synced`); app.ui.toggleCartDrawer(true);
            },
            updateQty: function(id, val) { const item = app.state.cart.find(i => i.product.id === id); if (!item) return; item.qty += val; if (item.qty <= 0) app.state.cart = app.state.cart.filter(i => i.product.id !== id); this.sync(); },
            sync: function() { localStorage.setItem('kinetic_loadout_cart', JSON.stringify(app.state.cart)); this.updateUI(); },
            updateUI: function() {
                const drawerContainer = document.getElementById('cart-drawer-items');
                const badge = document.getElementById('global-cart-count');
                const subtotalText = document.getElementById('cart-drawer-subtotal');
                const totalItems = app.state.cart.reduce((sum, i) => sum + i.qty, 0);
                const subtotal = app.state.cart.reduce((sum, i) => sum + (i.product.price * i.qty), 0);
                if (totalItems > 0) { badge.innerText = totalItems; badge.classList.remove('scale-0'); } else { badge.classList.add('scale-0'); }
                subtotalText.innerText = `$${subtotal.toFixed(2)}`;
                if (app.state.cart.length === 0) { drawerContainer.innerHTML = `<div class="text-center text-zinc-600 py-16 text-xs font-bold uppercase tracking-widest"><i data-lucide="shopping-cart" class="w-5 h-5 mx-auto mb-3 opacity-30"></i>Loadout allocation cell empty</div>`; } else {
                    drawerContainer.innerHTML = app.state.cart.map(item => `
                        <div class="flex items-center space-x-4 border-2 border-zinc-900 p-4 bg-zinc-950">
                            <img src="${item.product.images[0]}" class="w-14 h-14 object-cover border border-zinc-900 grayscale">
                            <div class="flex-grow min-w-0 space-y-2 uppercase">
                                <h4 class="text-xs font-bold font-display text-white truncate tracking-tight">${item.product.name}</h4>
                                <div class="flex items-center space-x-4">
                                    <button onclick="app.cart.updateQty('${item.product.id}', -1)" class="text-zinc-600 hover:text-[#CCFF00] text-xs font-black font-mono">-</button>
                                    <span class="text-xs text-white font-bold font-mono">${item.qty}</span>
                                    <button onclick="app.cart.updateQty('${item.product.id}', 1)" class="text-zinc-600 hover:text-[#CCFF00] text-xs font-black font-mono">+</button>
                                </div>
                            </div>
                        </div>`).join('');
                }
                lucide.createIcons();
            }
        };

        // --- HIGH VELOCITY TRANSACTION ROUTER PATH CHECKOUTS ---
        app.checkout = {
            initiateCheckout: function() { if(!app.state.cart.length) return; app.ui.toggleCartDrawer(false); app.router.navigate('checkout'); },
            renderCurrentStep: function() {
                const container = document.getElementById('checkout-step-container');
                const sub = app.state.cart.reduce((sum, i) => sum + (i.product.price * i.qty), 0);
                document.getElementById('chk-subtotal').innerText = `$${sub.toFixed(2)}`;
                document.getElementById('chk-total').innerText = `$${sub.toFixed(2)}`;
                document.getElementById('checkout-summary-items').innerHTML = app.state.cart.map(i => `<div class="flex justify-between text-xs py-2 uppercase font-bold text-zinc-500 font-sans"><span>${i.product.name} <span class="text-zinc-600 font-mono">(x${i.qty})</span></span><span class="text-white font-mono">$${(i.product.price * i.qty).toFixed(2)}</span></div>`).join('');
                document.getElementById('step-nav-1').className = app.state.activeCheckoutStep === 1 ? "text-[#CCFF00] font-black" : "text-zinc-600";
                document.getElementById('step-nav-2').className = app.state.activeCheckoutStep === 2 ? "text-[#CCFF00] font-black" : "text-zinc-600";
                document.getElementById('step-nav-3').className = app.state.activeCheckoutStep === 3 ? "text-[#CCFF00] font-black" : "text-zinc-600";

                if (app.state.activeCheckoutStep === 1) { container.innerHTML = `<h3 class="text-xs font-black text-white uppercase tracking-widest mb-3">// LOGISTICS DESTINATION NODE</h3><input type="email" required placeholder="EMAIL COMMUNICATIONS LOG" class="w-full p-4 text-xs font-bold uppercase shopify-input"><input type="text" required placeholder="PHYSICAL ROUTING DELIVERY LOCATION" class="w-full p-4 text-xs font-bold uppercase shopify-input"/>`; } else if (app.state.activeCheckoutStep === 2) { container.innerHTML = `<h3 class="text-xs font-black text-white uppercase tracking-widest mb-3">// SELECT DISPATCH SPEED</h3><div class="border-2 border-zinc-900 bg-zinc-900 text-xs font-bold p-4 flex items-center justify-between uppercase"><div class="flex items-center space-x-2"><input type="radio" checked class="accent-[#CCFF00]"> <span>Priority Secure Freight Transit</span></div> <span class="text-[#CCFF00]">COMPLIMENTARY</span></div>`; } else if (app.state.activeCheckoutStep === 3) { container.innerHTML = `<h3 class="text-xs font-black text-white uppercase tracking-widest mb-3">// SECURE TRANSACTION BOND VALUATION</h3><input type="text" required placeholder="DEBIT INVOICE VAULT GATEWAY ID TOKEN" class="w-full p-4 text-xs font-bold uppercase shopify-input">`; }
            },
            handleStepSubmit: function(e) { e.preventDefault(); if(app.state.activeCheckoutStep < 3) { app.state.activeCheckoutStep += 1; this.renderCurrentStep(); } else { app.state.cart = []; app.cart.sync(); app.state.activeCheckoutStep = 1; app.ui.triggerToast("Ledger updated! Check email feed."); app.router.navigate('home'); } }
        };

        // --- DECORATIVE INTERACTION OVERLAY CLOSURE HANDLERS ---
        app.ui = {
            toggleCartDrawer: function(forceOpen = null) {
                const overlay = document.getElementById('cart-drawer-overlay');
                if (forceOpen === true) { overlay.classList.remove('opacity-0', 'pointer-events-none'); overlay.firstElementChild.classList.remove('translate-x-full'); return; }
                if (forceOpen === false) { overlay.classList.add('opacity-0', 'pointer-events-none'); overlay.firstElementChild.classList.add('translate-x-full'); return; }
                overlay.classList.toggle('opacity-0'); overlay.classList.toggle('pointer-events-none');
                overlay.firstElementChild.classList.toggle('translate-x-full');
            },
            toggleSearchOverlay: function() { const s = document.getElementById('search-overlay'); s.classList.toggle('hidden'); s.classList.toggle('flex'); if(!s.classList.contains('hidden')) document.getElementById('live-search-input').focus(); },
            toggleAccordion: function(btn) { btn.querySelector('i').classList.toggle('rotate-90'); const panel = btn.nextElementSibling; if (panel.style.maxHeight && panel.style.maxHeight !== '0px') { panel.style.maxHeight = '0px'; } else { panel.style.maxHeight = panel.scrollHeight + "px"; } },
            handleContactSubmit: function(e) { e.preventDefault(); e.target.reset(); this.triggerToast("Signal broadcasted successfully"); },
            triggerToast: function(msg) {
                const t = document.getElementById('toast-notif'); document.getElementById('toast-notif-message').innerText = msg;
                t.className = "fixed bottom-6 right-6 bg-[#CCFF00] text-black text-xs font-black py-4 px-6 rounded-none shadow-2xl z-50 transform translate-y-0 opacity-100 transition-all duration-300 flex items-center space-x-3 uppercase tracking-widest";
                setTimeout(() => { t.className = "fixed bottom-6 right-6 bg-[#CCFF00] text-black text-xs font-black py-4 px-6 rounded-none shadow-2xl z-50 transform translate-y-20 opacity-0 transition-all duration-300 pointer-events-none flex items-center space-x-3 uppercase tracking-widest"; }, 3500);
            }
        };
        app.auth = {
            getUser: function () {
                if (!window.vmCustomer || !vmCustomer.isLoggedIn()) return null;
                const c = vmCustomer.cached();
                if (!c) return null;
                const parts = (c.name || '').trim().split(/\s+/).filter(Boolean);
                return {
                    email: c.email,
                    fname: parts[0] || '',
                    lname: parts.slice(1).join(' '),
                    phone: c.phone || '',
                    joinDate: c.created_at || ''
                };
            },
            isLoggedIn: function () { return !!window.vmCustomer && vmCustomer.isLoggedIn(); },
            iconClick: function () { if (this.isLoggedIn()) app.router.navigate('account'); else this.open('login'); },
            updateIcon: function () {
                const label = document.getElementById('auth-icon-label');
                if (!label) return;
                const u = this.getUser();
                label.textContent = u && u.fname ? u.fname : 'Account';
            },
            open: function (tab) {
                this.switchTab(tab || 'login');
                const m = document.getElementById('auth-modal');
                m.classList.add('is-open');
                document.body.style.overflow = 'hidden';
                if (window.lucide && typeof lucide.createIcons === 'function') lucide.createIcons();
            },
            close: function () {
                const m = document.getElementById('auth-modal');
                m.classList.remove('is-open');
                document.body.style.overflow = '';
                ['auth-login-error', 'auth-reg-error'].forEach(function (id) {
                    const el = document.getElementById(id);
                    if (el) { el.textContent = ''; el.classList.add('hidden'); }
                });
            },
            switchTab: function (tab) {
                ['login', 'register', 'forgot'].forEach(function (t) {
                    const btn = document.getElementById('auth-tab-' + t);
                    const pan = document.getElementById('auth-panel-' + t);
                    if (btn) btn.classList.toggle('active', t === tab);
                    if (pan) pan.classList.toggle('hidden', t !== tab);
                });
            },
            submitLogin: async function () {
                const email = document.getElementById('auth-login-email').value.trim();
                const pass = document.getElementById('auth-login-pass').value;
                const errEl = document.getElementById('auth-login-error');
                errEl.classList.add('hidden');
                if (!email || !pass) { errEl.textContent = 'Email and password required.'; errEl.classList.remove('hidden'); return; }
                try {
                    await vmCustomer.login(email, pass);
                    this.close();
                    const u = this.getUser();
                    app.ui.triggerToast('Welcome, ' + ((u && u.fname) || 'friend'));
                    app.router.navigate('account');
                } catch (e) {
                    errEl.textContent = (e && e.code === 'locked') ? 'Account temporarily locked. Try again in a few minutes.' : ((e && e.message) || 'Sign-in failed');
                    errEl.classList.remove('hidden');
                }
            },
            submitRegister: async function () {
                const fname = document.getElementById('auth-reg-fname').value.trim();
                const lname = document.getElementById('auth-reg-lname').value.trim();
                const email = document.getElementById('auth-reg-email').value.trim();
                const pass  = document.getElementById('auth-reg-pass').value;
                const pass2 = document.getElementById('auth-reg-pass2').value;
                const errEl = document.getElementById('auth-reg-error');
                errEl.classList.add('hidden');
                if (!fname || !email || !pass) { errEl.textContent = 'Please fill in all required fields.'; errEl.classList.remove('hidden'); return; }
                if (pass !== pass2) { errEl.textContent = 'Passwords do not match.'; errEl.classList.remove('hidden'); return; }
                if (pass.length < 8) { errEl.textContent = 'Password must be at least 8 characters.'; errEl.classList.remove('hidden'); return; }
                const name = (fname + ' ' + lname).trim();
                try {
                    await vmCustomer.register(email, pass, name, null);
                    this.close();
                    app.ui.triggerToast('Welcome, ' + fname);
                    app.router.navigate('account');
                } catch (e) {
                    errEl.textContent = (e && e.message) || 'Sign-up failed';
                    errEl.classList.remove('hidden');
                }
            },
            submitForgot: function () { app.ui.triggerToast('Reset link sent (placeholder)'); this.switchTab('login'); },
            doLogout: async function () {
                try { await vmCustomer.logout(); } catch (e) { /* cleared locally regardless */ }
                app.ui.triggerToast('Signed out');
                app.router.navigate('home');
            },
            activateTab: function (name) {
                ['overview', 'profile', 'orders', 'password'].forEach(function (t) {
                    const btn = document.getElementById('acc-tab-' + t);
                    const pan = document.getElementById('acc-panel-' + t);
                    if (btn) btn.classList.toggle('active', t === name);
                    if (pan) pan.classList.toggle('hidden', t !== name);
                });
                if (name === 'orders') app.auth.hydrateOrders();
            },
            renderDashboard: async function () {
                if (!this.isLoggedIn()) { this.open('login'); return; }
                const u = this.getUser();
                if (!u) { this.open('login'); return; }
                document.getElementById('acc-greeting').textContent = 'Welcome, ' + ((u.fname) || 'friend');
                document.getElementById('acc-ov-name').textContent  = (u.fname + ' ' + u.lname).trim() || '—';
                document.getElementById('acc-ov-email').textContent = u.email || '—';
                document.getElementById('acc-ov-joined').textContent = u.joinDate ? u.joinDate.split(' ')[0] : '—';
                document.getElementById('acc-fname').value = u.fname || '';
                document.getElementById('acc-lname').value = u.lname || '';
                document.getElementById('acc-email').value = u.email || '';
                document.getElementById('acc-phone').value = u.phone || '';
                this.activateTab('overview');
            },
            hydrateOrders: async function () {
                const wrap = document.getElementById('acc-orders-list');
                wrap.innerHTML = '<p class="text-[10px] uppercase tracking-widest text-zinc-500 py-12 text-center font-bold">Loading…</p>';
                try {
                    const r = await vmCustomer.myOrders();
                    const orders = (r.orders || []);
                    if (!orders.length) {
                        wrap.innerHTML = '<p class="text-[10px] uppercase tracking-widest text-zinc-500 py-12 text-center font-bold">No orders yet. <a href="#shop" onclick="app.router.navigate(\'shop\')" class="text-[#CCFF00] border-b border-[#CCFF00] pb-0.5">Start shopping →</a></p>';
                        return;
                    }
                    wrap.innerHTML = '<div class="space-y-4">' + orders.map(function (o) {
                        const total = (o.total_amount != null ? o.total_amount : 0).toFixed(2);
                        const dateStr = o.created_at ? String(o.created_at).split(' ')[0] : '—';
                        const status = o.status || 'pending';
                        return '<div class="flex items-center justify-between border-b-2 border-zinc-900 pb-4">' +
                                  '<div><p class="text-[10px] uppercase tracking-widest text-zinc-500 font-bold">Order</p>' +
                                  '<p class="font-display text-lg font-extrabold text-white">#' + o.id + '</p></div>' +
                                  '<div class="text-right"><p class="text-[10px] uppercase tracking-widest text-zinc-500 font-bold">' + dateStr + '</p>' +
                                  '<p class="text-sm text-white">$' + total + ' &middot; ' + status + '</p></div>' +
                               '</div>';
                    }).join('') + '</div>';
                } catch (e) {
                    wrap.innerHTML = '<p class="text-[10px] uppercase tracking-widest text-red-500 py-12 text-center font-bold">Failed to load orders.</p>';
                }
            },
            saveProfile: async function () {
                const fname = document.getElementById('acc-fname').value.trim();
                const lname = document.getElementById('acc-lname').value.trim();
                const phone = document.getElementById('acc-phone').value.trim();
                const name = (fname + ' ' + lname).trim();
                try {
                    await vmCustomer.updateProfile(name || null, phone || null);
                    const u = this.getUser();
                    if (u) {
                        document.getElementById('acc-greeting').textContent = 'Welcome, ' + ((u.fname) || 'friend');
                        document.getElementById('acc-ov-name').textContent = (u.fname + ' ' + u.lname).trim() || '—';
                    }
                    this.updateIcon();
                    app.ui.triggerToast('Profile updated');
                } catch (e) {
                    app.ui.triggerToast((e && e.message) || 'Update failed');
                }
            },
            changePassword: async function () {
                const cur = document.getElementById('acc-pw-cur').value;
                const nw  = document.getElementById('acc-pw-new').value;
                const conf = document.getElementById('acc-pw-conf').value;
                if (!cur || !nw || !conf) { app.ui.triggerToast('All password fields required'); return; }
                if (nw.length < 8) { app.ui.triggerToast('New password must be 8+ chars'); return; }
                if (nw !== conf) { app.ui.triggerToast('Passwords do not match'); return; }
                try {
                    await vmCustomer.changePassword(cur, nw);
                    ['acc-pw-cur','acc-pw-new','acc-pw-conf'].forEach(function (id) {
                        const el = document.getElementById(id); if (el) el.value = '';
                    });
                    app.ui.triggerToast('Password updated');
                } catch (e) {
                    app.ui.triggerToast((e && e.message) || 'Failed to change password');
                }
            }
        };

        window.app = app;

        window.addEventListener('DOMContentLoaded', () => app.init());
    </script>
</body>
</html>
