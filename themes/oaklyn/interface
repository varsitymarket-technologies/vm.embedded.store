            cursor: pointer;
        }

        .breadcrumb a:hover {
            color: var(--espresso);
        }

        .breadcrumb span {
            color: var(--gold);
        }

        /* ── SCROLL REVEAL ── */
        .reveal {
            opacity: 0;
            transform: translateY(24px);
            transition: opacity 0.6s ease, transform 0.6s ease;
        }

        .reveal.visible {
            opacity: 1;
            transform: translateY(0);
        }
    </style>
</head>

