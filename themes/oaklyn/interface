      <div style="font-family:'Cormorant Garamond',serif;font-size:18px;font-weight:300;color:var(--gold);">${o.status || 'Processing'}</div>
    </div>`).join("");
        }

        /* ORDERS LOOKUP */
        async function lookupOrders() {
            const email = document.getElementById("orders-email").value.trim();
            if (!email) { showToast("Please enter your email", "error"); return; }
            const orders = await fetchStore("orders", { email });
            const el = document.getElementById("orders-results");
            if (!orders.length) {
                el.innerHTML = `<div style="text-align:center;padding:48px 0;color:var(--stone);font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:300;">No orders found for this email.</div>`;
                return;
            }
            el.innerHTML = `<table style="width:100%;border-collapse:collapse;font-size:13px;">
    <thead><tr style="border-bottom:2px solid var(--cream);">
      <th style="text-align:left;padding:12px 0;font-family:'DM Mono',monospace;font-size:10px;letter-spacing:0.15em;text-transform:uppercase;color:var(--stone);">Order</th>
      <th style="text-align:left;padding:12px 0;font-family:'DM Mono',monospace;font-size:10px;letter-spacing:0.15em;text-transform:uppercase;color:var(--stone);">Date</th>
      <th style="text-align:left;padding:12px 0;font-family:'DM Mono',monospace;font-size:10px;letter-spacing:0.15em;text-transform:uppercase;color:var(--stone);">Total</th>
      <th style="text-align:left;padding:12px 0;font-family:'DM Mono',monospace;font-size:10px;letter-spacing:0.15em;text-transform:uppercase;color:var(--stone);">Status</th>
    </tr></thead>
    <tbody>${orders.map(o => `
      <tr style="border-bottom:1px solid var(--cream);">
        <td style="padding:16px 0;font-family:'DM Mono',monospace;">#${o.id}</td>
        <td style="padding:16px 0;color:var(--stone);">${o.created_at || '—'}</td>
        <td style="padding:16px 0;">${formatPrice(o.total_amount)}</td>
        <td style="padding:16px 0;"><span style="background:var(--cream);padding:3px 10px;font-family:'DM Mono',monospace;font-size:10px;letter-spacing:0.1em;text-transform:uppercase;">${o.status || 'Processing'}</span></td>
      </tr>`).join("")}
    </tbody></table>`;
        }

        /* ── CART DRAWER ── */
        function openCartDrawer() {
            renderCartDrawer();
            document.getElementById("cart-drawer").classList.add("open");
            document.getElementById("cart-drawer-overlay").classList.add("open");
            document.body.style.overflow = "hidden";
        }

        function closeCartDrawer() {
            document.getElementById("cart-drawer").classList.remove("open");
            document.getElementById("cart-drawer-overlay").classList.remove("open");
            document.body.style.overflow = "";
        }

        function renderCartDrawer() {
            const el = document.getElementById("cart-drawer-items");
            const subEl = document.getElementById("cart-drawer-subtotal");

            if (!cart.items.length) {
                el.innerHTML = `<div style="text-align:center;padding:48px 0;color:var(--stone);"><div style="font-size:40px;margin-bottom:16px;">🛍</div><p style="font-family:'Cormorant Garamond',serif;font-size:20px;">Your cart is empty</p></div>`;
                if (subEl) subEl.textContent = formatPrice(0);
                return;
            }

            el.innerHTML = cart.items.map(item => `
    <div style="display:flex;gap:16px;padding:16px 0;border-bottom:1px solid var(--cream);align-items:center;">
      <img src="${item.image}" style="width:64px;height:80px;object-fit:cover;background:var(--cream);" />
      <div style="flex:1;min-width:0;">
        <p style="font-family:'Cormorant Garamond',serif;font-size:15px;font-weight:400;margin-bottom:4px;line-height:1.3;">${item.name}</p>
        <p style="font-family:'DM Mono',monospace;font-size:11px;color:var(--stone);margin-bottom:8px;">${formatPrice(item.price)} × ${item.qty}</p>
        <div class="qty-ctrl" style="width:fit-content;">
          <button class="qty-btn" style="width:28px;height:28px;font-size:14px;" onclick="drawerUpdate(${item.id},${item.qty - 1})">−</button>
          <span class="qty-val" style="width:32px;font-size:12px;">${item.qty}</span>
          <button class="qty-btn" style="width:28px;height:28px;font-size:14px;" onclick="drawerUpdate(${item.id},${item.qty + 1})">+</button>
        </div>
      </div>
      <button onclick="drawerRemove(${item.id})" style="background:none;border:none;cursor:pointer;color:var(--stone);font-size:16px;flex-shrink:0;">✕</button>
    </div>`).join("");

            if (subEl) subEl.textContent = formatPrice(cart.subtotal());
        }

        function drawerUpdate(id, qty) { cart.update(id, qty); renderCartDrawer(); }
        function drawerRemove(id) { cart.remove(id); renderCartDrawer(); }

        /* ── SEARCH OVERLAY ── */
        let searchDebounce;
        async function doSearch(q) {
            const res = document.getElementById("search-results");
            if (!q) { res.innerHTML = ""; return; }
            const results = await fetchStore("search", { q });
            if (!results.length) { res.innerHTML = `<p style="font-family:'DM Mono',monospace;font-size:12px;color:var(--stone);letter-spacing:0.1em;">No results for "${q}"</p>`; return; }
            res.innerHTML = `<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;">${results.slice(0, 6).map(p => `
    <div style="cursor:pointer;" onclick="closeSearch();router.navigate('product',{id:${p.id}})">
      <img src="${p.image}" style="width:100%;aspect-ratio:1;object-fit:cover;background:var(--cream);display:block;margin-bottom:8px;" />
      <p style="font-family:'Cormorant Garamond',serif;font-size:15px;font-weight:400;">${p.name}</p>
      <p style="font-family:'DM Mono',monospace;font-size:11px;color:var(--stone);">${formatPrice(p.price)}</p>
    </div>`).join("")}</div>`;
        }

        function closeSearch() {
            document.getElementById("search-overlay").classList.remove("open");
            document.body.style.overflow = "";
        }

        /* CONTACT FORM */
        function submitContact() {
            const name = document.getElementById("contact-name").value;
            const email = document.getElementById("contact-email").value;
            const message = document.getElementById("contact-message").value;
            if (!name || !email || !message) { showToast("Please fill in all required fields", "error"); return; }
            showToast("Message sent! We'll be in touch within one business day.", "success");
            document.getElementById("contact-name").value = "";
            document.getElementById("contact-email").value = "";
            document.getElementById("contact-order").value = "";
            document.getElementById("contact-message").value = "";
        }

        /* NEWSLETTER */
        function subscribeNewsletter() {
            const email = document.getElementById("newsletter-input").value;
            if (!email) { showToast("Please enter your email", "error"); return; }
            showToast("You're subscribed to The OAKLYN Effect!", "success");
            document.getElementById("newsletter-input").value = "";
        }

        /* MOBILE NAV */
        function openMobileNav() { document.getElementById("mobile-nav").classList.add("open"); document.body.style.overflow = "hidden"; }
        function closeMobileNav() { document.getElementById("mobile-nav").classList.remove("open"); document.body.style.overflow = ""; }

        /* ── EVENT LISTENERS ── */
        document.getElementById("cart-toggle").addEventListener("click", openCartDrawer);
        document.getElementById("cart-drawer-close").addEventListener("click", closeCartDrawer);
        document.getElementById("cart-drawer-overlay").addEventListener("click", closeCartDrawer);
        document.getElementById("drawer-checkout-btn").addEventListener("click", closeCartDrawer);

        document.getElementById("hamburger-btn").addEventListener("click", openMobileNav);
        document.getElementById("mob-close").addEventListener("click", closeMobileNav);
        document.querySelectorAll("#mobile-nav a").forEach(a => a.addEventListener("click", closeMobileNav));

        document.getElementById("search-toggle").addEventListener("click", () => {
            document.getElementById("search-overlay").classList.add("open");
            document.body.style.overflow = "hidden";
            setTimeout(() => document.getElementById("search-input").focus(), 100);
        });
        document.getElementById("search-close").addEventListener("click", closeSearch);
        document.addEventListener("keydown", e => { if (e.key === "Escape") { closeSearch(); closeCartDrawer(); closeMobileNav(); } });

        document.getElementById("search-input").addEventListener("input", e => {
            clearTimeout(searchDebounce);
            searchDebounce = setTimeout(() => doSearch(e.target.value.trim()), 300);
        });

        window.addEventListener("cart-updated", () => {
            renderCartDrawer();
        });

        /* ── RESPONSIVE GRID ADJUSTMENTS ── */
        function updateGrids() {
            const w = window.innerWidth;
            const shopGrid = document.getElementById("shop-grid");
            if (shopGrid) shopGrid.style.gridTemplateColumns = w < 640 ? "1fr" : w < 1024 ? "repeat(2,1fr)" : "repeat(3,1fr)";
            const homeProds = document.getElementById("home-products");
            if (homeProds) homeProds.style.gridTemplateColumns = w < 640 ? "1fr 1fr" : w < 1024 ? "repeat(2,1fr)" : "repeat(4,1fr)";
            const homeCols = document.getElementById("home-collections");
            if (homeCols) homeCols.style.gridTemplateColumns = w < 640 ? "1fr" : w < 1024 ? "repeat(2,1fr)" : "repeat(3,1fr)";
            const saleProd = document.getElementById("sale-products");
            if (saleProd) saleProd.style.gridTemplateColumns = w < 640 ? "1fr 1fr" : w < 1024 ? "repeat(2,1fr)" : "repeat(4,1fr)";
            const relProd = document.getElementById("related-products");
            if (relProd) relProd.style.gridTemplateColumns = w < 640 ? "1fr 1fr" : "repeat(4,1fr)";
            const searchGrid = document.getElementById("search-page-grid");
            if (searchGrid) searchGrid.style.gridTemplateColumns = w < 640 ? "1fr 1fr" : w < 1024 ? "repeat(2,1fr)" : "repeat(4,1fr)";
            const colsGrid = document.getElementById("collections-grid");
            if (colsGrid) colsGrid.style.gridTemplateColumns = w < 640 ? "1fr" : w < 1024 ? "repeat(2,1fr)" : "repeat(3,1fr)";

            // Product page
            const prodGrid = document.querySelector("#view-product .page-inner > div:nth-child(2)");
            if (prodGrid) prodGrid.style.gridTemplateColumns = w < 768 ? "1fr" : "1fr 1fr";

            // Cart page
            const cartGrid = document.querySelector("#view-cart .page-inner > div:nth-child(2)");
            if (cartGrid) cartGrid.style.gridTemplateColumns = w < 1024 ? "1fr" : "1fr 360px";

            // Checkout grid
            const coGrid = document.querySelector("#view-checkout .page-inner > div");
            if (coGrid) coGrid.style.gridTemplateColumns = w < 1024 ? "1fr" : "1fr 380px";

            // Trust badges
            const trustBadges = document.querySelector(".view-section.active .page-inner > div[style*='grid-template-columns:repeat(3,1fr)']");
        }

        window.addEventListener("resize", updateGrids);

        /* ── INIT ── */
        window.addEventListener("DOMContentLoaded", async () => {
            // Load site config
            try {
                const site = await fetchStore("site");
                CURRENCY = site.currency || "R";
            } catch { }

            cart.updateBadge();
            renderFaq();
            router.init();
            updateGrids();
        });
    </script>
</body>

</html>