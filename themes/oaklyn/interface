                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 768px) {
            .nav-links {
                display: none;
            }

            .hamburger {
                display: flex;
            }

            .footer-grid {
                grid-template-columns: 1fr;
                gap: 32px;
            }

            .value-bar-inner {
                grid-template-columns: 1fr;
            }

            .hero-text {
                padding: 64px 24px;
            }
        }

        /* ── PAGE INNER ── */
        .page-inner {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 32px;
        }

        .page-section {
            padding: 80px 0;
        }

        @media (max-width: 640px) {
            .page-inner {
                padding: 0 20px;
            }

            .page-section {
                padding: 56px 0;
            }
        }

        /* ── SKELETON ── */
        .skeleton {
            background: linear-gradient(90deg, var(--cream) 25%, var(--ivory) 50%, var(--cream) 75%);
            background-size: 400% 100%;
            animation: shimmer 1.4s ease infinite;
        }

        @keyframes shimmer {
            0% {
                background-position: 100% 0
            }

            100% {
                background-position: -100% 0
            }
        }

        /* ── SALE BADGE ── */
        .sale-badge {
            background: var(--bark);
            color: var(--gold-lt);
            padding: 4px 12px;
            font-family: 'DM Mono', monospace;
            font-size: 9px;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            display: inline-block;
        }

        /* ── QTY CONTROL ── */
        .qty-ctrl {
            display: flex;
            align-items: center;
            border: 1px solid var(--cream);
        }

        .qty-btn {
            background: none;
            border: none;
            width: 36px;
            height: 36px;
            cursor: pointer;
            font-size: 16px;
            color: var(--espresso);
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background 0.2s;
        }

        .qty-btn:hover {
            background: var(--cream);
        }

        .qty-val {
            width: 44px;
            text-align: center;
            font-family: 'DM Mono', monospace;
            font-size: 13px;
        }

        /* ── DISCOUNT BADGE ── */
        .discount-card {
            background: var(--white);
            border: 1px dashed var(--gold);
            padding: 20px 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
        }

        .discount-code {
            font-family: 'DM Mono', monospace;
            font-size: 16px;
            letter-spacing: 0.15em;
            color: var(--espresso);
        }

        .discount-pct {
            font-family: 'Cormorant Garamond', serif;
            font-size: 28px;
            font-weight: 300;
            color: var(--gold);
        }

        /* ── BREADCRUMB ── */
        .breadcrumb {
            display: flex;
            gap: 8px;
            align-items: center;
            font-size: 11px;
            font-family: 'DM Mono', monospace;
            letter-spacing: 0.1em;
            color: var(--stone);
