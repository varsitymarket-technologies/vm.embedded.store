<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>OAKLYN — Curated Living</title>
    <meta name="description"
        content="OAKLYN is a curated lifestyle brand offering premium apparel, accessories, and home goods for the modern aesthetic." />
    <meta property="og:title" content="OAKLYN — Curated Living" />
    <meta property="og:description" content="Curated objects for a considered life." />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
        href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Mono:wght@300;400&family=Jost:wght@200;300;400;500&display=swap"
        rel="stylesheet" />

    <style>
        :root {
            --ivory: #f5f0e8;
            --cream: #ede7d9;
            --espresso: #2a1e14;
            --bark: #5c3d2e;
            --gold: #c8a96e;
            --gold-lt: #e8d5a8;
            --stone: #9a8f82;
            --white: #fdfaf5;
        }

        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Jost', sans-serif;
            background: var(--ivory);
            color: var(--espresso);
            font-weight: 300;
            letter-spacing: 0.01em;
            overflow-x: hidden;
        }

        /* ── TYPOGRAPHY ── */
        .font-serif {
            font-family: 'Cormorant Garamond', serif;
        }

        .font-mono {
            font-family: 'DM Mono', monospace;
        }

        /* ── VIEWS ── */
        .view-section {
            display: none;
        }

        .view-section.active {
            display: block;
        }

        /* ── ANNOUNCEMENT BAR ── */
        #announcement-bar {
            background: var(--espresso);
            color: var(--gold-lt);
            text-align: center;
            padding: 10px 16px;
            font-size: 11px;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            font-family: 'DM Mono', monospace;
        }

        /* ── HEADER ── */
        #site-header {
            background: var(--white);
            border-bottom: 1px solid var(--cream);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        #site-header nav {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 68px;
        }

        .nav-logo {
            font-family: 'Cormorant Garamond', serif;
            font-size: 28px;
            font-weight: 500;
            letter-spacing: 0.12em;
            color: var(--espresso);
            text-decoration: none;
            text-transform: uppercase;
        }

        .nav-links {
            display: flex;
            gap: 32px;
            align-items: center;
        }

        .nav-links a {
            font-size: 11px;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--bark);
            text-decoration: none;
            transition: color 0.2s;
        }

        .nav-links a:hover {
            color: var(--espresso);
        }

        .nav-icons {
            display: flex;
            gap: 20px;
            align-items: center;
        }

        .nav-icon-btn {
            background: none;
            border: none;
            cursor: pointer;
            color: var(--espresso);
            font-size: 18px;
            position: relative;
            padding: 4px;
        }

        .cart-badge {
            position: absolute;
            top: -4px;
            right: -6px;
            background: var(--gold);
            color: var(--espresso);
            border-radius: 50%;
            width: 16px;
            height: 16px;
            font-size: 9px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'DM Mono', monospace;
            font-weight: 400;
            display: none;
        }

        .hamburger {
            display: none;
            background: none;
            border: none;
            cursor: pointer;
            flex-direction: column;
            gap: 5px;
            padding: 4px;
        }

        .hamburger span {
            display: block;
            width: 22px;
            height: 1.5px;
            background: var(--espresso);
            transition: all 0.3s;
        }

        /* ── MOBILE NAV ── */
        #mobile-nav {
            display: none;
            position: fixed;
            inset: 0;
            z-index: 200;
            background: var(--espresso);
            color: var(--ivory);
            padding: 40px 32px;
        }

        #mobile-nav.open {
            display: flex;
            flex-direction: column;
        }

        #mobile-nav .mob-close {
            align-self: flex-end;
            background: none;
            border: none;
            color: var(--gold-lt);
            font-size: 24px;
            cursor: pointer;
            margin-bottom: 40px;
        }

        #mobile-nav a {
            font-family: 'Cormorant Garamond', serif;
            font-size: 36px;
            font-weight: 300;
            color: var(--ivory);
            text-decoration: none;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            padding: 16px 0;
            letter-spacing: 0.05em;
        }

        /* ── CART DRAWER ── */
        #cart-drawer-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(42, 30, 20, 0.5);
            z-index: 300;
        }

        #cart-drawer-overlay.open {
            display: block;
        }

        #cart-drawer {
            position: fixed;
            top: 0;
            right: -480px;
            width: 100%;
            max-width: 480px;
            height: 100%;
            background: var(--white);
            z-index: 301;
            display: flex;
            flex-direction: column;
            transition: right 0.35s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: -8px 0 40px rgba(42, 30, 20, 0.15);
        }

        #cart-drawer.open {
            right: 0;
        }

        .drawer-header {
            padding: 28px 32px;
            border-bottom: 1px solid var(--cream);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .drawer-header h2 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 22px;
            font-weight: 400;
            letter-spacing: 0.08em;
        }

        .drawer-close {
            background: none;
            border: none;
            cursor: pointer;
            font-size: 20px;
            color: var(--bark);
        }

        .drawer-items {
            flex: 1;
            overflow-y: auto;
            padding: 24px 32px;
        }

        .drawer-footer {
            padding: 24px 32px;
            border-top: 1px solid var(--cream);
        }

        /* ── SEARCH OVERLAY ── */
        #search-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(245, 240, 232, 0.97);
            z-index: 400;
            align-items: flex-start;
            justify-content: center;
            padding-top: 120px;
        }

        #search-overlay.open {
            display: flex;
        }

        .search-inner {
            width: 100%;
            max-width: 680px;
            padding: 0 24px;
        }

        .search-inner input {
            width: 100%;
            border: none;
            border-bottom: 2px solid var(--espresso);
            background: transparent;
            font-family: 'Cormorant Garamond', serif;
            font-size: 36px;
            color: var(--espresso);
            padding: 16px 0;
            outline: none;
            letter-spacing: 0.04em;
        }

        .search-inner input::placeholder {
            color: var(--stone);
        }

        #search-close {
            position: absolute;
            top: 32px;
            right: 40px;
            background: none;
            border: none;
            font-size: 28px;
            cursor: pointer;
            color: var(--espresso);
        }

        #search-results {
            margin-top: 32px;
        }

        /* ── TOAST ── */
        #toast-container {
            position: fixed;
            bottom: 32px;
            right: 32px;
            z-index: 500;
            display: flex;
            flex-direction: column;
            gap: 12px;
            pointer-events: none;
        }

        .toast {
            padding: 14px 22px;
            border-radius: 2px;
            font-family: 'DM Mono', monospace;
            font-size: 11px;
            letter-spacing: 0.1em;
            pointer-events: auto;
            animation: toastIn 0.3s ease;
        }

        .toast.success {
            background: var(--espresso);
            color: var(--gold-lt);
        }

        .toast.error {
            background: #7a2020;
            color: #fddede;
        }

        .toast.info {
            background: var(--bark);
            color: var(--ivory);
        }

        @keyframes toastIn {
            from {
                opacity: 0;
                transform: translateY(12px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ── BTN STYLES ── */
        .btn-primary {
            display: inline-block;
            background: var(--espresso);
            color: var(--gold-lt);
            padding: 14px 36px;
            font-size: 10px;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            font-family: 'DM Mono', monospace;
            cursor: pointer;
            border: none;
            transition: background 0.2s, color 0.2s;
            text-decoration: none;
        }

        .btn-primary:hover {
            background: var(--bark);
        }

        .btn-outline {
            display: inline-block;
            border: 1px solid var(--espresso);
            color: var(--espresso);
            padding: 13px 36px;
            font-size: 10px;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            font-family: 'DM Mono', monospace;
            cursor: pointer;
            background: transparent;
            transition: all 0.2s;
            text-decoration: none;
        }

        .btn-outline:hover {
            background: var(--espresso);
            color: var(--gold-lt);
        }

        .btn-gold {
            display: inline-block;
            background: var(--gold);
            color: var(--espresso);
            padding: 14px 36px;
            font-size: 10px;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            font-family: 'DM Mono', monospace;
            cursor: pointer;
            border: none;
            transition: background 0.2s;
        }

        .btn-gold:hover {
            background: var(--gold-lt);
        }

        /* ── PRODUCT CARD ── */
        .product-card {
            background: var(--white);
            cursor: pointer;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .product-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 16px 48px rgba(42, 30, 20, 0.1);
        }

        .product-card-img {
            width: 100%;
            aspect-ratio: 3/4;
            object-fit: cover;
            display: block;
            background: var(--cream);
        }

        .product-card-img-placeholder {
            width: 100%;
            aspect-ratio: 3/4;
            background: var(--cream);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--stone);
            font-size: 11px;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            font-family: 'DM Mono', monospace;
        }

        .product-card-body {
            padding: 16px 20px 20px;
        }

        .product-card-cat {
            font-size: 9px;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--stone);
            font-family: 'DM Mono', monospace;
            margin-bottom: 6px;
        }

        .product-card-name {
            font-family: 'Cormorant Garamond', serif;
            font-size: 18px;
            font-weight: 400;
            color: var(--espresso);
            margin-bottom: 8px;
            line-height: 1.3;
        }

        .product-card-price {
            font-family: 'DM Mono', monospace;
            font-size: 12px;
            color: var(--bark);
        }

        .product-badge {
            position: absolute;
            top: 16px;
            left: 16px;
            background: var(--gold);
            color: var(--espresso);
            font-size: 9px;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            font-family: 'DM Mono', monospace;
            padding: 4px 10px;
        }

        /* ── SECTION HEADING ── */
        .section-eyebrow {
            font-family: 'DM Mono', monospace;
            font-size: 10px;
            letter-spacing: 0.25em;
            text-transform: uppercase;
            color: var(--stone);
            margin-bottom: 12px;
        }

        .section-title {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(32px, 5vw, 56px);
            font-weight: 300;
            color: var(--espresso);
            line-height: 1.1;
        }

        /* ── FORM ── */
        .form-group {
            margin-bottom: 20px;
        }

        .form-label {
            display: block;
            font-size: 10px;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            font-family: 'DM Mono', monospace;
            color: var(--stone);
            margin-bottom: 8px;
        }

        .form-input {
            width: 100%;
            border: 1px solid var(--cream);
            background: var(--white);
            padding: 12px 16px;
            font-family: 'Jost', sans-serif;
            font-size: 14px;
            color: var(--espresso);
            outline: none;
            transition: border-color 0.2s;
        }

        .form-input:focus {
            border-color: var(--espresso);
        }

        .form-input::placeholder {
            color: var(--stone);
        }

        /* ── FOOTER ── */
        footer {
            background: var(--espresso);
            color: var(--ivory);
            padding: 64px 32px 32px;
            margin-top: 80px;
        }

        .footer-grid {
            max-width: 1400px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 48px;
            margin-bottom: 48px;
        }

        .footer-col h4 {
            font-family: 'DM Mono', monospace;
            font-size: 10px;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--gold);
            margin-bottom: 20px;
        }

        .footer-col a {
            display: block;
            color: rgba(245, 240, 232, 0.6);
            font-size: 13px;
            margin-bottom: 10px;
            text-decoration: none;
            letter-spacing: 0.04em;
            transition: color 0.2s;
        }

        .footer-col a:hover {
            color: var(--gold-lt);
        }

        .footer-brand {
            font-family: 'Cormorant Garamond', serif;
            font-size: 32px;
            font-weight: 300;
            letter-spacing: 0.12em;
            color: var(--white);
            margin-bottom: 12px;
        }

        .footer-tagline {
            font-size: 12px;
            color: var(--stone);
            letter-spacing: 0.08em;
        }

        .footer-bottom {
            max-width: 1400px;
            margin: 0 auto;
            padding-top: 24px;
            border-top: 1px solid rgba(255, 255, 255, 0.08);
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 11px;
            color: var(--stone);
            font-family: 'DM Mono', monospace;
        }

        /* ── ACCORDION ── */
        .accordion-item {
            border-bottom: 1px solid var(--cream);
        }

        .accordion-btn {
            width: 100%;
            background: none;
            border: none;
            text-align: left;
            padding: 20px 0;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .accordion-q {
            font-family: 'Cormorant Garamond', serif;
            font-size: 18px;
            font-weight: 400;
            color: var(--espresso);
        }

        .accordion-icon {
            font-size: 20px;
            color: var(--gold);
            transition: transform 0.3s;
            flex-shrink: 0;
        }

        .accordion-item.open .accordion-icon {
            transform: rotate(45deg);
        }

        .accordion-body {
            display: none;
            padding: 0 0 20px;
            color: var(--bark);
            line-height: 1.7;
            font-size: 14px;
        }

        .accordion-item.open .accordion-body {
            display: block;
        }

        /* ── CHECKOUT STEPS ── */
        .step-indicator {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 32px;
        }

        .step-dot {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'DM Mono', monospace;
            font-size: 11px;
            border: 1px solid var(--cream);
            color: var(--stone);
            transition: all 0.3s;
            flex-shrink: 0;
        }

        .step-dot.active {
            background: var(--espresso);
            color: var(--gold-lt);
            border-color: var(--espresso);
        }

        .step-dot.done {
            background: var(--gold);
            color: var(--espresso);
            border-color: var(--gold);
        }

        .step-line {
            flex: 1;
            height: 1px;
            background: var(--cream);
        }

        /* ── TRACKING TIMELINE ── */
        .track-step {
            display: flex;
            gap: 20px;
            align-items: flex-start;
            padding-bottom: 24px;
            position: relative;
        }

        .track-step-dot {
            width: 14px;
            height: 14px;
            border-radius: 50%;
            background: var(--cream);
            border: 2px solid var(--stone);
            flex-shrink: 0;
            margin-top: 3px;
            position: relative;
            z-index: 1;
        }

        .track-step.done .track-step-dot {
            background: var(--gold);
            border-color: var(--gold);
        }

        .track-step::after {
            content: '';
            position: absolute;
            left: 6px;
            top: 16px;
            bottom: 0;
            width: 2px;
            background: var(--cream);
        }

        .track-step:last-child::after {
            display: none;
        }

        /* ── HERO ── */
        .hero-bg {
            background: linear-gradient(135deg, var(--espresso) 0%, var(--bark) 50%, #3d2517 100%);
            min-height: 92vh;
            display: grid;
            grid-template-columns: 1fr 1fr;
            align-items: center;
            position: relative;
            overflow: hidden;
        }

        .hero-bg::before {
            content: '';
            position: absolute;
            inset: 0;
            background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23c8a96e' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        }

        .hero-text {
            padding: 80px 80px 80px 10%;
            color: var(--ivory);
            position: relative;
            z-index: 1;
        }

        .hero-eyebrow {
            font-family: 'DM Mono', monospace;
            font-size: 10px;
            letter-spacing: 0.3em;
            text-transform: uppercase;
            color: var(--gold);
            margin-bottom: 24px;
        }

        .hero-title {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(52px, 7vw, 96px);
            font-weight: 300;
            line-height: 1.0;
            margin-bottom: 28px;
        }

        .hero-title em {
            font-style: italic;
            color: var(--gold);
        }

        .hero-sub {
            font-size: 15px;
            color: rgba(245, 240, 232, 0.65);
            line-height: 1.7;
            margin-bottom: 40px;
            max-width: 380px;
            letter-spacing: 0.03em;
        }

        .hero-img-col {
            height: 92vh;
            position: relative;
            overflow: hidden;
        }

        .hero-img-col img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0.85;
        }

        .hero-img-placeholder {
            width: 100%;
            height: 100%;
            background: linear-gradient(180deg, rgba(92, 61, 46, 0.3) 0%, rgba(42, 30, 20, 0.6) 100%), url('https://images.unsplash.com/photo-1441986300917-64674bd600d8?w=900') center/cover;
        }

        /* ── VALUE PROPS ── */
        .value-bar {
            background: var(--espresso);
            padding: 24px 32px;
        }

        .value-bar-inner {
            max-width: 1400px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 16px;
        }

        .value-prop {
            display: flex;
            align-items: center;
            gap: 12px;
            color: var(--gold-lt);
        }

        .value-prop-icon {
            font-size: 18px;
            color: var(--gold);
            flex-shrink: 0;
        }

        .value-prop-text {
            font-size: 11px;
            letter-spacing: 0.1em;
        }

        /* ── COLLECTION CARD ── */
        .collection-card {
            position: relative;
            overflow: hidden;
            aspect-ratio: 4/5;
            cursor: pointer;
        }

        .collection-card img,
        .collection-card-bg {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            transition: transform 0.5s ease;
        }

        .collection-card:hover img,
        .collection-card:hover .collection-card-bg {
            transform: scale(1.04);
        }

        .collection-card-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, rgba(42, 30, 20, 0.7) 0%, transparent 60%);
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            padding: 32px;
        }

        .collection-card-overlay h3 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 28px;
            color: var(--white);
            font-weight: 300;
            letter-spacing: 0.05em;
        }

        .collection-card-overlay span {
            font-family: 'DM Mono', monospace;
            font-size: 10px;
            letter-spacing: 0.2em;
            color: var(--gold);
            text-transform: uppercase;
        }

        /* ── TRUST BADGES ── */
        .trust-badge {
            text-align: center;
            padding: 32px 24px;
        }

        .trust-badge-icon {
            font-size: 32px;
            margin-bottom: 12px;
            color: var(--gold);
        }

        .trust-badge h4 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 18px;
            font-weight: 400;
            margin-bottom: 6px;
        }

        .trust-badge p {
