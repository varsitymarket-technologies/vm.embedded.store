        /* Smooth, refined transitions */
        .fade-enter { animation: reveal 0.8s cubic-bezier(0.19, 1, 0.22, 1) forwards; }
        @keyframes reveal { from { opacity: 0; transform: translateY(15px); } to { opacity: 1; transform: translateY(0); } }
        
        .hidden { display: none !important; }

        /* Asymmetric grid spacing */
        .shop-grid > a:nth-child(even) { margin-top: 4rem; }
        
