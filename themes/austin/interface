            animation: shimmer 1.4s ease infinite;
            border-radius: 12px;
        }

        @keyframes shimmer {
            0% {
                background-position: 100% 0
            }

            100% {
                background-position: -100% 0
            }
        }

        /* ── VALUE BAR ── */
        .vbar {
            background: var(--forest);
            padding: 18px 40px;
