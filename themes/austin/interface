        function showAddrForm() { document.getElementById('addr-form-wrap').style.display = 'block'; }
        function hideAddrForm() { document.getElementById('addr-form-wrap').style.display = 'none'; }

        function saveAddress() {
            const addr = {
                fname: document.getElementById('af-fname').value.trim(),
                lname: document.getElementById('af-lname').value.trim(),
                street: document.getElementById('af-street').value.trim(),
                city: document.getElementById('af-city').value.trim(),
                province: document.getElementById('af-prov').value.trim(),
                postal: document.getElementById('af-post').value.trim(),
                country: document.getElementById('af-country').value.trim() || 'South Africa',
                isDefault: document.getElementById('af-default').checked
            };
            if (!addr.fname || !addr.street || !addr.city) { showToast('Please fill in required address fields', 'error'); return; }
            if (addr.isDefault) addresses.list.forEach(a => a.isDefault = false);
            addresses.add(addr); hideAddrForm(); renderAddresses(); showToast('Address saved');
        }

        function setDefAddr(id) { addresses.setDefault(id); renderAddresses(); showToast('Default address updated'); }
        function delAddr(id) { addresses.remove(id); renderAddresses(); showToast('Address removed', 'info'); }

        function renderWishlist() {
            const el = document.getElementById('wishlist-items');
            if (!wishlist.items.length) { el.innerHTML = `<div style="text-align:center;padding:56px 0;"><div style="font-family:'Playfair Display',serif;font-style:italic;font-size:28px;color:rgba(26,47,34,0.2);margin-bottom:12px;">Wishlist is empty.</div><p style="color:var(--ash);margin-bottom:22px;font-size:14px;">Browse the collection and save items you love.</p><a href="#shop" class="btn btn-dark">Shop Botanicals</a></div>`; return; }
            el.innerHTML = wishlist.items.map(p => `
    <div style="display:flex;gap:18px;align-items:center;padding:18px 0;border-bottom:1px solid rgba(26,47,34,0.07);">
      <div style="width:72px;height:88px;border-radius:12px;background:var(--sage);flex-shrink:0;overflow:hidden;">
        ${p.image ? `<img src="${p.image}" style="width:100%;height:100%;object-fit:cover;">` : ''}
      </div>
      <div style="flex:1;min-width:0;">
        <p class="font-mono" style="font-size:9px;color:var(--muted);letter-spacing:0.14em;text-transform:uppercase;margin-bottom:3px;">${MOCK.categories.find(c => c.id === p.category_id)?.name || ''}</p>
        <h4 class="font-serif" style="font-size:16px;color:var(--forest);margin-bottom:3px;">${p.name}</h4>
        <p class="font-mono" style="font-size:12px;color:var(--ash);">${fmt(p.price)}</p>
      </div>
      <div style="display:flex;gap:8px;align-items:center;">
        <button onclick="qAddWish(${p.id})" class="btn btn-dark" style="padding:8px 16px;font-size:11px;">Add to Cart</button>
        <button onclick="rmWish(${p.id})" style="background:none;border:1.5px solid rgba(26,47,34,0.12);color:var(--ash);width:34px;height:34px;border-radius:50%;cursor:pointer;font-size:14px;transition:all 0.2s;display:flex;align-items:center;justify-content:center;" onmouseover="this.style.borderColor='var(--warn)';this.style.color='var(--warn)'" onmouseout="this.style.borderColor='rgba(26,47,34,0.12)';this.style.color='var(--ash)'">✕</button>
      </div>
    </div>`).join('');
            document.getElementById('st-wish').textContent = wishlist.items.length;
        }

        async function qAddWish(id) { const p = await fetchStore('product', { id }); if (p && p.stock > 0) { cart.add(p, 1); openCart(); } else showToast('Out of stock', 'error'); }
        function rmWish(id) { const p = wishlist.items.find(i => i.id === id); if (p) wishlist.toggle(p); renderWishlist(); }

        async function saveAccountInfo() {
            const fname = document.getElementById('acc-fname').value.trim();
            const lname = document.getElementById('acc-lname').value.trim();
            const phone = document.getElementById('acc-phone').value.trim();
            const name = (fname + ' ' + lname).trim();
            try {
                await vmCustomer.updateProfile(name || null, phone || null);
                // helper updates vm_customer_cache; pull from there for re-render
                const u = auth.getUser();
                if (u) {
                    document.getElementById('sb-name').textContent = (u.fname + ' ' + u.lname).trim();
                    document.getElementById('sb-avatar').textContent =
                        (u.fname.charAt(0) + (u.lname ? u.lname.charAt(0) : '')).toUpperCase();
                }
                showToast('Profile updated');
            } catch (e) {
                showToast((e && e.message) || 'Update failed', 'error');
            }
        }

        function savePrefs() { showToast('Preferences saved'); }

        async function changePassword() {
            const cur = document.getElementById('pw-cur').value;
            const nw  = document.getElementById('pw-new').value;
            const conf = document.getElementById('pw-conf').value;
            if (!cur || !nw || !conf) { showToast('Please fill all password fields', 'error'); return; }
            if (nw.length < 8)  { showToast('New password must be at least 8 characters', 'error'); return; }
            if (nw !== conf)    { showToast('Passwords do not match', 'error'); return; }
            try {
                await vmCustomer.changePassword(cur, nw);
                ['pw-cur', 'pw-new', 'pw-conf'].forEach(function (id) {
                    const el = document.getElementById(id);
                    if (el) el.value = '';
                });
                showToast('Password updated');
            } catch (e) {
                showToast((e && e.message) || 'Failed to change password', 'error');
            }
        }

        /* ════════════════════════════════════
           RESPONSIVE GRIDS
        ════════════════════════════════════ */
        function updateGrids() {
            const w = window.innerWidth;
            const g = (id, cols) => { const el = document.getElementById(id); if (el) el.style.gridTemplateColumns = cols; };
            const cols = (desktop, tablet, mobile) => w < 640 ? mobile : w < 1024 ? tablet : desktop;

            g('shop-grid', cols('repeat(3,1fr)', 'repeat(2,1fr)', '1fr 1fr'));
            g('home-products', cols('repeat(4,1fr)', 'repeat(2,1fr)', '1fr 1fr'));
            g('home-collections', cols('repeat(4,1fr)', 'repeat(2,1fr)', '1fr 1fr'));
            g('collections-grid', cols('repeat(4,1fr)', 'repeat(2,1fr)', '1fr 1fr'));
            g('sale-products', cols('repeat(4,1fr)', 'repeat(2,1fr)', '1fr 1fr'));
            g('related-grid', cols('repeat(4,1fr)', 'repeat(2,1fr)', '1fr 1fr'));
            g('search-pg-grid', cols('repeat(4,1fr)', 'repeat(2,1fr)', '1fr 1fr'));
            g('addr-grid', cols('repeat(2,1fr)', 'repeat(2,1fr)', '1fr'));
            g('sale-discounts', w < 640 ? '1fr' : 'repeat(2,1fr)');

            const prodLayout = document.querySelector('#view-product .page-inner > div:nth-child(2)');
            if (prodLayout) prodLayout.style.gridTemplateColumns = w < 768 ? '1fr' : '1fr 1fr';

            const cartLayout = document.querySelector('#view-cart .page-inner > div:nth-child(2)');
            if (cartLayout) cartLayout.style.gridTemplateColumns = w < 1024 ? '1fr' : '1fr 340px';

            const coLayout = document.querySelector('#view-checkout .page-inner > div');
            if (coLayout) coLayout.style.gridTemplateColumns = w < 1024 ? '1fr' : '1fr 360px';
        }
        window.addEventListener('resize', updateGrids);

        /* ════════════════════════════════════
           EVENT LISTENERS
        ════════════════════════════════════ */
        document.getElementById('cart-toggle').addEventListener('click', openCart);
        document.getElementById('drawer-close').addEventListener('click', closeCart);
        document.getElementById('cart-overlay').addEventListener('click', closeCart);
        document.getElementById('drawer-checkout').addEventListener('click', closeCart);

        document.getElementById('hamburger-btn').addEventListener('click', openMobileNav);
        document.getElementById('mob-close').addEventListener('click', closeMobileNav);
        document.querySelectorAll('#mobile-nav a').forEach(a => a.addEventListener('click', closeMobileNav));

        document.getElementById('account-btn').addEventListener('click', () => {
            if (auth.isLoggedIn()) router.nav('dashboard');
            else openAuthModal('login');
        });

        document.getElementById('auth-close').addEventListener('click', closeAuthModal);
        document.getElementById('auth-overlay').addEventListener('click', e => {
            if (e.target === document.getElementById('auth-overlay')) closeAuthModal();
        });

        document.getElementById('search-toggle').addEventListener('click', openSearch);
        document.getElementById('search-close').addEventListener('click', closeSearch);
        document.getElementById('search-input').addEventListener('input', e => {
            clearTimeout(searchDebounce);
            searchDebounce = setTimeout(() => doSearch(e.target.value.trim()), 300);
        });

        document.addEventListener('keydown', e => {
            if (e.key === 'Escape') { closeSearch(); closeCart(); closeMobileNav(); closeAuthModal(); }
        });

        window.addEventListener('cart-updated', renderCartDrawer);

        /* ════════════════════════════════════
           INIT
        ════════════════════════════════════ */
        window.addEventListener('DOMContentLoaded', async () => {
            try { const site = await fetchStore('site'); CURRENCY = site.currency || 'R'; } catch { }
            cart.updateBadge();
            updateAccountBtn();
            updateGrids();
            renderFaq();
            router.init();
        });
    </script>
</body>

</html>