<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>e(__SITE_TITLE__)</title>
    <meta name="description" content="e(__SHOP_DESCRIPTION__)">
    <meta property="og:title" content="e(__SITE_TITLE__)">
    <meta property="og:description" content="e(__SHOP_DESCRIPTION__)">
    <meta property="og:image" content="e(__SITE_LOGO__)">
    <link rel="icon" href="e(__SITE_LOGO__)">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@300;400&display=swap"
        rel="stylesheet">

    <style>
        /* ── TOKENS ── */
        :root {
            --cream: #FDFCF8;
            --sage: #E6EBE7;
            --forest: #1A2F22;
            --muted: #648268;
            --dark: #0D1F15;
            --bone: #C8D4CA;
            --ash: #8A9E8E;
            --white: #FFFFFF;
            --blush: #F5EFE6;
            --warn: #C0392B;
            --glow: rgba(100, 130, 104, 0.18);
            --r: 1.5rem;
            /* card radius */
        }

        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--cream);
            color: var(--forest);
            font-weight: 400;
            letter-spacing: 0.01em;
            overflow-x: hidden;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* subtle paper texture */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            z-index: 0;
            pointer-events: none;
            opacity: 0.018;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
            background-size: 200px 200px;
        }

        /* ── TYPE ── */
        .font-serif {
            font-family: 'Playfair Display', serif;
        }

        .font-mono {
            font-family: 'DM Mono', monospace;
        }

        /* ── VIEWS ── */
        .view {
            display: none;
            position: relative;
            z-index: 1;
        }

        .view.active {
            display: block;
        }

        /* ── FADE ── */
        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(14px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .fade-in {
            animation: fadeUp 0.45s ease forwards;
        }

        /* ── ANNOUNCEMENT BAR ── */
        #bar {
            background: var(--forest);
            color: var(--bone);
            text-align: center;
            padding: 9px 16px;
            font-family: 'DM Mono', monospace;
            font-size: 10px;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            position: relative;
            z-index: 101;
        }

        /* ── HEADER ── */
        #site-header {
            position: sticky;
            top: 0;
            z-index: 100;
            background: rgba(253, 252, 248, 0.88);
            backdrop-filter: blur(16px);
            border-bottom: 1px solid rgba(26, 47, 34, 0.07);
        }

        #site-header nav {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 40px;
            height: 68px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .nav-logo {
            font-family: 'Playfair Display', serif;
            font-size: 22px;
            letter-spacing: 0.06em;
            color: var(--forest);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 9px;
        }

        .nav-logo svg {
            color: var(--muted);
            flex-shrink: 0;
        }

        .nav-links {
            display: flex;
            gap: 32px;
            align-items: center;
        }

        .nav-links a {
            font-size: 13px;
            font-weight: 500;
            letter-spacing: 0.04em;
            color: rgba(26, 47, 34, 0.65);
            text-decoration: none;
            transition: color 0.2s;
        }

        .nav-links a:hover,
        .nav-links a.active {
            color: var(--forest);
        }

        .nav-icons {
            display: flex;
            gap: 16px;
            align-items: center;
        }

        .nav-icon-btn {
            background: none;
            border: none;
            cursor: pointer;
            color: var(--ash);
            transition: color 0.2s;
            padding: 5px;
            position: relative;
        }

        .nav-icon-btn:hover {
            color: var(--forest);
        }

        .cart-pill {
            display: flex;
            align-items: center;
            gap: 8px;
            background: var(--sage);
            padding: 8px 18px;
            border-radius: 99px;
            font-size: 13px;
            font-weight: 500;
            color: var(--forest);
            cursor: pointer;
            border: none;
            transition: background 0.2s, color 0.2s;
        }

        .cart-pill:hover {
            background: var(--forest);
            color: var(--white);
        }

        .cart-count {
            background: var(--forest);
            color: var(--white);
            font-family: 'DM Mono', monospace;
            font-size: 9px;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background 0.2s;
        }

        .cart-pill:hover .cart-count {
            background: var(--muted);
        }

        .hamburger {
            display: none;
            background: none;
            border: none;
            cursor: pointer;
            flex-direction: column;
            gap: 5px;
            padding: 4px;
        }

        .hamburger span {
            display: block;
            width: 22px;
            height: 1.5px;
            background: var(--forest);
            transition: all 0.3s;
        }

        /* ── MOBILE NAV ── */
        #mobile-nav {
            display: none;
            position: fixed;
            inset: 0;
            z-index: 200;
            background: var(--cream);
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 0;
        }

        #mobile-nav.open {
            display: flex;
        }

        #mobile-nav .mob-close {
            position: absolute;
            top: 24px;
            right: 28px;
            background: none;
            border: none;
            font-size: 14px;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--ash);
            cursor: pointer;
        }

        #mobile-nav a {
            font-family: 'Playfair Display', serif;
            font-size: 38px;
            color: var(--forest);
            text-decoration: none;
            padding: 12px 0;
            border-bottom: 1px solid rgba(26, 47, 34, 0.07);
            width: 260px;
            text-align: center;
            transition: color 0.2s;
        }

        #mobile-nav a:hover {
            color: var(--muted);
        }

        /* ── CART DRAWER ── */
        #cart-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(13, 31, 21, 0.45);
            z-index: 300;
        }

        #cart-overlay.open {
            display: block;
        }

        #cart-drawer {
            position: fixed;
            top: 0;
            right: -520px;
            width: 100%;
            max-width: 500px;
            height: 100%;
            background: var(--cream);
            z-index: 301;
            display: flex;
            flex-direction: column;
            transition: right 0.35s cubic-bezier(0.4, 0, 0.2, 1);
            border-left: 1px solid rgba(26, 47, 34, 0.08);
        }

        #cart-drawer.open {
            right: 0;
        }

        .drawer-head {
            padding: 28px 32px;
            border-bottom: 1px solid rgba(26, 47, 34, 0.08);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .drawer-head h2 {
            font-family: 'Playfair Display', serif;
            font-size: 22px;
            color: var(--forest);
        }

        .drawer-close {
            background: none;
            border: none;
            cursor: pointer;
            font-size: 18px;
            color: var(--ash);
            transition: color 0.2s;
        }

        .drawer-close:hover {
            color: var(--warn);
        }

        .drawer-body {
            flex: 1;
            overflow-y: auto;
            padding: 24px 32px;
        }

        .drawer-foot {
            padding: 24px 32px;
            border-top: 1px solid rgba(26, 47, 34, 0.08);
        }

        .drawer-item {
            display: flex;
            gap: 14px;
            align-items: center;
            padding: 16px 0;
            border-bottom: 1px solid rgba(26, 47, 34, 0.07);
        }

        .drawer-item-img {
            width: 64px;
            height: 80px;
            border-radius: 10px;
            background: var(--sage);
            flex-shrink: 0;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .drawer-item-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .drawer-item-name {
            font-family: 'Playfair Display', serif;
            font-size: 14px;
            color: var(--forest);
            margin-bottom: 3px;
        }

        .drawer-item-price {
            font-family: 'DM Mono', monospace;
            font-size: 11px;
            color: var(--muted);
        }

        .qty-row {
            display: flex;
            align-items: center;
            background: var(--sage);
            border-radius: 99px;
            padding: 3px;
            width: fit-content;
            margin-top: 8px;
        }

        .qty-btn {
            background: none;
            border: none;
            width: 26px;
            height: 26px;
            border-radius: 50%;
            cursor: pointer;
            font-size: 16px;
            color: var(--forest);
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background 0.2s;
        }

        .qty-btn:hover {
            background: var(--white);
        }

        .qty-num {
            width: 28px;
            text-align: center;
            font-family: 'DM Mono', monospace;
            font-size: 12px;
            color: var(--forest);
        }

        /* ── SEARCH OVERLAY ── */
        #search-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(253, 252, 248, 0.97);
            z-index: 400;
            align-items: flex-start;
            justify-content: center;
            padding-top: 80px;
        }

        #search-overlay.open {
            display: flex;
        }

        .search-wrap {
            width: 100%;
            max-width: 680px;
            padding: 0 24px;
        }

        .search-wrap input {
            width: 100%;
            border: none;
            border-bottom: 2px solid var(--forest);
            background: transparent;
            font-family: 'Playfair Display', serif;
            font-size: 40px;
            color: var(--forest);
            padding: 14px 0;
            outline: none;
        }

        .search-wrap input::placeholder {
            color: rgba(26, 47, 34, 0.2);
        }

        #search-close {
            position: absolute;
            top: 28px;
            right: 36px;
            background: none;
            border: none;
            font-size: 14px;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--ash);
            cursor: pointer;
            transition: color 0.2s;
        }

        #search-close:hover {
            color: var(--forest);
        }

        /* ── TOAST ── */
        #toast-wrap {
            position: fixed;
            bottom: 28px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 500;
            display: flex;
            flex-direction: column;
            gap: 8px;
            pointer-events: none;
            align-items: center;
        }

        .toast {
            background: var(--forest);
            color: var(--bone);
            padding: 12px 24px;
            border-radius: 99px;
            font-family: 'DM Mono', monospace;
            font-size: 11px;
            letter-spacing: 0.08em;
            pointer-events: auto;
            white-space: nowrap;
            animation: toastIn 0.3s ease;
        }

        .toast.error {
            background: var(--warn);
        }

        .toast.info {
            background: var(--muted);
        }

        @keyframes toastIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ── AUTH MODAL ── */
        #auth-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(13, 31, 21, 0.5);
            z-index: 600;
            align-items: center;
            justify-content: center;
        }

        #auth-overlay.open {
            display: flex;
        }

        #auth-modal {
            background: var(--white);
            border-radius: 28px;
            width: 100%;
            max-width: 440px;
            padding: 48px 44px;
            position: relative;
            box-shadow: 0 40px 100px rgba(13, 31, 21, 0.18);
        }

        #auth-close {
            position: absolute;
            top: 18px;
            right: 22px;
            background: none;
            border: none;
            cursor: pointer;
            color: var(--ash);
            font-size: 18px;
            transition: color 0.2s;
        }

        #auth-close:hover {
            color: var(--warn);
        }

        .auth-tabs {
            display: flex;
            border-bottom: 1px solid rgba(26, 47, 34, 0.1);
            margin-bottom: 30px;
        }

        .auth-tab {
            flex: 1;
            padding: 11px 0;
            text-align: center;
            font-size: 12px;
            font-weight: 500;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            cursor: pointer;
            color: var(--ash);
            border-bottom: 2px solid transparent;
            margin-bottom: -1px;
            transition: all 0.2s;
            background: none;
            border-top: none;
            border-left: none;
            border-right: none;
        }

        .auth-tab.active {
            color: var(--forest);
            border-bottom-color: var(--muted);
        }

        .auth-panel {
            display: none;
        }

        .auth-panel.active {
            display: block;
        }

        /* ── BUTTONS ── */
        .btn {
            display: inline-block;
            cursor: pointer;
            border: none;
            font-family: 'DM Sans', sans-serif;
            font-weight: 500;
            text-decoration: none;
            transition: all 0.2s;
        }

        .btn-dark {
            background: var(--forest);
            color: var(--white);
            padding: 14px 36px;
            border-radius: 99px;
            font-size: 13px;
            letter-spacing: 0.04em;
        }

        .btn-dark:hover {
            background: var(--muted);
        }

        .btn-outline {
            background: transparent;
            color: var(--forest);
            border: 1.5px solid rgba(26, 47, 34, 0.25);
            padding: 12px 32px;
            border-radius: 99px;
            font-size: 13px;
            letter-spacing: 0.04em;
        }

        .btn-outline:hover {
            border-color: var(--forest);
        }

        .btn-sage {
            background: var(--sage);
            color: var(--forest);
            padding: 12px 28px;
            border-radius: 99px;
            font-size: 13px;
        }

        .btn-sage:hover {
            background: var(--muted);
            color: var(--white);
        }

        /* ── FORMS ── */
        .form-group {
            margin-bottom: 18px;
        }

        .form-label {
            display: block;
            font-family: 'DM Mono', monospace;
            font-size: 9px;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--ash);
            margin-bottom: 7px;
        }

        .form-input {
            width: 100%;
            background: rgba(230, 235, 231, 0.4);
            border: 1px solid rgba(26, 47, 34, 0.1);
            border-radius: 12px;
            padding: 11px 16px;
            font-family: 'DM Sans', sans-serif;
            font-size: 14px;
            color: var(--forest);
            outline: none;
            transition: border-color 0.2s;
        }

        .form-input:focus {
            border-color: var(--muted);
            background: var(--white);
        }

        .form-input::placeholder {
            color: rgba(26, 47, 34, 0.3);
        }

        select.form-input option {
            background: var(--cream);
        }

        /* ── PAGE INNER ── */
        .page-inner {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 40px;
        }

        .page-section {
            padding: 80px 0;
        }

        .eyebrow {
            font-family: 'DM Mono', monospace;
            font-size: 10px;
            letter-spacing: 0.22em;
            text-transform: uppercase;
            color: var(--muted);
            margin-bottom: 12px;
        }

        .section-title {
            font-family: 'Playfair Display', serif;
            font-size: clamp(32px, 5vw, 64px);
            color: var(--forest);
            line-height: 1.05;
        }

        .divider {
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(26, 47, 34, 0.1), transparent);
        }

        /* ── PRODUCT CARD ── */
        .product-card {
            cursor: pointer;
            transition: transform 0.4s, box-shadow 0.4s;
        }

        .product-card:hover {
            transform: translateY(-5px);
        }

        .product-card-img {
            width: 100%;
            aspect-ratio: 4/5;
            background: var(--sage);
            border-radius: var(--r);
            overflow: hidden;
            margin-bottom: 16px;
            position: relative;
        }

        .product-card-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.6s ease;
        }

        .product-card:hover .product-card-img img {
            transform: scale(1.04);
        }

        .product-card-img-placeholder {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Playfair Display', serif;
            font-style: italic;
            font-size: 13px;
            color: rgba(26, 47, 34, 0.25);
        }

        .product-card-quick {
            position: absolute;
            bottom: 12px;
            left: 12px;
            right: 12px;
            background: var(--forest);
            color: var(--white);
            border: none;
            border-radius: 99px;
            padding: 10px;
            font-family: 'DM Sans', sans-serif;
            font-size: 12px;
            font-weight: 500;
            cursor: pointer;
            opacity: 0;
            transform: translateY(6px);
            transition: opacity 0.3s, transform 0.3s;
        }

        .product-card:hover .product-card-quick {
            opacity: 1;
            transform: translateY(0);
        }

        .product-card-quick:hover {
            background: var(--muted);
        }

        .product-card-name {
            font-family: 'Playfair Display', serif;
            font-size: 16px;
            color: var(--forest);
            margin-bottom: 4px;
            text-align: center;
        }

        .product-card-price {
            font-family: 'DM Mono', monospace;
            font-size: 12px;
            color: var(--muted);
            text-align: center;
        }

        .product-card-cat {
            font-family: 'DM Mono', monospace;
            font-size: 9px;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            color: var(--ash);
            text-align: center;
            margin-bottom: 4px;
        }

        /* ── ACCORDION ── */
        .acc-item {
            border-bottom: 1px solid rgba(26, 47, 34, 0.1);
        }

        .acc-btn {
            width: 100%;
            background: none;
            border: none;
            text-align: left;
            padding: 20px 0;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .acc-q {
            font-family: 'Playfair Display', serif;
            font-size: 17px;
            color: var(--forest);
        }

        .acc-icon {
            font-size: 20px;
            color: var(--muted);
            transition: transform 0.3s;
            font-weight: 300;
        }

        .acc-item.open .acc-icon {
            transform: rotate(45deg);
        }

        .acc-body {
            display: none;
            padding: 0 0 20px;
            color: var(--ash);
            line-height: 1.75;
            font-size: 14px;
        }

        .acc-item.open .acc-body {
            display: block;
        }

        /* ── STEP INDICATOR ── */
        .step-row {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 40px;
        }

        .step-dot {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'DM Mono', monospace;
            font-size: 11px;
            border: 1.5px solid rgba(26, 47, 34, 0.18);
            color: var(--ash);
            transition: all 0.3s;
            flex-shrink: 0;
        }

        .step-dot.active {
            background: var(--forest);
            color: var(--white);
            border-color: var(--forest);
        }

        .step-dot.done {
            background: var(--sage);
            color: var(--muted);
            border-color: var(--muted);
        }

        .step-line {
            flex: 1;
            height: 1px;
            background: rgba(26, 47, 34, 0.12);
        }

        /* ── TRACK STEPS ── */
        .track-step {
            display: flex;
            gap: 18px;
            align-items: flex-start;
            padding-bottom: 24px;
            position: relative;
        }

        .track-dot {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: rgba(26, 47, 34, 0.15);
            border: 2px solid rgba(26, 47, 34, 0.15);
            flex-shrink: 0;
            margin-top: 4px;
            position: relative;
            z-index: 1;
        }

        .track-step.done .track-dot {
            background: var(--muted);
            border-color: var(--muted);
            box-shadow: 0 0 8px var(--glow);
        }

        .track-step::after {
            content: '';
            position: absolute;
            left: 5px;
            top: 16px;
            bottom: 0;
            width: 2px;
            background: rgba(26, 47, 34, 0.1);
        }

        .track-step:last-child::after {
            display: none;
        }

        .track-step.done::after {
            background: var(--muted);
            opacity: 0.4;
        }

        /* ── COLL CARD ── */
        .coll-card {
            position: relative;
            overflow: hidden;
            border-radius: 24px;
            aspect-ratio: 4/5;
            cursor: pointer;
        }

        .coll-card-bg {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.6s ease;
            display: block;
            filter: saturate(0.85);
