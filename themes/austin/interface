══════════════════════════ -->
    <script>
        /* ════════════════════════════════════
           MOCK DATA
        ════════════════════════════════════ */
        const MOCK = {
            site: { name: 'Austin', currency: 'e(__SYSTEM_CURRENCY__)' },
            categories: [
                { id: 1, name: 'Indoor Plants' },
                { id: 2, name: 'Ceramics' },
                { id: 3, name: 'Apothecary' },
                { id: 4, name: 'Tools' }
            ],
            products: [
                { id: 1, name: 'Ficus Elastica', price: 45, category_id: 1, image: 'https://images.unsplash.com/photo-1485955900006-10f4d324d411?w=600', description: 'A stunning Rubber Tree with deep burgundy leaves. Easy to care for and perfect for bright indirect light.', stock: 14 },
                { id: 2, name: 'Monstera Deliciosa', price: 60, category_id: 1, image: 'https://images.unsplash.com/photo-1614594975525-e45190c55d0b?w=600', description: 'The classic Swiss Cheese plant. Fast-growing and provides an instant tropical feel to any room.', stock: 9 },
                { id: 3, name: 'Terracotta Planter', price: 35, category_id: 2, image: 'https://images.unsplash.com/photo-1565193566173-7a0ee3dbe261?w=600', description: 'Hand-thrown unglazed terracotta. Provides excellent aeration for plant roots.', stock: 30 },
                { id: 4, name: 'Neem Oil Serum', price: 18, category_id: 3, image: 'https://images.unsplash.com/photo-1608248543803-ba4f8c70ae0b?w=600', description: 'Cold-pressed organic neem oil blended with peppermint. The ultimate natural leaf shine and protector.', stock: 25 },
                { id: 5, name: 'Brass Pruning Shears', price: 42, category_id: 4, image: 'https://images.unsplash.com/photo-1416879595882-3373a0480b5b?w=600', description: 'Solid brass Japanese-style pruning scissors. Keeps your plants neatly manicured.', stock: 7 },
                { id: 6, name: 'Olive Tree', price: 110, category_id: 1, image: 'https://images.unsplash.com/photo-1552896994-4c1b8e0c0e3f?w=600', description: 'A Mediterranean classic adapted for indoor living. Requires bright, sunny windows.', stock: 4 },
                { id: 7, name: 'Marble Planter', price: 55, category_id: 2, image: 'https://images.unsplash.com/photo-1485955900006-10f4d324d411?w=600', description: 'Cast marble-effect concrete planter with drainage hole. A timeless vessel for any botanical.', stock: 12 },
                { id: 8, name: 'Fiddle Leaf Fig', price: 85, category_id: 1, image: 'https://images.unsplash.com/photo-1634553573984-af85c4b83f04?w=600', description: 'The beloved statement plant. Large, architectural leaves that define a room.', stock: 6 },
                { id: 9, name: 'Plant Food Concentrate', price: 22, category_id: 3, image: 'https://images.unsplash.com/photo-1553361371-9b22f78e8b1d?w=600', description: 'Balanced NPK organic plant food concentrate. Mix 5ml per litre of water for weekly feeding.', stock: 18 },
                { id: 10, name: 'Long-Handled Trowel', price: 32, category_id: 4, image: 'https://images.unsplash.com/photo-1416879595882-3373a0480b5b?w=600', description: 'Stainless steel trowel with a sustainably sourced hardwood handle. Lifetime guarantee.', stock: 20 },
                { id: 11, name: 'Pothos Golden', price: 28, category_id: 1, image: 'https://images.unsplash.com/photo-1614594975525-e45190c55d0b?w=600', description: 'The unkillable houseplant. Thrives in low light, tolerates neglect, and trails beautifully.', stock: 22 },
                { id: 12, name: 'Ceramic Mist Bottle', price: 38, category_id: 2, image: 'https://images.unsplash.com/photo-1565193566173-7a0ee3dbe261?w=600', description: 'Fine-mist ceramic spray bottle with a brass nozzle. Keeps foliage hydrated and lustrous.', stock: 15 }
            ],
            discounts: [
                { id: 1, code: 'WELCOME10', percentage: 10, active: 1 },
                { id: 2, code: 'BLOOM20', percentage: 20, active: 1 }
            ]
        };

        /* ════════════════════════════════════
           API WRAPPER (falls back to MOCK)
        ════════════════════════════════════ */
        async function fetchStore(state, params = {}) {
            const url = new URL('api.php', window.location.href);
            url.searchParams.set('state', state);
            for (const [k, v] of Object.entries(params)) url.searchParams.set(k, v);
            try {
                const res = await fetch(url, { signal: AbortSignal.timeout(4000) });
                if (!res.ok) throw new Error(res.status);
                return await res.json();
            } catch {
                return getMockData(state, params);
            }
        }

        function getMockData(state, params = {}) {
            switch (state) {
                case 'site': return MOCK.site;
                case 'products': return MOCK.products;
                case 'product': return MOCK.products.find(p => p.id == params.id) || null;
                case 'categories': return MOCK.categories;
                case 'products_by_category': return MOCK.products.filter(p => p.category_id == params.category_id);
                case 'search': {
                    const q = (params.q || '').toLowerCase();
                    return MOCK.products.filter(p =>
                        p.name.toLowerCase().includes(q) ||
                        p.description.toLowerCase().includes(q) ||
                        (MOCK.categories.find(c => c.id === p.category_id)?.name || '').toLowerCase().includes(q)
                    );
                }
                case 'discounts': return MOCK.discounts;
                case 'orders': return [];
                default: return [];
            }
        }

        /* ════════════════════════════════════
           CURRENCY
        ════════════════════════════════════ */
        let CURRENCY = 'R';
        const fmt = a => `${CURRENCY}${parseFloat(a).toFixed(2)}`;

        /* ════════════════════════════════════
           TOAST
        ════════════════════════════════════ */
        function showToast(msg, type = 'success') {
            const wrap = document.getElementById('toast-wrap');
            const el = document.createElement('div');
            el.className = `toast ${type}`;
            el.textContent = msg;
            wrap.appendChild(el);
            setTimeout(() => el.remove(), 3200);
        }

        /* ════════════════════════════════════
           CART
        ════════════════════════════════════ */
        const cart = {
            items: JSON.parse(localStorage.getItem('aus_cart') || '[]'),
            appliedDiscount: null,
            save() {
                localStorage.setItem('aus_cart', JSON.stringify(this.items));
                this.updateBadge();
                window.dispatchEvent(new CustomEvent('cart-updated'));
            },
            add(product, qty = 1) {
                const ex = this.items.find(i => i.id === product.id);
                if (ex) ex.qty = Math.min(ex.qty + qty, product.stock);
                else this.items.push({ ...product, qty });
                this.save();
                showToast(`${product.name} added to cart`);
            },
            update(id, qty) {
                const i = this.items.find(x => x.id === id);
                if (!i) return;
                i.qty = Math.max(0, qty);
                if (i.qty === 0) this.remove(id);
                else this.save();
            },
            remove(id) { this.items = this.items.filter(i => i.id !== id); this.save(); },
            clear() { this.items = []; this.appliedDiscount = null; this.save(); },
            subtotal() { return this.items.reduce((s, i) => s + i.price * i.qty, 0); },
            count() { return this.items.reduce((s, i) => s + i.qty, 0); },
            applyCode(code, discounts) {
                const d = discounts.find(d => d.code.toUpperCase() === code.toUpperCase() && d.active);
                if (!d) return null;
                this.appliedDiscount = { code: d.code, pct: d.percentage, amount: this.subtotal() * (d.percentage / 100) };
                return this.appliedDiscount;
            },
            updateBadge() {
                const c = this.count();
                document.querySelectorAll('[data-cart-count]').forEach(el => {
                    el.textContent = c;
                    el.style.display = c > 0 ? 'flex' : 'flex';
                });
            }
        };
        cart.updateBadge();

        /* ════════════════════════════════════
           AUTH (localStorage mock)
        ════════════════════════════════════ */
        // D.2: auth adapter delegating to vm-customer.js. The returned shape
        // matches what austin's existing render code expects: fname/lname
        // (split from backend's single name field), email, phone, joinDate,
        // and orders (hydrated separately by hydrateOrdersForDashboard()).
        const auth = {
            getUser() {
                if (!window.vmCustomer || !vmCustomer.isLoggedIn()) return null;
                const c = vmCustomer.cached();
                if (!c) return null;
                const parts = (c.name || '').trim().split(/\s+/).filter(Boolean);
                return {
                    email: c.email,
                    fname: parts[0] || '',
                    lname: parts.slice(1).join(' '),
                    phone: c.phone || '',
                    joinDate: c.created_at || '',
                    orders: window.__aus_orders__ || []
                };
            },
            isLoggedIn() { return !!window.vmCustomer && vmCustomer.isLoggedIn(); }
            // setUser + clearUser deleted — call sites now go through
            // vmCustomer.updateProfile / vmCustomer.logout directly.
        };

        /* ════════════════════════════════════
           WISHLIST
        ════════════════════════════════════ */
        const wishlist = {
            items: JSON.parse(localStorage.getItem('aus_wishlist') || '[]'),
            save() { localStorage.setItem('aus_wishlist', JSON.stringify(this.items)); },
            toggle(product) {
                const idx = this.items.findIndex(i => i.id === product.id);
                if (idx > -1) { this.items.splice(idx, 1); showToast('Removed from wishlist', 'info'); }
                else { this.items.push(product); showToast('Added to wishlist'); }
                this.save();
            },
            has(id) { return this.items.some(i => i.id === id); }
        };

        /* ════════════════════════════════════
           ADDRESSES
        ════════════════════════════════════ */
        const addresses = {
            list: JSON.parse(localStorage.getItem('aus_addresses') || '[]'),
            save() { localStorage.setItem('aus_addresses', JSON.stringify(this.list)); },
            add(addr) { this.list.push({ ...addr, id: Date.now() }); this.save(); },
            remove(id) { this.list = this.list.filter(a => a.id !== id); this.save(); },
            setDefault(id) { this.list.forEach(a => a.isDefault = (a.id === id)); this.save(); }
        };

        /* ════════════════════════════════════
           PRODUCT CARD
        ════════════════════════════════════ */
        function productCard(p) {
            const cat = MOCK.categories.find(c => c.id === p.category_id);
            return `
    <div class="product-card" data-pid="${p.id}">
      <div class="product-card-img">
        ${p.image
                    ? `<img src="${p.image}" alt="${p.name}" loading="lazy">`
                    : `<div class="product-card-img-placeholder">${p.name}</div>`}
        <button class="product-card-quick" onclick="quickAdd(${p.id}, event)">Quick Add</button>
      </div>
      <div>
        <p class="product-card-cat">${cat ? cat.name : ''}</p>
        <h3 class="product-card-name">${p.name}</h3>
        <div style="display:flex;align-items:center;justify-content:center;gap:10px;margin-top:4px;">
          <p class="product-card-price">${fmt(p.price)}</p>
          <button onclick="wishlist.toggle(${JSON.stringify(p).replace(/"/g, '&quot;')});event.stopPropagation();" style="background:none;border:none;cursor:pointer;font-size:14px;color:${wishlist.has(p.id) ? 'var(--muted)' : 'rgba(26,47,34,0.25)'};transition:color 0.2s;" title="Wishlist">♡</button>
        </div>
      </div>
    </div>`;
        }

        function bindCards() {
            document.querySelectorAll('.product-card[data-pid]').forEach(card => {
                card.onclick = e => {
                    if (e.target.tagName === 'BUTTON' || e.target.closest('button')) return;
                    router.nav('product', { id: card.dataset.pid });
                };
            });
        }

        async function quickAdd(id, e) {
            e.stopPropagation();
            const p = await fetchStore('product', { id });
            if (p && p.stock > 0) { cart.add(p, 1); openCart(); }
            else showToast('Out of stock', 'error');
        }

        /* ════════════════════════════════════
           ROUTER
        ════════════════════════════════════ */
        let currentStep = 1;
        let shopCat = null;
        let shopAll = [];
        let currentProduct = null;
        let currentQty = 1;

        const router = {
            init() { window.addEventListener('hashchange', () => this.resolve()); this.resolve(); },
            nav(view, params = {}) {
                let hash = `#${view}`;
                const qs = new URLSearchParams(params).toString();
                if (qs) hash += `?${qs}`;
                window.location.hash = hash;
            },
            resolve() {
                const raw = window.location.hash.slice(1) || 'home';
                const [view, qs] = raw.split('?');
                const params = Object.fromEntries(new URLSearchParams(qs || ''));
                document.querySelectorAll('.view').forEach(s => s.classList.remove('active'));
                const target = document.getElementById(`view-${view}`);
                if (target) target.classList.add('active');
                else document.getElementById('view-home').classList.add('active');
                document.title = `Austin — ${view.charAt(0).toUpperCase() + view.slice(1)}`;
                window.scrollTo({ top: 0, behavior: 'instant' });
                closeCart(); closeMobileNav();
                this.onRoute(view, params);
            },
            onRoute(view, params) {
                switch (view) {
                    case 'home': renderHome(); break;
                    case 'shop': renderShop(params.cat); break;
                    case 'product': renderProduct(params.id); break;
                    case 'collections': renderCollections(); break;
                    case 'sale': renderSale(); break;
                    case 'cart': renderCartPage(); break;
                    case 'checkout': renderCheckout(); break;
                    case 'search': renderSearchPage(params.q); break;
                    case 'faq': renderFaq(); break;
                    case 'dashboard': renderDashboard(); break;
                    case 'track': if (params.email) { document.getElementById('track-email').value = params.email; trackOrder(); } break;
                    case 'orders': if (params.email) { document.getElementById('orders-email').value = params.email; lookupOrders(); } break;
                }
            }
        };

        /* ════════════════════════════════════
           PAGE RENDERERS
        ════════════════════════════════════ */

        async function renderHome() {
            const [prods, cats] = await Promise.all([fetchStore('products'), fetchStore('categories')]);

            // Featured products (4)
            const hp = document.getElementById('home-products');
            hp.innerHTML = prods.slice(0, 4).map(productCard).join('');
            bindCards();

            // Collections
            const imgs = [
                'https://images.unsplash.com/photo-1485955900006-10f4d324d411?w=600',
                'https://images.unsplash.com/photo-1565193566173-7a0ee3dbe261?w=600',
                'https://images.unsplash.com/photo-1608248543803-ba4f8c70ae0b?w=600',
                'https://images.unsplash.com/photo-1416879595882-3373a0480b5b?w=600'
            ];
            const hc = document.getElementById('home-collections');
            hc.innerHTML = cats.map((c, i) => {
                const cnt = MOCK.products.filter(p => p.category_id === c.id).length;
                return `<div class="coll-card" style="cursor:pointer;" onclick="router.nav('shop',{cat:${c.id}})">
      <img class="coll-card-bg" src="${imgs[i] || imgs[0]}" alt="${c.name}">
      <div class="coll-card-over"><span>${cnt} items</span><h3>${c.name}</h3></div>
    </div>`;
            }).join('');
        }

        async function renderShop(catId) {
            const [prods, cats] = await Promise.all([fetchStore('products'), fetchStore('categories')]);
            shopAll = prods;
            shopCat = catId ? parseInt(catId) : null;

            // Filters
            const fEl = document.getElementById('shop-filters');
            fEl.innerHTML = `<button onclick="shopFilter(null)" style="display:block;width:100%;text-align:left;background:none;border:none;cursor:pointer;padding:8px 0;font-size:13px;border-bottom:1px solid rgba(26,47,34,0.07);color:${!shopCat ? 'var(--forest)' : 'var(--ash)'};font-weight:${!shopCat ? 500 : 400};transition:color 0.2s;">All Products</button>`
                + cats.map(c => `<button onclick="shopFilter(${c.id})" style="display:block;width:100%;text-align:left;background:none;border:none;cursor:pointer;padding:8px 0;font-size:13px;border-bottom:1px solid rgba(26,47,34,0.07);color:${shopCat === c.id ? 'var(--forest)' : 'var(--ash)'};font-weight:${shopCat === c.id ? 500 : 400};transition:color 0.2s;">${c.name}</button>`).join('');

            buildShopGrid();
        }

        function shopFilter(id) { shopCat = id; buildShopGrid(); }

        function buildShopGrid() {
            let list = shopCat ? shopAll.filter(p => p.category_id === shopCat) : shopAll;
            const sort = document.getElementById('shop-sort')?.value || 'default';
            if (sort === 'price-asc') list = [...list].sort((a, b) => a.price - b.price);
            if (sort === 'price-desc') list = [...list].sort((a, b) => b.price - a.price);

            const ct = document.getElementById('shop-count');
            if (ct) ct.textContent = `${list.length} items`;

            const grid = document.getElementById('shop-grid');
            if (!grid) return;
            if (!list.length) {
                grid.innerHTML = `<div style="grid-column:1/-1;text-align:center;padding:80px 0;font-family:'Playfair Display',serif;font-style:italic;font-size:20px;color:rgba(26,47,34,0.3);">No products found</div>`;
                return;
            }
            grid.innerHTML = list.map(productCard).join('');
            bindCards();
        }

        async function renderProduct(id) {
            currentQty = 1;
            document.getElementById('prod-qty').textContent = 1;
            const p = await fetchStore('product', { id });
            if (!p) { showToast('Product not found', 'error'); router.nav('shop'); return; }
            currentProduct = p;
            const cat = MOCK.categories.find(c => c.id === p.category_id);

            document.getElementById('prod-bc').textContent = p.name;
            document.getElementById('prod-cat').textContent = cat ? cat.name : '';
            document.getElementById('prod-name').textContent = p.name;
            document.getElementById('prod-price').textContent = fmt(p.price);
            document.getElementById('prod-desc').textContent = p.description;

            const img = document.getElementById('prod-img');
            const fallback = document.getElementById('prod-img-fallback');
            if (p.image) { img.src = p.image; img.alt = p.name; img.style.display = 'block'; fallback.style.display = 'none'; }
            else { img.style.display = 'none'; fallback.style.display = 'block'; }

            const sb = document.getElementById('prod-stock');
            const btn = document.getElementById('add-to-cart-btn');
            if (p.stock > 10) sb.innerHTML = `<span style="background:rgba(100,130,104,0.12);color:var(--muted);border:1px solid rgba(100,130,104,0.2);padding:4px 12px;border-radius:99px;font-family:'DM Mono',monospace;font-size:9px;letter-spacing:0.14em;text-transform:uppercase;">In Stock</span>`;
            else if (p.stock > 0) sb.innerHTML = `<span style="background:rgba(26,47,34,0.06);color:var(--ash);border:1px solid rgba(26,47,34,0.12);padding:4px 12px;border-radius:99px;font-family:'DM Mono',monospace;font-size:9px;letter-spacing:0.14em;text-transform:uppercase;">Only ${p.stock} left</span>`;
            else { sb.innerHTML = `<span style="background:rgba(192,57,43,0.08);color:var(--warn);border:1px solid rgba(192,57,43,0.18);padding:4px 12px;border-radius:99px;font-family:'DM Mono',monospace;font-size:9px;letter-spacing:0.14em;text-transform:uppercase;">Sold Out</span>`; btn.disabled = true; btn.style.opacity = '0.4'; }

            const related = await fetchStore('products_by_category', { category_id: p.category_id });
            document.getElementById('related-grid').innerHTML = related.filter(r => r.id != p.id).slice(0, 4).map(productCard).join('');
            bindCards();
        }

        function changeQty(d) {
            if (!currentProduct) return;
            currentQty = Math.max(1, Math.min(currentProduct.stock, currentQty + d));
            document.getElementById('prod-qty').textContent = currentQty;
        }

        function addCurrentToCart() {
            if (!currentProduct) return;
            cart.add(currentProduct, currentQty);
            openCart();
        }

        async function renderCollections() {
            const [cats, prods] = await Promise.all([fetchStore('categories'), fetchStore('products')]);
            const imgs = [
                'https://images.unsplash.com/photo-1485955900006-10f4d324d411?w=600',
                'https://images.unsplash.com/photo-1565193566173-7a0ee3dbe261?w=600',
                'https://images.unsplash.com/photo-1608248543803-ba4f8c70ae0b?w=600',
                'https://images.unsplash.com/photo-1416879595882-3373a0480b5b?w=600'
            ];
            const cg = document.getElementById('collections-grid');
            cg.innerHTML = cats.map((c, i) => {
                const cnt = prods.filter(p => p.category_id === c.id).length;
                return `<div class="coll-card" style="cursor:pointer;" onclick="router.nav('shop',{cat:${c.id}})">
      <img class="coll-card-bg" src="${imgs[i] || imgs[0]}" alt="${c.name}">
      <div class="coll-card-over"><span>${cnt} items</span><h3>${c.name}</h3></div>
    </div>`;
            }).join('');
        }

        async function renderSale() {
            const [discounts, prods] = await Promise.all([fetchStore('discounts'), fetchStore('products')]);
            const maxPct = Math.max(...discounts.filter(d => d.active).map(d => d.percentage));
            const hl = document.getElementById('sale-headline');
            if (hl) hl.textContent = `UP TO ${maxPct}% OFF`;

            const sd = document.getElementById('sale-discounts');
            sd.innerHTML = discounts.filter(d => d.active).map(d => `
    <div class="disc-card">
      <div><div class="font-mono" style="font-size:9px;letter-spacing:0.18em;text-transform:uppercase;color:var(--ash);margin-bottom:5px;">Discount Code</div><div class="disc-code">${d.code}</div></div>
      <div style="text-align:right;">
        <div class="disc-pct">${d.percentage}%<br><span style="font-size:16px;color:var(--ash);">OFF</span></div>
        <button onclick="copyCode('${d.code}')" class="btn btn-sage" style="padding:5px 14px;font-size:10px;margin-top:6px;">Copy</button>
      </div>
    </div>`).join('');

            document.getElementById('sale-products').innerHTML = prods.map(productCard).join('');
            bindCards();
        }

        function copyCode(code) {
            navigator.clipboard.writeText(code).then(() => showToast(`"${code}" copied!`));
        }

        function renderCartPage() {
            const el = document.getElementById('cart-page-items');
            const disc = cart.appliedDiscount;
            if (!cart.items.length) {
                el.innerHTML = `<div style="text-align:center;padding:80px 0;">
      <div style="font-family:'Playfair Display',serif;font-size:64px;color:rgba(26,47,34,0.1);margin-bottom:14px;font-style:italic;">empty.</div>
      <h2 style="font-family:'Playfair Display',serif;font-size:28px;color:var(--forest);margin-bottom:14px;">Nothing in your cart yet</h2>
      <a href="#shop" class="btn btn-dark">Shop Botanicals</a>
    </div>`;
                document.getElementById('cart-sub').textContent = fmt(0);
                document.getElementById('cart-total').textContent = fmt(0);
                return;
            }
            el.innerHTML = cart.items.map(item => `
    <div style="display:flex;gap:18px;padding:20px 0;border-bottom:1px solid rgba(26,47,34,0.07);align-items:center;">
      <div style="width:80px;height:100px;border-radius:12px;background:var(--sage);flex-shrink:0;overflow:hidden;">
        ${item.image ? `<img src="${item.image}" style="width:100%;height:100%;object-fit:cover;">` : ''}
      </div>
      <div style="flex:1;min-width:0;">
        <p class="font-mono" style="font-size:9px;letter-spacing:0.16em;text-transform:uppercase;color:var(--muted);margin-bottom:3px;">${MOCK.categories.find(c => c.id === item.category_id)?.name || ''}</p>
        <h4 class="font-serif" style="font-size:17px;color:var(--forest);margin-bottom:8px;">${item.name}</h4>
        <div class="qty-row">
          <button class="qty-btn" onclick="cartUpd(${item.id},${item.qty - 1})">−</button>
          <span class="qty-num">${item.qty}</span>
