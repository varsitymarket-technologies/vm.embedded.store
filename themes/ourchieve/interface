    <!-- Cart Drawer -->
    <div id="cart-overlay" class="fixed inset-0 z-[70] hidden">
        <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="toggleCart()"></div>
        <div id="cart-drawer" class="absolute top-0 right-0 w-full max-w-md h-full bg-dark-800 border-l border-white/5 slide-in flex flex-col">
            <!-- Cart Header -->
            <div class="flex items-center justify-between p-6 border-b border-white/5">
                <h2 class="text-lg font-bold text-white flex items-center gap-2">
