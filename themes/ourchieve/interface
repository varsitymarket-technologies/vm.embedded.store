
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ourchieve - Premium Lifestyle Store</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        dark: { 900: '#0A0A0C', 800: '#121214', 700: '#1A1A1E', 600: '#222226', 500: '#2A2A2E' },
                        accent: { DEFAULT: '#00FF88', dark: '#00CC6A', light: '#33FF9F' }
                    },
                    fontFamily: {
                        sans: ['Inter', 'system-ui', '-apple-system', 'sans-serif']
                    }
                }
            }
        }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; background: #0A0A0C; color: #fff; }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #0A0A0C; }
        ::-webkit-scrollbar-thumb { background: #2A2A2E; border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: #00FF88; }

        .glass { background: rgba(18,18,20,0.8); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); }
        .glow-border { border: 1px solid rgba(0,255,136,0.1); }
        .glow-border:hover { border-color: rgba(0,255,136,0.4); box-shadow: 0 0 20px rgba(0,255,136,0.05); }
        .card-shine { position: relative; overflow: hidden; }
        .card-shine::before { content: ''; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%; background: radial-gradient(circle, rgba(0,255,136,0.03) 0%, transparent 70%); opacity: 0; transition: opacity 0.5s; pointer-events: none; z-index: 1; }
        .card-shine:hover::before { opacity: 1; }

        .slide-in { transform: translateX(100%); transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
        .slide-in.open { transform: translateX(0); }

        .fade-in { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }
        .fade-in.visible { opacity: 1; transform: translateY(0); }

        .modal-overlay { opacity: 0; pointer-events: none; transition: opacity 0.3s ease; }
        .modal-overlay.active { opacity: 1; pointer-events: all; }
        .modal-content { transform: scale(0.95) translateY(10px); transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1); }
        .modal-overlay.active .modal-content { transform: scale(1) translateY(0); }

        .qty-btn { transition: all 0.15s ease; }
        .qty-btn:active { transform: scale(0.9); }

        .hero-gradient { background: radial-gradient(ellipse at 30% 50%, rgba(0,255,136,0.08) 0%, transparent 60%), radial-gradient(ellipse at 70% 20%, rgba(0,100,255,0.05) 0%, transparent 50%); }

        .text-gradient { background: linear-gradient(135deg, #fff 0%, #00FF88 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

        .btn-primary { background: #00FF88; color: #0A0A0C; font-weight: 700; transition: all 0.3s ease; }
        .btn-primary:hover { background: #33FF9F; box-shadow: 0 0 30px rgba(0,255,136,0.3); transform: translateY(-1px); }

        .btn-outline { border: 1px solid rgba(255,255,255,0.2); color: #fff; transition: all 0.3s ease; }
        .btn-outline:hover { border-color: #00FF88; color: #00FF88; }

        .product-img { transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
        .product-card:hover .product-img { transform: scale(1.05); }

        .checkout-view { display: none; }
        .checkout-view.active { display: block; }
        .main-view.hidden { display: none; }

        @keyframes pulse-glow { 0%, 100% { box-shadow: 0 0 0 0 rgba(0,255,136,0.4); } 50% { box-shadow: 0 0 0 8px rgba(0,255,136,0); } }
        .cart-pulse { animation: pulse-glow 2s infinite; }

        .announcement-slide { animation: slide-text 20s linear infinite; }
        @keyframes slide-text { 0% { transform: translateX(100%); } 100% { transform: translateX(-100%); } }
    </style>
</head>
<body class="antialiased">

    <!-- Announcement Bar -->
    <div class="bg-accent text-dark-900 text-xs font-semibold py-2 overflow-hidden">
