    <!-- Product Modal -->
    <div id="product-modal" class="modal-overlay fixed inset-0 z-[80] flex items-center justify-center p-4">
        <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" onclick="closeModal()"></div>
        <div class="modal-content relative bg-dark-800 rounded-2xl border border-white/5 max-w-3xl w-full max-h-[90vh] overflow-y-auto">
            <button onclick="closeModal()" class="absolute top-4 right-4 z-10 p-2 bg-dark-700 rounded-full text-gray-400 hover:text-white transition-colors">
                <i class="fa-solid fa-xmark"></i>
            </button>
            <div class="grid grid-cols-1 md:grid-cols-2">
                <div class="bg-dark-700 p-8 flex items-center justify-center rounded-t-2xl md:rounded-l-2xl md:rounded-tr-none">
                    <img id="modal-image" src="" alt="" class="w-full max-h-80 object-contain">
