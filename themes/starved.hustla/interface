    <template id="tpl-account">
        <div class="max-w-4xl mx-auto px-6 py-32 min-h-[60vh]">
            <p class="text-[10px] uppercase tracking-widest opacity-50 mb-2">Account</p>
            <h2 class="text-3xl font-light tracking-tighter mb-12 uppercase">Welcome, <span class="js-acc-name">Friend</span></h2>
            <p class="text-xs uppercase tracking-widest opacity-60 mb-12 js-acc-email"></p>

            <p class="text-[10px] uppercase tracking-widest opacity-50 mb-4">Order History</p>
            <div class="js-orders-list space-y-2 mb-12 border-t border-black/10 pt-4"></div>

            <button class="text-[10px] uppercase border-b border-red-500 text-red-500 pb-1 js-logout">Sign Out</button>
        </div>
    </template>
    
    <template id="tpl-static">
        <div class="max-w-3xl mx-auto px-6 py-32 text-center min-h-[60vh]">
            <h1 class="text-4xl md:text-6xl font-light tracking-tighter mb-10 uppercase js-static-title"></h1>
            <p class="text-sm leading-loose uppercase tracking-widest opacity-70 js-static-content"></p>
        </div>
    </template>


    <script>
        // --- 1. MOCK DATABASE ---
        const DB = {
            currency: 'e(__SYSTEM_CURRENCY__)',
            categories: ['All', 'Seating', 'Lighting', 'Glassware', 'Objects'],
            products: [
                { id: 1, title: 'Osmosis Chair', price: 450, category: 'Seating', img: 'SEATING', desc: 'Handcrafted from sustainably sourced solid oak. Features a seamless joint design.' },
                { id: 2, title: 'Glass Decanter', price: 85, category: 'Glassware', img: 'GLASS', desc: 'Hand-blown minimalist 750ml vessel.' },
                { id: 3, title: 'Monolithic Table', price: 1200, category: 'Objects', img: 'TABLE', desc: 'Matte black steel frame with a cast concrete top.' },
                { id: 4, title: 'Brutalist Lamp', price: 320, category: 'Lighting', img: 'LAMP', desc: 'Cast concrete base with warm industrial filament glow.' },
                { id: 5, title: 'Steel Bookend', price: 65, category: 'Objects', img: 'STEEL', desc: 'Raw hot-rolled steel, sold individually.' },
                { id: 6, title: 'Lounge Seat', price: 850, category: 'Seating', img: 'SEATING', desc: 'Low profile boucle fabric on a hidden wooden frame.' }
            ]
        };

        // --- 2. CORE APPLICATION CLASS ---
        class StoreEngine {
            constructor() {
                this.root = document.getElementById('app-root');
                this.cart = JSON.parse(localStorage.getItem('shf_cart')) || [];
                // Legacy mock-auth cleanup (pre-D.3.2 port).
                try { localStorage.removeItem('shf_auth'); } catch {}
                this.auth = {
                    user: (() => { try { return JSON.parse(localStorage.getItem('vm_customer_cache') || 'null'); } catch { return null; } })(),
                    token: localStorage.getItem('vm_customer_token')
                };
                this.bootCustomer();
                
                this.initLayout();
                this.initRouter();
                this.updateCartCount();
            }

            // --- LAYOUT & GLOBALS ---
            isLoggedIn() { return !!(this.auth && this.auth.user); }

            async bootCustomer() {
                if (!this.auth.token) {
                    document.dispatchEvent(new CustomEvent('vm:customer-logout'));
                    return;
                }
                try {
                    const res = await fetch(new URL("api.php?state=customer_me", window.location.href), {
                        headers: { 'X-Customer-Token': this.auth.token },
                        signal: AbortSignal.timeout(4000)
                    });
                    if (res.status === 401) {
                        localStorage.removeItem('vm_customer_token');
                        localStorage.removeItem('vm_customer_cache');
                        this.auth.user = null;
                        this.auth.token = null;
                        document.dispatchEvent(new CustomEvent('vm:customer-logout'));
                        const cur = (window.location.hash || '').slice(1).split('/')[0];
                        if (cur === 'account' || cur === 'auth') this.route();
                        return;
                    }
                    if (!res.ok) throw new Error('boot failed: ' + res.status);
                    const data = await res.json();
                    if (data && data.ok && data.customer) {
                        this.auth.user = data.customer;
                        localStorage.setItem('vm_customer_cache', JSON.stringify(data.customer));
                        document.dispatchEvent(new CustomEvent('vm:customer-login', { detail: data.customer }));
                    }
                } catch (e) { /* network failure */ }
            }

            async login(email, password) {
                const result = await postStore('customer_login', { email, password });
                if (result.ok && result.data.token && result.data.customer) {
                    this.auth.token = result.data.token;
                    this.auth.user = result.data.customer;
                    localStorage.setItem('vm_customer_token', result.data.token);
                    localStorage.setItem('vm_customer_cache', JSON.stringify(result.data.customer));
                    document.dispatchEvent(new CustomEvent('vm:customer-login', { detail: result.data.customer }));
                    return { ok: true };
                }
                return { ok: false, error: result.error || 'Sign-in failed' };
            }

            async register(email, password, name) {
                const result = await postStore('customer_register', { email, password, name });
                if (result.ok && result.data.token && result.data.customer) {
                    this.auth.token = result.data.token;
                    this.auth.user = result.data.customer;
                    localStorage.setItem('vm_customer_token', result.data.token);
                    localStorage.setItem('vm_customer_cache', JSON.stringify(result.data.customer));
                    document.dispatchEvent(new CustomEvent('vm:customer-login', { detail: result.data.customer }));
                    return { ok: true };
                }
                return { ok: false, error: result.error || 'Could not create account' };
            }

            async logout() {
                try { await postStore('customer_logout', {}); } catch {}
                this.auth.token = null;
                this.auth.user = null;
                localStorage.removeItem('vm_customer_token');
                localStorage.removeItem('vm_customer_cache');
                document.dispatchEvent(new CustomEvent('vm:customer-logout'));
            }

            initLayout() {
                const mobBtn = document.getElementById('mobile-menu-btn');
                const mobMenu = document.getElementById('mobile-menu');
                const mobClose = document.getElementById('mobile-close-btn');
                
                const toggle = () => mobMenu.classList.toggle('hidden');
                
                mobBtn.onclick = toggle;
                mobClose.onclick = toggle;
                document.querySelectorAll('.js-mobile-link').forEach(link => link.onclick = toggle);
            }

            showToast(msg) {
                const container = document.getElementById('toast-container');
                const toast = document.createElement('div');
                toast.className = 'bg-black text-white px-6 py-4 text-[10px] uppercase tracking-widest shadow-xl transition-all duration-300 transform translate-y-10 opacity-0';
                toast.textContent = msg;
                container.appendChild(toast);
                
                requestAnimationFrame(() => toast.classList.remove('translate-y-10', 'opacity-0'));
                setTimeout(() => {
                    toast.classList.add('translate-y-10', 'opacity-0');
                    setTimeout(() => toast.remove(), 300);
                }, 2500);
            }

            // --- ROUTER LOGIC ---
            initRouter() {
                window.addEventListener('hashchange', () => this.route());
                this.route(); // Trigger on load
            }

            route() {
                const hash = window.location.hash.slice(1) || 'home';
                const parts = hash.split('/');
                const view = parts[0];
                const id = parts[1];

                this.root.classList.remove('fade-enter');
                void this.root.offsetWidth; // Trigger reflow
                this.root.classList.add('fade-enter');
                window.scrollTo(0, 0);

                // Routing Switchboard
                switch(view) {
                    case 'shop': this.renderShop(id); break; // id is category if present
                    case 'product': this.renderProduct(id); break;
                    case 'cart': this.renderCart(); break;
                    case 'checkout': this.renderCheckout(); break;
                    case 'success': this.renderSuccess(); break;
                    case 'auth': this.isLoggedIn() ? this.renderAccount() : this.renderTemplate('tpl-auth', this.bindAuth); break;
                    case 'account': this.isLoggedIn() ? this.renderAccount() : window.location.hash = 'auth'; break;
                    case 'search': this.renderSearch(); break;
                    case 'about': this.renderStatic('Our Ethos', 'We believe in the reduction of noise. Everything you need. Nothing you do not.'); break;
                    case 'contact': this.renderStatic('Inquiries', 'Contact us at strictly@starved.family for bespoke orders.'); break;
                    default: this.renderTemplate('tpl-home'); break;
                }
            }

            renderTemplate(templateId, callback = null) {
                const tpl = document.getElementById(templateId);
                if (!tpl) return;
                this.root.innerHTML = '';
                this.root.appendChild(tpl.content.cloneNode(true));
                if (callback) callback.call(this, this.root);
            }

            // --- VIEW CONTROLLERS ---

            renderShop(activeCategory = 'All') {
                activeCategory = decodeURI(activeCategory);
                this.renderTemplate('tpl-shop', (view) => {
                    const list = view.querySelector('.js-category-list');
                    const grid = view.querySelector('.js-product-grid');
                    const catTpl = document.getElementById('tpl-category-item');
                    const prodTpl = document.getElementById('tpl-product-card');

                    // 1. Build Categories Sidebar
                    DB.categories.forEach(cat => {
                        const li = catTpl.content.cloneNode(true);
                        const link = li.querySelector('.js-cat-link');
                        link.textContent = cat;
                        if(cat === activeCategory) link.classList.add('font-bold', 'text-black', 'opacity-100');
                        link.onclick = () => window.location.hash = `shop/${cat}`;
                        list.appendChild(li);
                    });

                    // 2. Filter & Render Products
                    const filtered = activeCategory === 'All' ? DB.products : DB.products.filter(p => p.category === activeCategory);
                    view.querySelector('.js-collection-title').textContent = activeCategory === 'All' ? 'All Objects' : activeCategory;
                    view.querySelector('.js-collection-count').textContent = `${filtered.length} Items`;

                    filtered.forEach(p => {
                        const card = prodTpl.content.cloneNode(true);
                        card.querySelector('.js-prod-link').href = `#product/${p.id}`;
                        card.querySelector('.js-title').textContent = p.title;
                        card.querySelector('.js-price').textContent = `${DB.currency}${p.price}`;
                        card.querySelector('.js-img-placeholder').textContent = p.img;
                        grid.appendChild(card);
                    });
                });
            }

            renderProduct(id) {
                const product = DB.products.find(p => p.id == id);
                if (!product) return window.location.hash = 'shop';

                this.renderTemplate('tpl-product', (view) => {
                    view.querySelector('.js-detail-title').textContent = product.title;
                    view.querySelector('.js-detail-price').textContent = `${DB.currency}${product.price}`;
                    view.querySelector('.js-detail-cat').textContent = product.category;
                    view.querySelector('.js-detail-desc').textContent = product.desc;
                    view.querySelector('.js-detail-img').textContent = product.img;

                    view.querySelector('.js-add-btn').onclick = () => {
                        this.cartAdd(product);
                        this.showToast(`Added ${product.title}`);
                    };
                });
            }

            renderCart() {
                if (this.cart.length === 0) {
                    this.renderTemplate('tpl-cart-empty', (emptyView) => {
                        this.renderTemplate('tpl-cart', (mainView) => {
                            mainView.querySelector('.js-cart-container').appendChild(emptyView);
                        });
                    });
                    return;
                }

                this.renderTemplate('tpl-cart', (mainView) => {
                    const container = mainView.querySelector('.js-cart-container');
                    const layoutTpl = document.getElementById('tpl-cart-layout').content.cloneNode(true);
                    const listContainer = layoutTpl.querySelector('.js-cart-items');
                    const itemTpl = document.getElementById('tpl-cart-item');
                    
                    let total = 0;

                    this.cart.forEach((item, index) => {
                        total += (item.price * item.qty);
                        const row = itemTpl.content.cloneNode(true);
                        
                        row.querySelector('.js-item-title').textContent = item.title;
                        row.querySelector('.js-item-price').textContent = `${DB.currency}${item.price}`;
                        row.querySelector('.js-item-qty').textContent = item.qty;
                        row.querySelector('.js-item-img').textContent = item.img;

                        // Cart Actions
                        row.querySelector('.js-qty-add').onclick = () => this.cartUpdate(index, 1);
                        row.querySelector('.js-qty-sub').onclick = () => this.cartUpdate(index, -1);
                        row.querySelector('.js-item-remove').onclick = () => {
                            this.cart.splice(index, 1);
                            this.cartSave();
                            this.renderCart();
                        };

                        listContainer.appendChild(row);
                    });

                    layoutTpl.querySelector('.js-cart-subtotal').textContent = `${DB.currency}${total.toFixed(2)}`;
                    layoutTpl.querySelector('.js-cart-total').textContent = `${DB.currency}${total.toFixed(2)}`;
                    container.appendChild(layoutTpl);
                });
            }

            renderCheckout() {
                if(this.cart.length === 0) return window.location.hash = 'cart';
                this.renderTemplate('tpl-checkout', (view) => {
                    view.querySelector('.js-checkout-form').onsubmit = (e) => {
                        e.preventDefault();
                        this.cart = []; // Clear Cart
                        this.cartSave();
                        window.location.hash = 'success';
                    };
                });
            }

            renderSearch() {
                this.renderTemplate('tpl-search', (view) => {
                    const input = view.querySelector('.js-search-input');
                    const results = view.querySelector('.js-search-results');
                    const prodTpl = document.getElementById('tpl-product-card');

                    input.oninput = (e) => {
                        const query = e.target.value.toLowerCase();
                        results.innerHTML = '';
                        if(query.length < 2) return;

                        const hits = DB.products.filter(p => p.title.toLowerCase().includes(query) || p.category.toLowerCase().includes(query));
                        hits.forEach(p => {
                            const card = prodTpl.content.cloneNode(true);
                            card.querySelector('.js-prod-link').href = `#product/${p.id}`;
                            card.querySelector('.js-title').textContent = p.title;
                            card.querySelector('.js-price').textContent = `${DB.currency}${p.price}`;
                            card.querySelector('.js-img-placeholder').textContent = p.img;
                            results.appendChild(card);
                        });
                    };
                });
            }

            renderAccount() {
                this.renderTemplate('tpl-account', async (view) => {
                    const u = this.auth.user || {};
                    const nameEl = view.querySelector('.js-acc-name');
                    const emailEl = view.querySelector('.js-acc-email');
                    if (nameEl) nameEl.textContent = u.name || 'Friend';
                    if (emailEl) emailEl.textContent = u.email || '';

                    const ordersEl = view.querySelector('.js-orders-list');
                    if (ordersEl) {
                        ordersEl.innerHTML = '<p class="text-xs uppercase tracking-widest opacity-50 py-4 text-center">Loading…</p>';
                        let orders = [];
                        try { orders = await fetchStore('customer_my_orders'); } catch { orders = []; }
                        if (!Array.isArray(orders)) orders = [];
                        if (orders.length === 0) {
                            ordersEl.innerHTML = '<p class="text-xs uppercase tracking-widest opacity-50 py-4 text-center">No orders yet.</p>';
                        } else {
                            ordersEl.innerHTML = orders.slice(0, 5).map(o => {
                                const id = o.id || '?';
                                const total = o.total_amount != null ? o.total_amount : (o.total || '?');
                                const status = (o.status || 'pending').toString();
                                const date = (o.created_at || '').toString().substring(0, 10);
                                return '<div class="flex justify-between items-center py-3 border-b border-black/5 text-xs uppercase tracking-widest">' +
                                          '<span class="opacity-60">#' + String(id).padStart(4, '0') + '</span>' +
                                          '<span class="opacity-60">' + date + '</span>' +
                                          '<span>' + total + '</span>' +
                                          '<span class="font-bold">' + status + '</span>' +
                                       '</div>';
                            }).join('');
                        }
                    }

                    view.querySelector('.js-logout').onclick = async () => {
                        await this.logout();
                        this.showToast("Signed Out");
                        window.location.hash = 'home';
                    };
                });
            }

            renderSuccess() { this.renderTemplate('tpl-success'); }
            
            renderStatic(title, content) {
                this.renderTemplate('tpl-static', (view) => {
                    view.querySelector('.js-static-title').textContent = title;
                    view.querySelector('.js-static-content').textContent = content;
                });
            }

            bindAuth(view) {
                const showSection = (which) => {
                    view.querySelector('.acc-login').classList.toggle('hidden', which !== 'login');
                    view.querySelector('.acc-register').classList.toggle('hidden', which !== 'register');
                };
                const setError = (which, msg) => {
                    const el = view.querySelector('[data-err="' + which + '"]');
                    if (!el) return;
                    if (msg) { el.textContent = msg; el.classList.remove('hidden'); }
                    else { el.textContent = ''; el.classList.add('hidden'); }
                };

                view.querySelectorAll('[data-action="show-register"]').forEach(el => {
                    el.addEventListener('click', (e) => { e.preventDefault(); setError('login', ''); showSection('register'); });
                });
                view.querySelectorAll('[data-action="show-login"]').forEach(el => {
                    el.addEventListener('click', (e) => { e.preventDefault(); setError('register', ''); showSection('login'); });
                });

                const loginForm = view.querySelector('[data-form="login"]');
                if (loginForm) {
                    loginForm.addEventListener('submit', async (e) => {
                        e.preventDefault();
                        setError('login', '');
                        const fd = new FormData(loginForm);
                        const result = await this.login(fd.get('email'), fd.get('password'));
                        if (result.ok) {
                            window.location.hash = 'account';
                            this.showToast("Authentication Successful");
                        } else {
                            setError('login', result.error);
                        }
                    });
                }

                const registerForm = view.querySelector('[data-form="register"]');
                if (registerForm) {
                    registerForm.addEventListener('submit', async (e) => {
                        e.preventDefault();
                        setError('register', '');
                        const fd = new FormData(registerForm);
                        const result = await this.register(fd.get('email'), fd.get('password'), fd.get('name'));
                        if (result.ok) {
                            window.location.hash = 'account';
                            this.showToast("Account Created");
                        } else {
                            setError('register', result.error);
                        }
                    });
                }
            }

            // Legacy stub kept for clarity but not used after port:
            _legacyBindAuth(view) {
                view.querySelector('.js-auth-form').onsubmit = (e) => {
                    e.preventDefault();
                    window.location.hash = 'account';
                    this.showToast("Authentication Successful");
                };
            }

            // --- CART DATA MUTATIONS ---
            cartAdd(product) {
                const existing = this.cart.find(item => item.id === product.id);
                if (existing) {
                    existing.qty += 1;
                } else {
                    this.cart.push({ ...product, qty: 1 });
                }
                this.cartSave();
            }

            cartUpdate(index, amount) {
                this.cart[index].qty += amount;
                if (this.cart[index].qty <= 0) this.cart.splice(index, 1);
                this.cartSave();
                this.renderCart(); // Re-render instantly
            }

            cartSave() {
                localStorage.setItem('shf_cart', JSON.stringify(this.cart));
                this.updateCartCount();
            }

            updateCartCount() {
                const count = this.cart.reduce((sum, item) => sum + item.qty, 0);
                document.querySelectorAll('.js-cart-count').forEach(el => el.textContent = count);
            }
        }

        // --- 3. BOOTSTRAP ---
        /* ════════════════════
           CANONICAL DATA LAYER — fetchStore → api.php?state=X, getMockData fallback, MOCK shape
        ════════════════════ */
        const __CATS = [...new Set(DB.products.map(p => p.category).filter(Boolean))].map((name, i) => ({ id: i + 1, name }));
        const MOCK = {
            site: { name: "STARVED HUSTLA", currency: DB.currency || "R", domain: window.location.hostname },
            categories: __CATS,
            products: DB.products.map((p, i) => ({
                ...p,
                id: p.id != null ? p.id : i + 1,
                name: p.name || p.title || "",
                image: p.image || p.img || "",
                description: p.description || p.desc || "",
                stock: p.stock != null ? p.stock : 12,
                category_id: (__CATS.find(c => c.name === p.category) || {}).id || null
            })),
            discounts: [
                { id: 1, code: "WELCOME10", percentage: 10, active: 1 },
                { id: 2, code: "DROP20", percentage: 20, active: 1 }
            ]
        };
        async function fetchStore(state, params = {}) {
            const url = new URL("api.php", window.location.href);
            url.searchParams.set("state", state);
            for (const [k, v] of Object.entries(params)) url.searchParams.set(k, v);
            const headers = {};
            const token = localStorage.getItem('vm_customer_token');
            if (token) headers['X-Customer-Token'] = token;
            try {
                const res = await fetch(url, { signal: AbortSignal.timeout(4000), headers });
                if (!res.ok) throw new Error(res.status);
                return await res.json();
            } catch {
                return getMockData(state, params);
            }
        }

        async function postStore(state, body = {}) {
            const url = new URL("api.php", window.location.href);
            url.searchParams.set("state", state);
            const headers = { 'Content-Type': 'application/json' };
            const token = localStorage.getItem('vm_customer_token');
            if (token) headers['X-Customer-Token'] = token;
            try {
                const res = await fetch(url, {
                    method: 'POST',
                    headers,
                    body: JSON.stringify(body),
                    signal: AbortSignal.timeout(8000)
                });
                const data = await res.json().catch(() => ({}));
                return { ok: res.ok && (data.ok !== false), status: res.status, data, error: data.error || null };
            } catch (e) {
                return { ok: false, status: 0, data: {}, error: e.message };
            }
        }
        function getMockData(state, params = {}) {
            switch (state) {
                case "site": return MOCK.site;
                case "products": return MOCK.products;
                case "product": return MOCK.products.find(p => p.id == params.id) || null;
                case "categories": return MOCK.categories;
                case "products_by_category": return MOCK.products.filter(p => p.category_id == params.category_id);
                case "search": {
                    const q = (params.q || "").toLowerCase();
                    return MOCK.products.filter(p => (p.name || "").toLowerCase().includes(q) || (p.description || "").toLowerCase().includes(q));
                }
                case "discounts": return MOCK.discounts;
                case "orders": return [];
                default: return [];
            }
        }

        document.addEventListener('DOMContentLoaded', async () => {
            try { const __d = await fetchStore('products'); DB.products = __d.map(p => ({ ...p, title: p.title || p.name || '', img: p.img || p.image || '', desc: p.desc || p.description || '', category: p.category || ((MOCK.categories.find(c => c.id == p.category_id) || {}).name) || '' })); } catch {}
            window.App = new StoreEngine();
        });
    </script>
</body>
