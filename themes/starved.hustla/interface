    <template id="tpl-auth">
        <div class="max-w-md mx-auto px-6 py-32 min-h-[60vh]">
            <h2 class="text-3xl font-light tracking-tighter mb-12 uppercase text-center">Account</h2>

            <div class="acc-login space-y-8">
                <form data-form="login" class="space-y-6">
                    <input type="email" name="email" placeholder="EMAIL" required class="w-full border-b border-black/20 py-4 text-xs uppercase focus:outline-none focus:border-black">
                    <input type="password" name="password" placeholder="PASSWORD" required class="w-full border-b border-black/20 py-4 text-xs uppercase focus:outline-none focus:border-black">
