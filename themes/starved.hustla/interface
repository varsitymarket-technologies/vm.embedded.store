            <p class="text-xs uppercase tracking-widest opacity-60 mb-12">Your objects are being prepared.</p>
            <a href="#shop" class="bg-black text-white px-10 py-4 text-[10px] uppercase tracking-[0.3em]">Return Home</a>
        </div>
