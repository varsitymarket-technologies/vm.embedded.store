                    No account? <a href="#" data-action="show-register" class="border-b border-black pb-0.5">Create one</a>
                </p>
            </div>

            <div class="acc-register hidden space-y-8">
                <form data-form="register" class="space-y-6">
                    <input type="text" name="name" placeholder="NAME" class="w-full border-b border-black/20 py-4 text-xs uppercase focus:outline-none focus:border-black">
                    <input type="email" name="email" placeholder="EMAIL" required class="w-full border-b border-black/20 py-4 text-xs uppercase focus:outline-none focus:border-black">
                    <input type="password" name="password" placeholder="PASSWORD (8+)" required minlength="8" class="w-full border-b border-black/20 py-4 text-xs uppercase focus:outline-none focus:border-black">
                    <button type="submit" class="w-full bg-black text-white py-5 text-xs uppercase tracking-[0.3em]">Create Account</button>
                    <p data-err="register" class="hidden text-[10px] uppercase tracking-widest text-red-500"></p>
