<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IMARA | Modern Heritage</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Prata&family=Plus+Jakarta+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-warm: #FAF6F0;
            --text-dark: #2C221E;
            --text-muted: #7A6E67;
            --brand-ochre: #D49B41;
            --brand-terracotta: #B95C38;
            --border-soft: #EAE3D8;
        }
        
        body { 
            font-family: 'Plus Jakarta Sans', sans-serif; 
            background-color: var(--bg-warm); 
            color: var(--text-dark); 
            -webkit-font-smoothing: antialiased;
        }
        .font-serif { font-family: 'Prata', serif; }
        
        .view-section { display: none; }
        .view-section.active { display: block; animation: warmFade 0.6s cubic-bezier(0.215, 0.610, 0.355, 1) forwards; }
        
        @keyframes warmFade {
            from { opacity: 0; transform: translateY(8px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Earthy Premium Inputs */
        .imara-input { 
            border: 1px solid var(--border-soft); 
            background-color: #FFFFFF;
            color: var(--text-dark);
            border-radius: 2px;
            padding: 14px;
            font-size: 14px;
            transition: all 0.3s ease;
        }
        .imara-input:focus { 
            outline: none; 
            border-color: var(--brand-terracotta);
            box-shadow: 0 0 0 1px var(--brand-terracotta);
        }
        
        /* Artisan Buttons */
        .btn-terracotta {
            background-color: var(--brand-terracotta);
            color: #FFFFFF;
            font-weight: 500;
            letter-spacing: 0.05em;
            transition: all 0.3s ease;
        }
        .btn-terracotta:hover {
            background-color: #9C4B2C;
        }

        .btn-outline {
            border: 1px solid var(--text-dark);
            background-color: transparent;
            color: var(--text-dark);
            transition: all 0.3s ease;
        }
        .btn-outline:hover {
            background-color: var(--text-dark);
            color: var(--bg-warm);
        }

        /* Delicate Custom Scrollbar */
        ::-webkit-scrollbar { width: 5px; }
        ::-webkit-scrollbar-track { background: var(--bg-warm); }
        ::-webkit-scrollbar-thumb { background: var(--border-soft); }
        ::-webkit-scrollbar-thumb:hover { background: var(--text-muted); }
    </style>

    <!-- D.3.x: customer auth helper (vm-customer.js from same dir as api.php) -->
    <script src="vm-customer.js" defer></script>
    <script>
        window.addEventListener('vm:customer-loaded', function () {
            document.body.dataset.customer = 'logged-in';
            if (window.app && app.auth && typeof app.auth.updateIcon === 'function') app.auth.updateIcon();
        });
        window.addEventListener('vm:customer-login', function () {
            document.body.dataset.customer = 'logged-in';
            if (window.app && app.auth && typeof app.auth.updateIcon === 'function') app.auth.updateIcon();
        });
        window.addEventListener('vm:customer-logout', function () {
            document.body.dataset.customer = 'logged-out';
            if (window.app && app.auth && typeof app.auth.updateIcon === 'function') app.auth.updateIcon();
        });
    </script>
</head>
<body class="min-h-screen flex flex-col justify-between selection:bg-[#B95C38] selection:text-white">

    <div class="bg-[#2C221E] text-[#FAF6F0] text-center py-2.5 text-xs tracking-widest uppercase font-light px-4">
        Empowering Women-Led Artisan Collectives Across the Continent • Global Shipping Available
    </div>

    <header class="sticky top-0 bg-[var(--bg-warm)]/90 backdrop-blur-md z-40 border-b border-[var(--border-soft)]">
        <div class="max-w-7xl mx-auto px-6 h-24 flex items-center justify-between">
            
            <nav class="hidden md:flex items-center space-x-8 text-xs font-semibold tracking-widest uppercase">
                <a href="#shop" onclick="app.router.navigate('shop')" class="hover:text-[var(--brand-terracotta)] transition-colors">The Edit</a>
                <a href="#about" onclick="app.router.navigate('about')" class="hover:text-[var(--brand-terracotta)] transition-colors">Our Impact</a>
            </nav>

            <a href="#home" onclick="app.router.navigate('home')" class="text-center">
                <span class="font-serif text-3xl tracking-[0.2em] text-[var(--text-dark)] block">IMARA</span>
                <span class="text-[9px] tracking-[0.4em] uppercase text-[var(--brand-ochre)] block -mt-1 pl-1">Artisanal Luxury</span>
            </a>

            <div class="flex items-center space-x-6">
                <button class="hover:text-[var(--brand-terracotta)] transition-colors" onclick="app.ui.toggleSearchOverlay()" aria-label="Search">
                    <i data-lucide="search" class="w-5 h-5 stroke-[1.5]"></i>
                </button>
                <button id="auth-icon-btn" class="hover:text-[var(--brand-terracotta)] transition-colors flex items-center space-x-1" onclick="app.auth.iconClick()" aria-label="Account">
                    <span class="sr-only" id="auth-icon-label">Account</span>
                    <i data-lucide="user" class="w-5 h-5 stroke-[1.5]"></i>
                </button>
                <button class="hover:text-[var(--brand-terracotta)] transition-colors flex items-center space-x-1 relative" onclick="app.ui.toggleCartDrawer()" aria-label="Cart">
                    <i data-lucide="shopping-bag" class="w-5 h-5 stroke-[1.5]"></i>
                    <span id="global-cart-count" class="absolute -top-1 -right-2 text-[9px] bg-[var(--brand-terracotta)] text-white w-4.5 h-4.5 rounded-full flex items-center justify-center opacity-0 transition-opacity font-bold">0</span>
                </button>
            </div>
        </div>
    </header>

    <main class="flex-grow">

        <section id="view-home" class="view-section active">
            <div class="max-w-7xl mx-auto px-6 py-8">
                <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center bg-white rounded-sm overflow-hidden border border-[var(--border-soft)]">
                    <div class="lg:col-span-5 p-8 sm:p-12 lg:p-16 flex flex-col justify-center">
                        <span class="text-xs font-semibold tracking-[0.25em] uppercase text-[var(--brand-ochre)] mb-4 block">Sourced Safely, Crafted Beautifully</span>
                        <h1 class="font-serif text-4xl sm:text-6xl text-[var(--text-dark)] leading-[1.1] mb-6">Designed by Identity. remade by hand.</h1>
                        <p class="text-[var(--text-muted)] text-sm leading-relaxed mb-10 max-w-sm">A curation of high-end home, style, and wellness items created exclusively by exceptional female entrepreneurs and cooperatives across Africa.</p>
                        <button onclick="app.router.navigate('shop')" class="w-fit px-8 py-4 btn-terracotta text-xs uppercase tracking-widest">
                            Explore The Collection
                        </button>
                    </div>
                    <div class="lg:col-span-7 h-[65vh] min-h-[450px] relative">
                        <img src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?q=80&w=1600&auto=format&fit=crop" class="absolute inset-0 w-full h-full object-cover" alt="African Female Entrepreneur Portrait">
                        <div class="absolute inset-0 bg-[var(--brand-terracotta)]/10 mix-blend-multiply"></div>
                    </div>
                </div>
            </div>

            <div class="max-w-7xl mx-auto px-6 py-20 grid grid-cols-1 md:grid-cols-3 gap-12 border-b border-[var(--border-soft)]">
                <div class="flex flex-col items-center text-center px-4">
                    <div class="bg-white p-4 rounded-full border border-[var(--border-soft)] mb-6 text-[var(--brand-terracotta)]">
                        <i data-lucide="heart-handshake" class="w-6 h-6 stroke-[1.25]"></i>
                    </div>
                    <h3 class="font-serif text-xl mb-3 text-[var(--text-dark)]">100% Women-Owned</h3>
                    <p class="text-[var(--text-muted)] text-xs sm:text-sm leading-relaxed">Direct commercial partnerships that route capital straight to female founders and rural matriarchal trade collectives.</p>
                </div>
                <div class="flex flex-col items-center text-center px-4">
                    <div class="bg-white p-4 rounded-full border border-[var(--border-soft)] mb-6 text-[var(--brand-terracotta)]">
                        <i data-lucide="globe-2" class="w-6 h-6 stroke-[1.25]"></i>
                    </div>
                    <h3 class="font-serif text-xl mb-3 text-[var(--text-dark)]">Traceable Provenance</h3>
                    <p class="text-[var(--text-muted)] text-xs sm:text-sm leading-relaxed">Every individual artifact maps cleanly back to its region of origin—from hand-spun cotton in Addis Ababa to organic balms in Accra.</p>
                </div>
                <div class="flex flex-col items-center text-center px-4">
                    <div class="bg-white p-4 rounded-full border border-[var(--border-soft)] mb-6 text-[var(--brand-terracotta)]">
                        <i data-lucide="sparkles" class="w-6 h-6 stroke-[1.25]"></i>
                    </div>
                    <h3 class="font-serif text-xl mb-3 text-[var(--text-dark)]">Premium Quality</h3>
                    <p class="text-[var(--text-muted)] text-xs sm:text-sm leading-relaxed">We bypass mass commercial setups to supply highly durable, rare luxury configurations that last a lifetime.</p>
                </div>
            </div>
        </section>

        <section id="view-shop" class="view-section max-w-7xl mx-auto px-6 py-16">
            <div class="flex flex-col sm:flex-row justify-between items-baseline mb-12 border-b border-[var(--border-soft)] pb-6 gap-4">
                <div>
                    <h2 class="font-serif text-3xl sm:text-4xl text-[var(--text-dark)]">The Continental Catalog</h2>
                    <p class="text-xs text-[var(--text-muted)] mt-2">Filter and inspect signature products of structural brilliance.</p>
                </div>
                <div class="flex items-center space-x-3 text-sm">
                    <span class="text-xs uppercase tracking-widest text-[var(--text-muted)]">Arrange:</span>
                    <select id="catalog-sort" onchange="app.store.sortCatalog(this.value)" class="bg-transparent border-b border-[var(--border-soft)] text-xs uppercase tracking-wider text-[var(--text-dark)] focus:outline-none cursor-pointer pb-1">
                        <option value="featured">Curated List</option>
                        <option value="price-low">Price: Ascending</option>
                        <option value="price-high">Price: Descending</option>
                    </select>
                </div>
            </div>

            <div id="shop-items-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-14">
                </div>
        </section>

        <section id="view-product" class="view-section max-w-7xl mx-auto px-6 py-16">
            <div id="product-detail-target" class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20">
                </div>
        </section>

        <section id="view-about" class="view-section max-w-4xl mx-auto px-6 py-20 text-center">
            <span class="text-[var(--brand-terracotta)] text-xs tracking-[0.3em] uppercase mb-4 block font-semibold">Economic Ecosystems</span>
            <h2 class="font-serif text-4xl sm:text-5xl mb-8 text-[var(--text-dark)] leading-tight">Investing in the structural backbone of communities.</h2>
            <div class="space-y-6 text-[var(--text-muted)] text-base sm:text-lg font-light leading-relaxed text-left max-w-2xl mx-auto">
                <p>When you invest in an African businesswoman, you elevate an entire village matrix. Statistically, women across the African continent reinvest up to 90% of their earned income straight back into family nutrition, healthcare, and educational infrastructure.</p>
                <p><strong>IMARA</strong> behaves as a premium direct channel pipeline. By completely removing unnecessary brokerage networks, we protect the pricing leverage of our female founders, honoring their meticulous skill and heritage styles on a global stage.</p>
            </div>
            <div class="mt-12 grid grid-cols-2 sm:grid-cols-4 gap-4">
                <div class="bg-white p-6 border border-[var(--border-soft)] rounded-sm"><div class="font-serif text-2xl text-[var(--brand-terracotta)]">100%</div><div class="text-[10px] uppercase text-[var(--text-muted)] mt-1 tracking-wider">Female Led</div></div>
                <div class="bg-white p-6 border border-[var(--border-soft)] rounded-sm"><div class="font-serif text-2xl text-[var(--brand-terracotta)]">14</div><div class="text-[10px] uppercase text-[var(--text-muted)] mt-1 tracking-wider">Hub Communities</div></div>
                <div class="bg-white p-6 border border-[var(--border-soft)] rounded-sm"><div class="font-serif text-2xl text-[var(--brand-terracotta)]">$42k+</div><div class="text-[10px] uppercase text-[var(--text-muted)] mt-1 tracking-wider">Direct Payouts</div></div>
                <div class="bg-white p-6 border border-[var(--border-soft)] rounded-sm"><div class="font-serif text-2xl text-[var(--brand-terracotta)]">Zero</div><div class="text-[10px] uppercase text-[var(--text-muted)] mt-1 tracking-wider">Middlemen Markups</div></div>
            </div>
        </section>

        <!-- D.3.x: account view -->
        <section id="view-account" class="view-section max-w-5xl mx-auto px-6 py-16">
            <div class="flex items-center justify-between mb-12">
                <div>
                    <p class="text-[10px] uppercase tracking-[0.2em] text-[var(--brand-ochre)] font-semibold">Account</p>
                    <h1 id="acc-greeting" class="font-serif text-4xl text-[var(--text-dark)] mt-2">Welcome</h1>
                </div>
                <button onclick="app.auth.doLogout()" class="text-[10px] uppercase tracking-[0.2em] text-[var(--text-dark)]/60 hover:text-[var(--brand-terracotta)] font-semibold">Sign Out</button>
            </div>

            <div class="flex space-x-8 border-b border-[var(--border-soft)] mb-8">
                <button id="acc-tab-overview" onclick="app.auth.activateTab('overview')" class="acc-tab pb-3 text-[11px] uppercase tracking-[0.2em] font-semibold">Overview</button>
                <button id="acc-tab-profile"  onclick="app.auth.activateTab('profile')"  class="acc-tab pb-3 text-[11px] uppercase tracking-[0.2em] font-semibold">Profile</button>
                <button id="acc-tab-orders"   onclick="app.auth.activateTab('orders')"   class="acc-tab pb-3 text-[11px] uppercase tracking-[0.2em] font-semibold">Orders</button>
                <button id="acc-tab-password" onclick="app.auth.activateTab('password')" class="acc-tab pb-3 text-[11px] uppercase tracking-[0.2em] font-semibold">Password</button>
            </div>

            <div id="acc-panel-overview" class="acc-panel">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
                    <div><p class="text-[10px] uppercase tracking-[0.2em] text-[var(--text-dark)]/60">Name</p><p id="acc-ov-name" class="text-sm text-[var(--text-dark)] mt-2">—</p></div>
                    <div><p class="text-[10px] uppercase tracking-[0.2em] text-[var(--text-dark)]/60">Email</p><p id="acc-ov-email" class="text-sm text-[var(--text-dark)] mt-2">—</p></div>
                    <div><p class="text-[10px] uppercase tracking-[0.2em] text-[var(--text-dark)]/60">Member Since</p><p id="acc-ov-joined" class="text-sm text-[var(--text-dark)] mt-2">—</p></div>
                </div>
                <button onclick="app.auth.activateTab('profile')" class="text-[10px] uppercase tracking-[0.2em] text-[var(--text-dark)] border-b border-[var(--text-dark)] pb-0.5">Edit profile</button>
            </div>

            <div id="acc-panel-profile" class="acc-panel hidden">
                <form onsubmit="event.preventDefault(); app.auth.saveProfile()" class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div><label class="block text-[10px] uppercase tracking-[0.2em] text-[var(--text-dark)]/60 mb-2 font-semibold">First Name</label>
                             <input type="text" id="acc-fname" class="imara-input w-full"></div>
                        <div><label class="block text-[10px] uppercase tracking-[0.2em] text-[var(--text-dark)]/60 mb-2 font-semibold">Last Name</label>
                             <input type="text" id="acc-lname" class="imara-input w-full"></div>
                    </div>
                    <div><label class="block text-[10px] uppercase tracking-[0.2em] text-[var(--text-dark)]/60 mb-2 font-semibold">Email</label>
                         <input type="email" id="acc-email" readonly title="Email is the account identifier and cannot be changed here" class="imara-input w-full bg-[var(--bg-warm)] cursor-not-allowed"></div>
                    <div><label class="block text-[10px] uppercase tracking-[0.2em] text-[var(--text-dark)]/60 mb-2 font-semibold">Phone (optional)</label>
                         <input type="tel" id="acc-phone" class="imara-input w-full"></div>
                    <button type="submit" class="w-full bg-[var(--brand-terracotta)] text-white py-3 text-[11px] uppercase tracking-[0.2em] font-semibold hover:bg-[var(--brand-terracotta)]/90 transition-colors">Save</button>
                </form>
            </div>

            <div id="acc-panel-orders" class="acc-panel hidden">
                <div id="acc-orders-list">
                    <p class="text-[10px] uppercase tracking-[0.2em] text-[var(--text-dark)]/60 py-12 text-center">Loading…</p>
                </div>
            </div>

            <div id="acc-panel-password" class="acc-panel hidden">
                <form onsubmit="event.preventDefault(); app.auth.changePassword()" class="space-y-6">
                    <div><label class="block text-[10px] uppercase tracking-[0.2em] text-[var(--text-dark)]/60 mb-2 font-semibold">Current Password</label>
                         <input type="password" id="acc-pw-cur" required class="imara-input w-full"></div>
                    <div><label class="block text-[10px] uppercase tracking-[0.2em] text-[var(--text-dark)]/60 mb-2 font-semibold">New Password</label>
                         <input type="password" id="acc-pw-new" required minlength="8" class="imara-input w-full"></div>
                    <div><label class="block text-[10px] uppercase tracking-[0.2em] text-[var(--text-dark)]/60 mb-2 font-semibold">Confirm New Password</label>
                         <input type="password" id="acc-pw-conf" required minlength="8" class="imara-input w-full"></div>
                    <button type="submit" class="w-full bg-[var(--brand-terracotta)] text-white py-3 text-[11px] uppercase tracking-[0.2em] font-semibold hover:bg-[var(--brand-terracotta)]/90 transition-colors">Change Password</button>
                </form>
            </div>
        </section>

        <style>
            .acc-tab { color: rgba(44, 34, 30, 0.5); border-bottom: 1px solid transparent; transition: all 0.3s; }
            .acc-tab.active { color: var(--text-dark); border-bottom-color: var(--brand-terracotta); }
        </style>

        <!-- D.3.x: Auth modal overlay -->
        <div id="auth-modal" class="fixed inset-0 bg-[var(--bg-warm)] z-50 hidden flex-col items-center justify-start overflow-y-auto p-6">
            <div class="w-full max-w-md mx-auto pt-12 pb-24">
                <div class="flex items-center justify-between mb-12">
                    <span class="font-serif text-2xl tracking-[0.2em] text-[var(--text-dark)]">IMARA</span>
                    <button onclick="app.auth.close()" aria-label="Close" class="text-[var(--text-dark)]/60 hover:text-[var(--brand-terracotta)] transition-colors">
                        <i data-lucide="x" class="w-5 h-5"></i>
                    </button>
                </div>

                <div class="flex space-x-8 border-b border-[var(--border-soft)] mb-8">
                    <button id="auth-tab-login"    onclick="app.auth.switchTab('login')"    class="auth-tab pb-3 text-[11px] uppercase tracking-[0.2em] font-semibold">Sign In</button>
                    <button id="auth-tab-register" onclick="app.auth.switchTab('register')" class="auth-tab pb-3 text-[11px] uppercase tracking-[0.2em] font-semibold">Create</button>
                    <button id="auth-tab-forgot"   onclick="app.auth.switchTab('forgot')"   class="auth-tab pb-3 text-[11px] uppercase tracking-[0.2em] font-semibold">Forgot</button>
                </div>

                <div id="auth-panel-login" class="auth-panel">
                    <form onsubmit="event.preventDefault(); app.auth.submitLogin()" class="space-y-6">
                        <div>
                            <label class="block text-[10px] uppercase tracking-[0.2em] text-[var(--text-dark)]/60 mb-2 font-semibold">Email</label>
                            <input type="email" id="auth-login-email" required class="imara-input w-full">
                        </div>
                        <div>
                            <label class="block text-[10px] uppercase tracking-[0.2em] text-[var(--text-dark)]/60 mb-2 font-semibold">Password</label>
                            <input type="password" id="auth-login-pass" required class="imara-input w-full">
                        </div>
                        <div id="auth-login-error" class="hidden text-[11px] text-red-700 mt-2"></div>
                        <button type="submit" class="w-full bg-[var(--brand-terracotta)] text-white py-3 text-[11px] uppercase tracking-[0.2em] font-semibold hover:bg-[var(--brand-terracotta)]/90 transition-colors">Sign In</button>
                    </form>
                </div>

                <div id="auth-panel-register" class="auth-panel hidden">
                    <form onsubmit="event.preventDefault(); app.auth.submitRegister()" class="space-y-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div><label class="block text-[10px] uppercase tracking-[0.2em] text-[var(--text-dark)]/60 mb-2 font-semibold">First Name</label>
                                 <input type="text" id="auth-reg-fname" required class="imara-input w-full"></div>
                            <div><label class="block text-[10px] uppercase tracking-[0.2em] text-[var(--text-dark)]/60 mb-2 font-semibold">Last Name</label>
                                 <input type="text" id="auth-reg-lname" class="imara-input w-full"></div>
                        </div>
                        <div><label class="block text-[10px] uppercase tracking-[0.2em] text-[var(--text-dark)]/60 mb-2 font-semibold">Email</label>
                             <input type="email" id="auth-reg-email" required class="imara-input w-full"></div>
                        <div><label class="block text-[10px] uppercase tracking-[0.2em] text-[var(--text-dark)]/60 mb-2 font-semibold">Password</label>
                             <input type="password" id="auth-reg-pass" required minlength="8" class="imara-input w-full"></div>
                        <div><label class="block text-[10px] uppercase tracking-[0.2em] text-[var(--text-dark)]/60 mb-2 font-semibold">Confirm Password</label>
                             <input type="password" id="auth-reg-pass2" required minlength="8" class="imara-input w-full"></div>
                        <div id="auth-reg-error" class="hidden text-[11px] text-red-700 mt-2"></div>
                        <button type="submit" class="w-full bg-[var(--brand-terracotta)] text-white py-3 text-[11px] uppercase tracking-[0.2em] font-semibold hover:bg-[var(--brand-terracotta)]/90 transition-colors">Create Account</button>
                    </form>
                </div>

                <div id="auth-panel-forgot" class="auth-panel hidden">
                    <form onsubmit="event.preventDefault(); app.auth.submitForgot()" class="space-y-6">
                        <p class="text-sm text-[var(--text-dark)]/70 leading-relaxed">Enter the email associated with your account and we'll send a reset link when this feature becomes available.</p>
                        <div><label class="block text-[10px] uppercase tracking-[0.2em] text-[var(--text-dark)]/60 mb-2 font-semibold">Email</label>
                             <input type="email" id="auth-forgot-email" required class="imara-input w-full"></div>
                        <button type="submit" class="w-full bg-[var(--brand-terracotta)] text-white py-3 text-[11px] uppercase tracking-[0.2em] font-semibold hover:bg-[var(--brand-terracotta)]/90 transition-colors">Send Reset</button>
                    </form>
                </div>
            </div>
        </div>

        <style>
            .auth-tab { color: rgba(44, 34, 30, 0.5); border-bottom: 1px solid transparent; transition: all 0.3s; }
            .auth-tab.active { color: var(--text-dark); border-bottom-color: var(--brand-terracotta); }
            #auth-modal.is-open { display: flex; }
        </style>

