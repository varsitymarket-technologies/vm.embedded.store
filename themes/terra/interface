    </main>

    <div id="cart-drawer-overlay" class="fixed inset-0 bg-[#2D2A26]/40 backdrop-blur-xs z-50 pointer-events-none opacity-0 transition-all duration-300" onclick="app.ui.toggleCartDrawer()">
        <div class="absolute right-0 top-0 h-full w-full max-w-md bg-[#FBF9F6] p-6 sm:p-8 flex flex-col justify-between pointer-events-auto transform translate-x-full transition-transform duration-300 ease-in-out" onclick="event.stopPropagation()">
            <div class="flex flex-col min-h-0 flex-grow">
                <div class="flex items-center justify-between border-b border-[#E1DCD6] pb-4 mb-6">
