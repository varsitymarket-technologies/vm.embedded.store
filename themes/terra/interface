<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TERRA // Thoughtful Objects & Apparel</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Outfit', sans-serif; background-color: #FBF9F6; color: #332F2C; }
        .font-serif { font-family: 'Playfair Display', serif; }
        .view-section { display: none; }
        .view-section.active { display: block; }
        
        /* Shopify style input focus overrides */
        .shopify-input { 
            border: 1px solid #E1DCD6; 
            background-color: #FFFFFF;
            transition: all 0.2s ease;
        }
        .shopify-input:focus { 
            outline: none; 
            border-color: #8C7A6B; 
            box-shadow: 0 0 0 1px #8C7A6B;
        }
        
        /* Soft zoom product card transitions */
        .product-card img {
            transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .product-card:hover img {
            transform: scale(1.03);
        }
    </style>

    <!-- D.3.x: customer auth helper (vm-customer.js from same dir as api.php) -->
    <script src="vm-customer.js" defer></script>
    <script>
        window.addEventListener('vm:customer-loaded', function () {
            document.body.dataset.customer = 'logged-in';
            if (window.app && app.auth && typeof app.auth.updateIcon === 'function') app.auth.updateIcon();
        });
        window.addEventListener('vm:customer-login', function () {
            document.body.dataset.customer = 'logged-in';
            if (window.app && app.auth && typeof app.auth.updateIcon === 'function') app.auth.updateIcon();
        });
        window.addEventListener('vm:customer-logout', function () {
            document.body.dataset.customer = 'logged-out';
            if (window.app && app.auth && typeof app.auth.updateIcon === 'function') app.auth.updateIcon();
        });
    </script>
</head>
<body class="antialiased min-h-screen flex flex-col justify-between selection:bg-[#8C7A6B] selection:text-white">

    <div class="bg-[#2D2A26] text-[#FBF9F6] py-2 text-[11px] font-medium tracking-widest text-center uppercase px-4">
        Crafted with purpose — Enjoy free shipping on continental orders over $200
    </div>

    <header class="sticky top-0 bg-[#FBF9F6]/90 backdrop-blur-md z-40 border-b border-[#E1DCD6]">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between">
            
            <nav class="hidden md:flex items-center space-x-10 text-xs font-medium tracking-widest uppercase text-[#615951]">
                <a href="#shop" onclick="app.router.navigate('shop')" class="hover:text-[#2D2A26] transition-colors">The Shop</a>
                <a href="#about" onclick="app.router.navigate('about')" class="hover:text-[#2D2A26] transition-colors">Our Ethos</a>
            </nav>

            <a href="#home" onclick="app.router.navigate('home')" class="font-serif text-3xl font-medium tracking-wide text-[#2D2A26]">
                TERRA
            </a>

            <div class="flex items-center space-x-5">
                <button class="p-2 text-[#615951] hover:text-[#2D2A26] transition-colors" onclick="app.ui.toggleSearchOverlay()" aria-label="Search Catalog">
                    <i data-lucide="search" class="w-5 h-5 stroke-[1.25]"></i>
                </button>
                <button id="auth-icon-btn" class="p-2 text-[#615951] hover:text-[#2D2A26] transition-colors flex items-center" onclick="app.auth.iconClick()" aria-label="Account">
                    <span class="sr-only" id="auth-icon-label">Account</span>
                    <i data-lucide="user" class="w-5 h-5 stroke-[1.25]"></i>
                </button>
                <button class="p-2 text-[#615951] hover:text-[#2D2A26] transition-colors relative flex items-center" onclick="app.ui.toggleCartDrawer()" aria-label="View Bag">
                    <i data-lucide="shopping-bag" class="w-5 h-5 stroke-[1.25]"></i>
                    <span id="global-cart-count" class="absolute -top-1 -right-1 text-[10px] font-medium text-white bg-[#8C7A6B] w-4 h-4 rounded-full flex items-center justify-center transition-all transform scale-0">0</span>
                </button>
            </div>
        </div>
    </header>

    <main class="flex-grow">

        <section id="view-home" class="view-section active">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-20 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
                <div class="lg:col-span-5 space-y-6 text-center lg:text-left order-2 lg:order-1">
                    <span class="text-xs font-semibold tracking-widest uppercase text-[#8C7A6B]">Volume 03 / Lived Minimalism</span>
                    <h1 class="font-serif text-4xl sm:text-5xl lg:text-6xl text-[#2D2A26] leading-tight font-light">
                        Honest materials. <br><span class="italic">Gentle design.</span>
                    </h1>
                    <p class="text-[#615951] text-sm max-w-md mx-auto lg:mx-0 font-light leading-relaxed">
                        A curated wardrobe framework focused on soft organic linens, raw heavy-weight cottons, and earth-toned home accents built for longevity.
                    </p>
                    <div class="pt-4">
                        <button onclick="app.router.navigate('shop')" class="bg-[#2D2A26] text-[#FBF9F6] text-xs font-medium tracking-widest uppercase px-10 py-4.5 hover:bg-[#4A443E] transition-colors rounded-none">
                            Explore the Collection
                        </button>
                    </div>
                </div>
                <div class="lg:col-span-7 order-1 lg:order-2">
                    <div class="aspect-[16/10] w-full bg-[#EBE7E0] overflow-hidden">
                        <img src="https://images.unsplash.com/photo-1542291026-7eec264c27ff?q=80&w=1200&auto=format&fit=crop" class="w-full h-full object-cover mix-blend-multiply opacity-95" alt="Artisan curation header">
                    </div>
                </div>
            </div>

            <div class="bg-[#F4EFEA] border-y border-[#E1DCD6] py-10 my-8">
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
                    <div class="space-y-1">
                        <h4 class="font-serif text-lg text-[#2D2A26] italic">Organic Foundations</h4>
                        <p class="text-xs text-[#615951] font-light">100% GOTS certified organic materials</p>
                    </div>
                    <div class="space-y-1">
                        <h4 class="font-serif text-lg text-[#2D2A26] italic">Artisanal Production</h4>
                        <p class="text-xs text-[#615951] font-light">Handmade in small, sustainable batches</p>
                    </div>
                    <div class="space-y-1">
                        <h4 class="font-serif text-lg text-[#2D2A26] italic">Traceable Journey</h4>
                        <p class="text-xs text-[#615951] font-light">Transparent supply chain from field to finish</p>
                    </div>
                </div>
            </div>
        </section>

        <section id="view-shop" class="view-section max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <div class="flex flex-col sm:flex-row sm:items-baseline justify-between border-b border-[#E1DCD6] pb-5 mb-12">
                <div>
                    <h2 class="font-serif text-3xl text-[#2D2A26] font-light">The Object Registry</h2>
                    <p id="catalog-count-string" class="text-[#8C7A6B] text-xs mt-1 font-light tracking-wide">Cataloging active pieces...</p>
                </div>
                <div class="mt-4 sm:mt-0 flex items-center space-x-3">
                    <label for="catalog-sort" class="text-xs text-[#615951] uppercase tracking-wider">Sort:</label>
                    <select id="catalog-sort" onchange="app.store.sortCatalog(this.value)" class="text-xs bg-white border border-[#E1DCD6] text-[#2D2A26] rounded-none py-2.5 px-4 focus:outline-none focus:border-[#8C7A6B]">
                        <option value="featured">Curated Selection</option>
                        <option value="price-low">Value: Low to High</option>
                        <option value="price-high">Value: High to Low</option>
                    </select>
                </div>
            </div>

            <div id="shop-items-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-y-16 gap-x-8">
                </div>
        </section>

        <section id="view-product" class="view-section max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <div id="product-detail-target" class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-start">
                </div>
        </section>

        <section id="view-about" class="view-section max-w-3xl mx-auto px-4 py-16 text-center space-y-10">
            <div class="space-y-4">
                <span class="text-xs text-[#8C7A6B] font-semibold tracking-widest uppercase">The Terra Manifesto</span>
                <h2 class="font-serif text-4xl text-[#2D2A26] font-light">Slowing down the rhythm of modern consumption.</h2>
                <p class="text-[#615951] text-sm font-light leading-relaxed">We believe a home and wardrobe should be built around intentionality. Rather than chasing weekly micro-trends, we analyze standard daily utilities to engineer garments that weather beautifully with deep age, wear, and utility.</p>
            </div>
            <div class="aspect-[16/9] w-full bg-[#EBE7E0]">
                <img src="https://images.unsplash.com/photo-1508296695146-257a814070b4?q=80&w=1200&auto=format&fit=crop" class="w-full h-full object-cover opacity-90" alt="Weaving workshop process">
            </div>
        </section>

        <section id="view-faq" class="view-section max-w-2xl mx-auto px-4 py-16 space-y-8">
            <div class="text-center space-y-2">
                <h2 class="font-serif text-3xl text-[#2D2A26]">Store Policies</h2>
                <p class="text-[#8C7A6B] text-xs font-light">Everything you need to know about your shipment routing</p>
            </div>
            <div class="border-t border-[#E1DCD6] divide-y divide-[#E1DCD6]">
                <div class="py-5">
                    <button onclick="app.ui.toggleAccordion(this)" class="w-full flex justify-between items-center text-left py-2 text-sm font-medium text-[#2D2A26] focus:outline-none">
                        <span>How are items packaged?</span>
                        <i data-lucide="plus" class="w-4 h-4 text-[#8C7A6B] transform transition-transform"></i>
                    </button>
                    <div class="max-h-0 overflow-hidden transition-all duration-300 ease-in-out text-[#615951] text-xs leading-relaxed">
                        <p class="py-4 pr-4">Every order ships completely plastic-free inside 100% biodegradable corrugated containers made from post-consumer recycled paper waste. Fabrics are safely bundled in organic cotton gift bags meant to be repurposed.</p>
                    </div>
                </div>
                <div class="py-5">
                    <button onclick="app.ui.toggleAccordion(this)" class="w-full flex justify-between items-center text-left py-2 text-sm font-medium text-[#2D2A26] focus:outline-none">
                        <span>Do you accept international returns?</span>
                        <i data-lucide="plus" class="w-4 h-4 text-[#8C7A6B] transform transition-transform"></i>
                    </button>
                    <div class="max-h-0 overflow-hidden transition-all duration-300 ease-in-out text-[#615951] text-xs leading-relaxed">
                        <p class="py-4 pr-4">Yes, we accommodate international returns within 21 calendar days of delivery logs. Please keep in mind that outside of continental territories, return transport pricing and custom clearing logistics fees are assumed by the returning party.</p>
                    </div>
                </div>
            </div>
        </section>

        <section id="view-contact" class="view-section max-w-4xl mx-auto px-4 py-16">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12 bg-[#F4EFEA] p-8 sm:p-14 border border-[#E1DCD6]">
                <div class="space-y-6 flex flex-col justify-between">
                    <div class="space-y-4">
                        <h2 class="font-serif text-3xl text-[#2D2A26] font-light">Connect With Us</h2>
                        <p class="text-[#615951] text-xs leading-relaxed font-light">Whether you need exact size dimensions, dye details, or bulk registry consulting, our warm support desk is here to assist your step.</p>
                    </div>
                    <div class="text-xs text-[#8C7A6B] font-light space-y-1">
                        <p>Inquiries: hello@terrastudio.co</p>
                        <p>Hours: Mon - Fri, 9AM — 5PM PST</p>
                    </div>
                </div>
                <form onsubmit="app.ui.handleContactSubmit(event)" class="space-y-4">
                    <input type="text" required placeholder="Name" class="w-full p-4 text-xs shopify-input">
                    <input type="email" required placeholder="Email address" class="w-full p-4 text-xs shopify-input">
                    <textarea required rows="4" placeholder="Your message..." class="w-full p-4 text-xs shopify-input"></textarea>
                    <button type="submit" class="w-full bg-[#2D2A26] text-white py-4 text-xs font-medium tracking-widest uppercase hover:bg-[#4A443E] transition-colors rounded-none">Send Inquiry</button>
                </form>
            </div>
        </section>

        <!-- D.3.x: account view -->
        <section id="view-account" class="view-section max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <div class="flex items-center justify-between mb-12">
                <div>
                    <p class="text-[11px] uppercase tracking-widest text-[#8C7A6B] font-medium">Account</p>
                    <h1 id="acc-greeting" class="font-serif text-4xl font-medium text-[#2D2A26] mt-2 tracking-wide">Welcome</h1>
                </div>
                <button onclick="app.auth.doLogout()" class="text-[11px] uppercase tracking-widest text-[#615951] hover:text-[#2D2A26] font-medium">Sign Out</button>
            </div>

            <div class="flex space-x-8 border-b border-[#E1DCD6] mb-8">
                <button id="acc-tab-overview" onclick="app.auth.activateTab('overview')" class="acc-tab pb-3 text-[11px] uppercase tracking-widest font-medium">Overview</button>
                <button id="acc-tab-profile"  onclick="app.auth.activateTab('profile')"  class="acc-tab pb-3 text-[11px] uppercase tracking-widest font-medium">Profile</button>
                <button id="acc-tab-orders"   onclick="app.auth.activateTab('orders')"   class="acc-tab pb-3 text-[11px] uppercase tracking-widest font-medium">Orders</button>
                <button id="acc-tab-password" onclick="app.auth.activateTab('password')" class="acc-tab pb-3 text-[11px] uppercase tracking-widest font-medium">Password</button>
            </div>

            <div id="acc-panel-overview" class="acc-panel">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
                    <div><p class="text-[11px] uppercase tracking-widest text-[#615951]">Name</p><p id="acc-ov-name" class="text-sm text-[#2D2A26] mt-2">—</p></div>
                    <div><p class="text-[11px] uppercase tracking-widest text-[#615951]">Email</p><p id="acc-ov-email" class="text-sm text-[#2D2A26] mt-2">—</p></div>
                    <div><p class="text-[11px] uppercase tracking-widest text-[#615951]">Member Since</p><p id="acc-ov-joined" class="text-sm text-[#2D2A26] mt-2">—</p></div>
                </div>
                <button onclick="app.auth.activateTab('profile')" class="text-[11px] uppercase tracking-widest text-[#2D2A26] border-b border-[#2D2A26] pb-0.5 font-medium">Edit profile</button>
            </div>

            <div id="acc-panel-profile" class="acc-panel hidden">
                <form onsubmit="event.preventDefault(); app.auth.saveProfile()" class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div><label class="block text-[11px] uppercase tracking-widest text-[#615951] mb-2">First Name</label>
                             <input type="text" id="acc-fname" class="w-full bg-white border border-[#E1DCD6] px-4 py-3 text-[#2D2A26] focus:outline-none focus:border-[#2D2A26]"></div>
                        <div><label class="block text-[11px] uppercase tracking-widest text-[#615951] mb-2">Last Name</label>
                             <input type="text" id="acc-lname" class="w-full bg-white border border-[#E1DCD6] px-4 py-3 text-[#2D2A26] focus:outline-none focus:border-[#2D2A26]"></div>
                    </div>
                    <div><label class="block text-[11px] uppercase tracking-widest text-[#615951] mb-2">Email</label>
                         <input type="email" id="acc-email" readonly title="Email is the account identifier and cannot be changed here" class="w-full bg-[#F4EFEA] border border-[#E1DCD6] px-4 py-3 text-[#615951] cursor-not-allowed"></div>
                    <div><label class="block text-[11px] uppercase tracking-widest text-[#615951] mb-2">Phone (optional)</label>
                         <input type="tel" id="acc-phone" class="w-full bg-white border border-[#E1DCD6] px-4 py-3 text-[#2D2A26] focus:outline-none focus:border-[#2D2A26]"></div>
                    <button type="submit" class="w-full bg-[#2D2A26] text-white py-3 text-[11px] uppercase tracking-widest font-medium hover:bg-[#8C7A6B] transition-colors">Save</button>
                </form>
            </div>

            <div id="acc-panel-orders" class="acc-panel hidden">
                <div id="acc-orders-list">
                    <p class="text-[11px] uppercase tracking-widest text-[#615951] py-12 text-center">Loading…</p>
                </div>
            </div>

            <div id="acc-panel-password" class="acc-panel hidden">
                <form onsubmit="event.preventDefault(); app.auth.changePassword()" class="space-y-6">
                    <div><label class="block text-[11px] uppercase tracking-widest text-[#615951] mb-2">Current Password</label>
                         <input type="password" id="acc-pw-cur" required class="w-full bg-white border border-[#E1DCD6] px-4 py-3 text-[#2D2A26] focus:outline-none focus:border-[#2D2A26]"></div>
                    <div><label class="block text-[11px] uppercase tracking-widest text-[#615951] mb-2">New Password</label>
                         <input type="password" id="acc-pw-new" required minlength="8" class="w-full bg-white border border-[#E1DCD6] px-4 py-3 text-[#2D2A26] focus:outline-none focus:border-[#2D2A26]"></div>
                    <div><label class="block text-[11px] uppercase tracking-widest text-[#615951] mb-2">Confirm New Password</label>
                         <input type="password" id="acc-pw-conf" required minlength="8" class="w-full bg-white border border-[#E1DCD6] px-4 py-3 text-[#2D2A26] focus:outline-none focus:border-[#2D2A26]"></div>
                    <button type="submit" class="w-full bg-[#2D2A26] text-white py-3 text-[11px] uppercase tracking-widest font-medium hover:bg-[#8C7A6B] transition-colors">Change Password</button>
                </form>
            </div>
        </section>

        <style>
            .acc-tab { color: #615951; border-bottom: 1px solid transparent; transition: all 0.3s; }
            .acc-tab.active { color: #2D2A26; border-bottom-color: #2D2A26; }
        </style>

        <!-- D.3.x: Auth modal overlay -->
        <div id="auth-modal" class="fixed inset-0 bg-[#FBF9F6] z-50 hidden flex-col items-center justify-start overflow-y-auto p-6">
            <div class="w-full max-w-md mx-auto pt-12 pb-24">
                <div class="flex items-center justify-between mb-12">
                    <span class="font-serif text-3xl font-medium tracking-wide text-[#2D2A26]">TERRA</span>
                    <button onclick="app.auth.close()" aria-label="Close" class="text-[#615951] hover:text-[#2D2A26] transition-colors">
                        <i data-lucide="x" class="w-5 h-5"></i>
                    </button>
                </div>

                <div class="flex space-x-8 border-b border-[#E1DCD6] mb-8">
                    <button id="auth-tab-login"    onclick="app.auth.switchTab('login')"    class="auth-tab pb-3 text-[11px] uppercase tracking-widest font-medium">Sign In</button>
                    <button id="auth-tab-register" onclick="app.auth.switchTab('register')" class="auth-tab pb-3 text-[11px] uppercase tracking-widest font-medium">Create</button>
                    <button id="auth-tab-forgot"   onclick="app.auth.switchTab('forgot')"   class="auth-tab pb-3 text-[11px] uppercase tracking-widest font-medium">Forgot</button>
                </div>

                <div id="auth-panel-login" class="auth-panel">
                    <form onsubmit="event.preventDefault(); app.auth.submitLogin()" class="space-y-6">
                        <div><label class="block text-[11px] uppercase tracking-widest text-[#615951] mb-2">Email</label>
                            <input type="email" id="auth-login-email" required class="w-full bg-white border border-[#E1DCD6] px-4 py-3 text-[#2D2A26] focus:outline-none focus:border-[#2D2A26]"></div>
                        <div><label class="block text-[11px] uppercase tracking-widest text-[#615951] mb-2">Password</label>
                            <input type="password" id="auth-login-pass" required class="w-full bg-white border border-[#E1DCD6] px-4 py-3 text-[#2D2A26] focus:outline-none focus:border-[#2D2A26]"></div>
                        <div id="auth-login-error" class="hidden text-[11px] text-red-700 mt-2"></div>
                        <button type="submit" class="w-full bg-[#2D2A26] text-white py-3 text-[11px] uppercase tracking-widest font-medium hover:bg-[#8C7A6B] transition-colors">Sign In</button>
                    </form>
                </div>

                <div id="auth-panel-register" class="auth-panel hidden">
                    <form onsubmit="event.preventDefault(); app.auth.submitRegister()" class="space-y-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div><label class="block text-[11px] uppercase tracking-widest text-[#615951] mb-2">First Name</label>
                                 <input type="text" id="auth-reg-fname" required class="w-full bg-white border border-[#E1DCD6] px-4 py-3 text-[#2D2A26] focus:outline-none focus:border-[#2D2A26]"></div>
                            <div><label class="block text-[11px] uppercase tracking-widest text-[#615951] mb-2">Last Name</label>
                                 <input type="text" id="auth-reg-lname" class="w-full bg-white border border-[#E1DCD6] px-4 py-3 text-[#2D2A26] focus:outline-none focus:border-[#2D2A26]"></div>
                        </div>
                        <div><label class="block text-[11px] uppercase tracking-widest text-[#615951] mb-2">Email</label>
                             <input type="email" id="auth-reg-email" required class="w-full bg-white border border-[#E1DCD6] px-4 py-3 text-[#2D2A26] focus:outline-none focus:border-[#2D2A26]"></div>
                        <div><label class="block text-[11px] uppercase tracking-widest text-[#615951] mb-2">Password</label>
                             <input type="password" id="auth-reg-pass" required minlength="8" class="w-full bg-white border border-[#E1DCD6] px-4 py-3 text-[#2D2A26] focus:outline-none focus:border-[#2D2A26]"></div>
                        <div><label class="block text-[11px] uppercase tracking-widest text-[#615951] mb-2">Confirm Password</label>
                             <input type="password" id="auth-reg-pass2" required minlength="8" class="w-full bg-white border border-[#E1DCD6] px-4 py-3 text-[#2D2A26] focus:outline-none focus:border-[#2D2A26]"></div>
                        <div id="auth-reg-error" class="hidden text-[11px] text-red-700 mt-2"></div>
                        <button type="submit" class="w-full bg-[#2D2A26] text-white py-3 text-[11px] uppercase tracking-widest font-medium hover:bg-[#8C7A6B] transition-colors">Create Account</button>
                    </form>
                </div>

                <div id="auth-panel-forgot" class="auth-panel hidden">
                    <form onsubmit="event.preventDefault(); app.auth.submitForgot()" class="space-y-6">
                        <p class="text-sm text-[#615951] leading-relaxed">Enter the email associated with your account and we'll send a reset link when this feature becomes available.</p>
