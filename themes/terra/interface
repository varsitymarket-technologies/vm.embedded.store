        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-8 border-b border-[#E1DCD6] pb-12 mb-8">
            <div class="space-y-4">
                <h4 class="text-[#2D2A26] font-semibold tracking-wider uppercase text-[11px]">The Shop</h4>
                <ul class="space-y-2.5"><li class="cursor-pointer hover:text-[#2D2A26]" onclick="app.router.navigate('shop')">All Objects</li></ul>
            </div>
            <div class="space-y-4">
                <h4 class="text-[#2D2A26] font-semibold tracking-wider uppercase text-[11px]">The Brand</h4>
                <ul class="space-y-2.5"><li class="cursor-pointer hover:text-[#2D2A26]" onclick="app.router.navigate('about')">Our Ethos</li></ul>
            </div>
            <div class="space-y-4">
                <h4 class="text-[#2D2A26] font-semibold tracking-wider uppercase text-[11px]">Assistance</h4>
                <ul class="space-y-2.5"><li class="cursor-pointer hover:text-[#2D2A26]" onclick="app.router.navigate('faq')">Help & Care Guides</li><li class="cursor-pointer hover:text-[#2D2A26]" onclick="app.router.navigate('contact')">Contact Desk</li></ul>
            </div>
