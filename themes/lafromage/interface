    <template id="tpl-product">
        <section class="max-w-7xl mx-auto px-10 py-20 grid grid-cols-1 lg:grid-cols-2 gap-24 reveal">
            <div class="aspect-[3/4] bg-archive-line specimen-border overflow-hidden">
                <img src="" class="w-full h-full object-cover grayscale js-detail-img">
