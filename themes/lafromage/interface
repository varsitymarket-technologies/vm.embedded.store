<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>SPECIMEN // ARCHIVE</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@200;900&family=JetBrains+Mono:wght@300&display=swap" rel="stylesheet">
    
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        archive: {
                            paper: '#F5F5F5',
                            ink: '#1A1A1A',
                            line: '#E0E0E0'
                        }
                    },
                    fontFamily: {
                        display: ['"Inter"', 'sans-serif'],
                        mono: ['"JetBrains Mono"', 'monospace']
                    }
                }
            }
        }
    </script>
    <style>
        body { background-color: #F5F5F5; color: #1A1A1A; font-family: 'JetBrains Mono', monospace; overflow-x: hidden; }
        
        /* Thin borders like a blueprint */
        .specimen-border { border: 0.5px solid #E0E0E0; }
        
        /* Subtle reveal animations */
        .reveal { animation: specReveal 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
        @keyframes specReveal { 
            from { opacity: 0; transform: translateY(20px); filter: blur(5px); } 
            to { opacity: 1; transform: translateY(0); filter: blur(0); } 
        }

        /* Hover Reveal Logic */
        .specimen-card .info { opacity: 0; transition: opacity 0.4s ease; }
        .specimen-card:hover .info { opacity: 1; }
        .specimen-card img { transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1); }
        .specimen-card:hover img { transform: scale(1.03); }

        .hidden { display: none !important; }
        ::-webkit-scrollbar { width: 4px; }
        ::-webkit-scrollbar-thumb { background: #1A1A1A; }
    </style>
</head>
<body class="antialiased">

    <nav class="fixed top-0 left-0 w-full z-50 mix-blend-difference px-10 py-8 flex justify-between items-baseline">
        <a href="#home" class="font-display font-black text-2xl tracking-tighter text-archive-ink">S//P</a>
        <div class="flex space-x-12 text-[10px] uppercase tracking-[0.4em] font-bold">
            <a href="#search" class="hover:line-through">Search</a>
            <a href="#shop" class="hover:line-through">Catalog</a>
            <a href="#account" class="hover:line-through">Archive</a>
            <a href="#cart" class="hover:line-through">Index [<span class="js-cart-count">0</span>]</a>
        </div>
    </nav>

    <main id="app-root" class="pt-32 min-h-screen"></main>

    <footer class="p-20 mt-40 specimen-border border-t">
        <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-start space-y-10 md:space-y-0">
            <div class="max-w-xs">
                <p class="font-display font-black text-4xl mb-4">SPECIMEN.</p>
                <p class="text-[9px] leading-loose opacity-40">A study in textile permanence and anatomical geometry. All items are produced in numbered sequences.</p>
            </div>
            <div class="text-[9px] uppercase space-y-2 opacity-40">
                <p>VarsityMarket_Terminal_v4.0</p>
                <p>© 2026 Permanent Collection</p>
            </div>
        </div>
    </footer>

    <template id="tpl-home">
        <section class="max-w-7xl mx-auto px-10 py-20 reveal">
            <div class="mb-40">
                <h1 class="font-display font-thin text-[12vw] leading-none tracking-tighter">THE <br> <span class="font-black">COLLECTION</span></h1>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-20 items-end">
                <div class="aspect-[3/4] bg-archive-line overflow-hidden">
                    <img src="https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?q=80&w=800" class="w-full h-full object-cover grayscale opacity-80">
                </div>
                <div class="pb-20">
                    <p class="text-xs leading-loose mb-10 opacity-60 max-w-sm">
                        Objects intended for the void. We focus on the architecture of the garment, stripping away the unnecessary until only the specimen remains.
                    </p>
                    <a href="#shop" class="font-display font-black text-3xl border-b-2 border-archive-ink pb-2 hover:bg-archive-ink hover:text-archive-paper transition-all px-4">BROWSE_ARCHIVE</a>
                </div>
            </div>
        </section>
    </template>

    <template id="tpl-shop">
        <section class="max-w-7xl mx-auto px-10 py-20">
            <div class="flex justify-between items-end mb-20">
                <h2 class="font-display font-black text-6xl uppercase italic">The Catalog</h2>
                <span class="text-[10px] opacity-30 font-bold uppercase tracking-[0.5em]">Issue_001</span>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12 js-product-grid"></div>
        </section>
    </template>

    <template id="tpl-product-card">
        <div class="specimen-card flex flex-col group cursor-pointer js-prod-link">
            <div class="aspect-[4/5] bg-archive-line mb-6 overflow-hidden relative specimen-border">
                <img src="" alt="" class="w-full h-full object-cover grayscale">
                <div class="absolute inset-0 bg-archive-paper/80 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                    <span class="text-[10px] font-bold tracking-[0.4em]">VIEW_ARTIFACT</span>
                </div>
            </div>
            <div class="info flex justify-between items-start">
                <div>
                    <h3 class="font-display font-black text-xl uppercase js-title"></h3>
                    <p class="text-[9px] opacity-40 uppercase js-category"></p>
                </div>
                <span class="font-bold text-sm js-price"></span>
            </div>
        </div>
