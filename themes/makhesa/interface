    </main>

    <div id="cart-drawer-overlay" class="fixed inset-0 bg-[var(--mks-dark)]/20 backdrop-blur-xs z-50 pointer-events-none opacity-0 transition-opacity duration-300" onclick="app.ui.toggleCartDrawer()">
