                    <option value="price-low">Price Structure: Low to High</option>
                    <option value="price-high">Price Structure: High to Low</option>
                </select>
            </div>

            <div id="shop-items-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-6 gap-y-16">
                </div>
        </section>

        <section id="view-product" class="view-section max-w-7xl mx-auto px-6 py-12">
            <div id="product-detail-target" class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-24">
                </div>
        </section>

        <!-- D.3.x: account view -->
        <section id="view-account" class="view-section max-w-4xl mx-auto px-6 py-16">
