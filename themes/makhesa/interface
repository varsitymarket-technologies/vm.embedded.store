                    <div class="flex justify-between items-start text-sm">
                        <span class="font-medium group-hover:text-[var(--mks-saffron)] transition-colors">Lineage Merino Shawl</span>
                        <span class="text-[var(--mks-muted)]">$150</span>
                    </div>
                </div>
            </div>
        </section>

        <section id="view-shop" class="view-section max-w-7xl mx-auto px-6 py-12">
            <div class="flex flex-col sm:flex-row justify-between items-baseline mb-12 border-b border-[var(--mks-border)] pb-6">
