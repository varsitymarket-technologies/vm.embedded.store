                    <div><p class="text-[10px] uppercase tracking-[0.25em] text-[var(--mks-dark)]/60 font-semibold">Name</p><p id="acc-ov-name" class="text-sm text-[var(--mks-dark)] mt-2">—</p></div>
                    <div><p class="text-[10px] uppercase tracking-[0.25em] text-[var(--mks-dark)]/60 font-semibold">Email</p><p id="acc-ov-email" class="text-sm text-[var(--mks-dark)] mt-2">—</p></div>
                    <div><p class="text-[10px] uppercase tracking-[0.25em] text-[var(--mks-dark)]/60 font-semibold">Member Since</p><p id="acc-ov-joined" class="text-sm text-[var(--mks-dark)] mt-2">—</p></div>
