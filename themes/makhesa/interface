                    </div>
                    <div class="flex justify-between items-start text-sm">
                        <span class="font-medium group-hover:text-[var(--mks-saffron)] transition-colors">Koko Structural Cardigan</span>
                        <span class="text-[var(--mks-muted)]">$310</span>
                    </div>
                </div>
                <div class="group cursor-pointer" onclick="app.router.navigate('product', {id: 'mks-02'})">
                    <div class="bg-white border border-[var(--mks-border)] aspect-[3/4] overflow-hidden p-4 mb-4 flex items-center justify-center">
