                <h4 class="text-white/30 uppercase tracking-[0.2em] text-[10px] font-bold mb-4">Navigation Index</h4>
                <a href="#shop" onclick="app.router.navigate('shop')" class="block text-white/70 hover:text-[var(--mks-saffron)] transition-colors">Seasonal Showroom</a>
                <a href="#" class="block text-white/70 hover:text-[var(--mks-saffron)] transition-colors">Global Logistics Policy</a>
                <a href="#" class="block text-white/70 hover:text-[var(--mks-saffron)] transition-colors">Sartorial Inquiries</a>
            </div>
