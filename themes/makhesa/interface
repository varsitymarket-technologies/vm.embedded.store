                    <div><label class="block text-[10px] uppercase tracking-[0.25em] text-[var(--mks-dark)]/60 mb-2 font-semibold">Confirm New Password</label>
                         <input type="password" id="acc-pw-conf" required minlength="8" class="w-full bg-white border border-[var(--mks-border)] px-4 py-3 text-[var(--mks-dark)] focus:outline-none focus:border-[var(--mks-dark)]"></div>
                    <button type="submit" class="w-full bg-[var(--mks-dark)] text-white py-3 text-[11px] uppercase tracking-[0.25em] font-semibold hover:bg-[var(--mks-saffron)] transition-colors">Change Password</button>
                </form>
            </div>
        </section>

        <style>
            .acc-tab { color: rgba(19, 26, 38, 0.5); border-bottom: 1px solid transparent; transition: all 0.3s; }
            .acc-tab.active { color: var(--mks-dark); border-bottom-color: var(--mks-saffron); }
