<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MAKHESA | Neo-African Luxury</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600&family=Syne:wght@700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --mks-bone: #FDFBF7;
            --mks-dark: #131A26;
            --mks-muted: #626A75;
            --mks-saffron: #E09F3E;
            --mks-border: #E5E0D8;
        }
        
        body { 
            font-family: 'Space Grotesk', sans-serif; 
            background-color: var(--mks-bone); 
            color: var(--mks-dark); 
            -webkit-font-smoothing: antialiased;
        }
        .font-display { font-family: 'Syne', sans-serif; font-weight: 800; }
        
        .view-section { display: none; }
        .view-section.active { display: block; animation: geoFade 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
        
        @keyframes geoFade {
            from { opacity: 0; transform: scale(0.99) translateY(10px); }
            to { opacity: 1; transform: scale(1) translateY(0); }
        }

        /* Minimalist Structural Inputs */
        .mks-input { 
            border: 1px solid var(--mks-border); 
            background-color: transparent;
            color: var(--mks-dark);
            padding: 16px;
            font-size: 14px;
            transition: all 0.2s ease;
        }
        .mks-input:focus { 
            outline: none; 
            border-color: var(--mks-dark);
            background-color: #FFFFFF;
        }
        
        /* Sculptural Buttons */
        .btn-mks-dark {
            background-color: var(--mks-dark);
            color: var(--mks-bone);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            transition: all 0.3s ease;
        }
        .btn-mks-dark:hover {
            background-color: #232D3F;
            letter-spacing: 0.15em;
        }

        .btn-mks-outline {
            border: 1px solid var(--mks-dark);
            background-color: transparent;
            color: var(--mks-dark);
            text-transform: uppercase;
            letter-spacing: 0.1em;
            transition: all 0.2s ease;
        }
        .btn-mks-outline:hover {
            background-color: var(--mks-dark);
            color: var(--mks-bone);
        }

        /* Custom Scrollbar styling */
        ::-webkit-scrollbar { width: 4px; }
        ::-webkit-scrollbar-track { background: var(--mks-bone); }
        ::-webkit-scrollbar-thumb { background: var(--mks-dark); }
    </style>

    <!-- D.3.x: customer auth helper (vm-customer.js from same dir as api.php) -->
    <script src="vm-customer.js" defer></script>
    <script>
        window.addEventListener('vm:customer-loaded', function () {
            document.body.dataset.customer = 'logged-in';
            if (window.app && app.auth && typeof app.auth.updateIcon === 'function') app.auth.updateIcon();
        });
        window.addEventListener('vm:customer-login', function () {
            document.body.dataset.customer = 'logged-in';
            if (window.app && app.auth && typeof app.auth.updateIcon === 'function') app.auth.updateIcon();
        });
        window.addEventListener('vm:customer-logout', function () {
            document.body.dataset.customer = 'logged-out';
            if (window.app && app.auth && typeof app.auth.updateIcon === 'function') app.auth.updateIcon();
        });
    </script>
</head>
<body class="min-h-screen flex flex-col justify-between selection:bg-[#131A26] selection:text-white">

    <div class="bg-[var(--mks-dark)] text-[var(--mks-bone)] text-center py-2 text-[11px] tracking-[0.2em] uppercase font-medium border-b border-white/10 px-4 overflow-hidden whitespace-nowrap">
        MAKHESA AUTUMN/WINTER '26 RUNWAY COLLECTION • COMPLIMENTARY DHL EXPRESS DELIVERY
    </div>

    <header class="sticky top-0 bg-[var(--mks-bone)]/90 backdrop-blur-md z-40 border-b border-[var(--mks-border)]">
        <div class="max-w-7xl mx-auto px-6 h-24 flex items-center justify-between">
            
            <nav class="hidden md:flex items-center space-x-10 text-xs font-medium tracking-[0.15em] uppercase">
                <a href="#shop" onclick="app.router.navigate('shop')" class="hover:text-[var(--mks-saffron)] transition-colors">Collections</a>
                <a href="#shop" onclick="app.router.navigate('shop')" class="hover:text-[var(--mks-saffron)] transition-colors">Lineage</a>
            </nav>

            <a href="#home" onclick="app.router.navigate('home')" class="text-center group">
