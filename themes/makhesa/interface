                <a href="#shop" onclick="app.router.navigate('shop')" class="text-xs uppercase tracking-wider font-semibold border-b border-black pb-1 hover:text-[var(--mks-saffron)] hover:border-[var(--mks-saffron)] transition-colors">See All Work</a>
