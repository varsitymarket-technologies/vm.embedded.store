                </div>

                <div id="auth-panel-register" class="auth-panel hidden">
                    <form onsubmit="event.preventDefault(); app.auth.submitRegister()" class="space-y-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div><label class="block text-[10px] uppercase tracking-[0.25em] text-[var(--mks-dark)]/60 mb-2 font-semibold">First Name</label>
                                 <input type="text" id="auth-reg-fname" required class="w-full bg-white border border-[var(--mks-border)] px-4 py-3 text-[var(--mks-dark)] focus:outline-none focus:border-[var(--mks-dark)]"></div>
                            <div><label class="block text-[10px] uppercase tracking-[0.25em] text-[var(--mks-dark)]/60 mb-2 font-semibold">Last Name</label>
