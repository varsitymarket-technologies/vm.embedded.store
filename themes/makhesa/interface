                             <input type="password" id="auth-reg-pass" required minlength="8" class="w-full bg-white border border-[var(--mks-border)] px-4 py-3 text-[var(--mks-dark)] focus:outline-none focus:border-[var(--mks-dark)]"></div>
                        <div><label class="block text-[10px] uppercase tracking-[0.25em] text-[var(--mks-dark)]/60 mb-2 font-semibold">Confirm Password</label>
                             <input type="password" id="auth-reg-pass2" required minlength="8" class="w-full bg-white border border-[var(--mks-border)] px-4 py-3 text-[var(--mks-dark)] focus:outline-none focus:border-[var(--mks-dark)]"></div>
