                <button onclick="app.auth.activateTab('profile')" class="text-[10px] uppercase tracking-[0.25em] text-[var(--mks-dark)] border-b border-[var(--mks-dark)] pb-0.5 font-semibold">Edit profile</button>
            </div>

            <div id="acc-panel-profile" class="acc-panel hidden">
                <form onsubmit="event.preventDefault(); app.auth.saveProfile()" class="space-y-6">
