                    <button type="submit" class="w-full bg-[var(--mks-dark)] text-white py-3 text-[11px] uppercase tracking-[0.25em] font-semibold hover:bg-[var(--mks-saffron)] transition-colors">Save</button>
                </form>
            </div>

            <div id="acc-panel-orders" class="acc-panel hidden">
                <div id="acc-orders-list">
                    <p class="text-[10px] uppercase tracking-[0.25em] text-[var(--mks-dark)]/60 py-12 text-center">Loading…</p>
                </div>
            </div>

            <div id="acc-panel-password" class="acc-panel hidden">
                <form onsubmit="event.preventDefault(); app.auth.changePassword()" class="space-y-6">
