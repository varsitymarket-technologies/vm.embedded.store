                    <img src="https://images.unsplash.com/photo-1552346154-21d32810baa3?q=80&w=2000&auto=format&fit=crop" class="absolute inset-0 w-full h-full object-cover" alt="Hero Sneaker">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
                    
                    <div class="absolute bottom-12 left-8 md:left-16 z-10 text-white max-w-xl">
                        <span class="font-bold text-sm tracking-widest mb-2 block text-[var(--brand-red)] uppercase">Latest Drop</span>
                        <h1 class="font-display font-bold text-6xl sm:text-8xl leading-[0.9] mb-6">DEFY<br>GRAVITY.</h1>
