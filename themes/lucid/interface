                        <img src="https://images.unsplash.com/photo-1600185365483-26d7a4cc7519?q=80&w=800&auto=format&fit=crop" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 mix-blend-multiply" alt="Shoe">
                    </div>
                    <div class="font-medium">Lucid Retro 1 High</div>
                    <div class="text-neutral-500">Men's Shoes</div>
                    <div class="font-medium mt-2">$180</div>
                </div>
                <div class="cursor-pointer group" onclick="app.router.navigate('product', {id: 'ar-02'})">
                    <div class="bg-[#F5F5F5] aspect-square flex items-center justify-center p-8 rounded-lg mb-4 overflow-hidden">
                        <img src="https://images.unsplash.com/photo-1542291026-7eec264c27ff?q=80&w=800&auto=format&fit=crop" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 mix-blend-multiply" alt="Shoe">
                    </div>
                    <div class="font-medium">Lucid React Vision</div>
                    <div class="text-neutral-500">Men's Shoes</div>
                    <div class="font-medium mt-2">$140</div>
                </div>
                <div class="cursor-pointer group" onclick="app.router.navigate('shop')">
                    <div class="bg-[#F5F5F5] aspect-square flex items-center justify-center p-8 rounded-lg mb-4 overflow-hidden">
                        <img src="https://images.unsplash.com/photo-1551107696-a4b0c5a0d9a2?q=80&w=800&auto=format&fit=crop" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 mix-blend-multiply" alt="Shoe">
                    </div>
                    <div class="font-medium">Lucid Force Low</div>
                    <div class="text-neutral-500">Women's Shoes</div>
                    <div class="font-medium mt-2">$110</div>
                </div>
                <div class="cursor-pointer group" onclick="app.router.navigate('shop')">
                    <div class="bg-[#F5F5F5] aspect-square flex items-center justify-center p-8 rounded-lg mb-4 overflow-hidden">
                        <img src="https://images.unsplash.com/photo-1595950653106-6c9ebd614d3a?q=80&w=800&auto=format&fit=crop" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 mix-blend-multiply" alt="Shoe">
                    </div>
                    <div class="font-medium">Lucid Max 95</div>
                    <div class="text-neutral-500">Men's Shoes</div>
                    <div class="font-medium mt-2">$170</div>
                </div>
