        <section id="view-product" class="view-section max-w-[1200px] mx-auto px-6 py-12">
            <div id="product-detail-target" class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-20">
                </div>
        </section>

        <!-- D.3.x: account view -->
        <section id="view-account" class="view-section max-w-[1000px] mx-auto px-6 py-12">
            <div class="flex items-center justify-between mb-12">
                <div>
                    <p class="text-[11px] uppercase tracking-widest text-neutral-500 font-medium">Account</p>
