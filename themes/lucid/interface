                        <div class="flex space-x-4">
                            <button onclick="app.router.navigate('shop')" class="bg-white text-black px-8 py-4 rounded-full font-medium hover:bg-neutral-200 transition-colors">Shop Collection</button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="max-w-[1440px] mx-auto px-6 mt-16 mb-6 flex justify-between items-end">
