            </div>

            <div class="flex space-x-8 border-b border-neutral-200 mb-8">
                <button id="acc-tab-overview" onclick="app.auth.activateTab('overview')" class="acc-tab pb-3 text-[12px] uppercase tracking-wider font-medium">Overview</button>
                <button id="acc-tab-profile"  onclick="app.auth.activateTab('profile')"  class="acc-tab pb-3 text-[12px] uppercase tracking-wider font-medium">Profile</button>
                <button id="acc-tab-orders"   onclick="app.auth.activateTab('orders')"   class="acc-tab pb-3 text-[12px] uppercase tracking-wider font-medium">Orders</button>
                <button id="acc-tab-password" onclick="app.auth.activateTab('password')" class="acc-tab pb-3 text-[12px] uppercase tracking-wider font-medium">Password</button>
            </div>

            <div id="acc-panel-overview" class="acc-panel">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
                    <div><p class="text-[11px] uppercase tracking-wider text-neutral-500">Name</p><p id="acc-ov-name" class="text-sm text-[var(--brand-black)] mt-2 font-medium">—</p></div>
                    <div><p class="text-[11px] uppercase tracking-wider text-neutral-500">Email</p><p id="acc-ov-email" class="text-sm text-[var(--brand-black)] mt-2 font-medium">—</p></div>
                    <div><p class="text-[11px] uppercase tracking-wider text-neutral-500">Member Since</p><p id="acc-ov-joined" class="text-sm text-[var(--brand-black)] mt-2 font-medium">—</p></div>
                </div>
                <button onclick="app.auth.activateTab('profile')" class="text-[12px] uppercase tracking-wider text-[var(--brand-black)] border-b border-[var(--brand-black)] pb-0.5 font-medium">Edit profile</button>
            </div>

            <div id="acc-panel-profile" class="acc-panel hidden">
                <form onsubmit="event.preventDefault(); app.auth.saveProfile()" class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div><label class="block text-[11px] uppercase tracking-wider text-neutral-500 mb-2 font-medium">First Name</label>
                             <input type="text" id="acc-fname" class="w-full bg-[#F5F5F5] border border-[#F5F5F5] rounded-xl px-4 py-3 text-[var(--brand-black)] focus:outline-none focus:border-[var(--brand-black)] focus:bg-white"></div>
                        <div><label class="block text-[11px] uppercase tracking-wider text-neutral-500 mb-2 font-medium">Last Name</label>
                             <input type="text" id="acc-lname" class="w-full bg-[#F5F5F5] border border-[#F5F5F5] rounded-xl px-4 py-3 text-[var(--brand-black)] focus:outline-none focus:border-[var(--brand-black)] focus:bg-white"></div>
                    </div>
                    <div><label class="block text-[11px] uppercase tracking-wider text-neutral-500 mb-2 font-medium">Email</label>
                         <input type="email" id="acc-email" readonly title="Email is the account identifier and cannot be changed here" class="w-full bg-neutral-100 border border-neutral-200 rounded-xl px-4 py-3 text-neutral-500 cursor-not-allowed"></div>
                    <div><label class="block text-[11px] uppercase tracking-wider text-neutral-500 mb-2 font-medium">Phone (optional)</label>
                         <input type="tel" id="acc-phone" class="w-full bg-[#F5F5F5] border border-[#F5F5F5] rounded-xl px-4 py-3 text-[var(--brand-black)] focus:outline-none focus:border-[var(--brand-black)] focus:bg-white"></div>
                    <button type="submit" class="w-full bg-[var(--brand-black)] text-white py-3 rounded-full text-sm font-semibold uppercase tracking-wider hover:bg-neutral-800 transition-colors">Save</button>
                </form>
            </div>

            <div id="acc-panel-orders" class="acc-panel hidden">
                <div id="acc-orders-list">
                    <p class="text-[11px] uppercase tracking-wider text-neutral-500 py-12 text-center">Loading…</p>
                </div>
            </div>

            <div id="acc-panel-password" class="acc-panel hidden">
                <form onsubmit="event.preventDefault(); app.auth.changePassword()" class="space-y-6">
                    <div><label class="block text-[11px] uppercase tracking-wider text-neutral-500 mb-2 font-medium">Current Password</label>
