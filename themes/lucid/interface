                <div class="flex space-x-8 border-b border-neutral-200 mb-8">
                    <button id="auth-tab-login"    onclick="app.auth.switchTab('login')"    class="auth-tab pb-3 text-[12px] uppercase tracking-wider font-medium">Sign In</button>
                    <button id="auth-tab-register" onclick="app.auth.switchTab('register')" class="auth-tab pb-3 text-[12px] uppercase tracking-wider font-medium">Create</button>
                    <button id="auth-tab-forgot"   onclick="app.auth.switchTab('forgot')"   class="auth-tab pb-3 text-[12px] uppercase tracking-wider font-medium">Forgot</button>
                </div>

                <div id="auth-panel-login" class="auth-panel">
                    <form onsubmit="event.preventDefault(); app.auth.submitLogin()" class="space-y-6">
                        <div><label class="block text-[11px] uppercase tracking-wider text-neutral-500 mb-2 font-medium">Email</label>
                            <input type="email" id="auth-login-email" required class="w-full bg-[#F5F5F5] border border-[#F5F5F5] rounded-xl px-4 py-3 text-[var(--brand-black)] focus:outline-none focus:border-[var(--brand-black)] focus:bg-white"></div>
                        <div><label class="block text-[11px] uppercase tracking-wider text-neutral-500 mb-2 font-medium">Password</label>
                            <input type="password" id="auth-login-pass" required class="w-full bg-[#F5F5F5] border border-[#F5F5F5] rounded-xl px-4 py-3 text-[var(--brand-black)] focus:outline-none focus:border-[var(--brand-black)] focus:bg-white"></div>
                        <div id="auth-login-error" class="hidden text-[12px] text-[var(--brand-red)] mt-2"></div>
                        <button type="submit" class="w-full bg-[var(--brand-black)] text-white py-3 rounded-full text-sm font-semibold uppercase tracking-wider hover:bg-neutral-800 transition-colors">Sign In</button>
                    </form>
                </div>

                <div id="auth-panel-register" class="auth-panel hidden">
                    <form onsubmit="event.preventDefault(); app.auth.submitRegister()" class="space-y-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div><label class="block text-[11px] uppercase tracking-wider text-neutral-500 mb-2 font-medium">First Name</label>
                                 <input type="text" id="auth-reg-fname" required class="w-full bg-[#F5F5F5] border border-[#F5F5F5] rounded-xl px-4 py-3 text-[var(--brand-black)] focus:outline-none focus:border-[var(--brand-black)] focus:bg-white"></div>
                            <div><label class="block text-[11px] uppercase tracking-wider text-neutral-500 mb-2 font-medium">Last Name</label>
                                 <input type="text" id="auth-reg-lname" class="w-full bg-[#F5F5F5] border border-[#F5F5F5] rounded-xl px-4 py-3 text-[var(--brand-black)] focus:outline-none focus:border-[var(--brand-black)] focus:bg-white"></div>
                        </div>
                        <div><label class="block text-[11px] uppercase tracking-wider text-neutral-500 mb-2 font-medium">Email</label>
                             <input type="email" id="auth-reg-email" required class="w-full bg-[#F5F5F5] border border-[#F5F5F5] rounded-xl px-4 py-3 text-[var(--brand-black)] focus:outline-none focus:border-[var(--brand-black)] focus:bg-white"></div>
