                    <div><label class="block text-[11px] uppercase tracking-wider text-neutral-500 mb-2 font-medium">New Password</label>
                         <input type="password" id="acc-pw-new" required minlength="8" class="w-full bg-[#F5F5F5] border border-[#F5F5F5] rounded-xl px-4 py-3 text-[var(--brand-black)] focus:outline-none focus:border-[var(--brand-black)] focus:bg-white"></div>
                    <div><label class="block text-[11px] uppercase tracking-wider text-neutral-500 mb-2 font-medium">Confirm New Password</label>
                         <input type="password" id="acc-pw-conf" required minlength="8" class="w-full bg-[#F5F5F5] border border-[#F5F5F5] rounded-xl px-4 py-3 text-[var(--brand-black)] focus:outline-none focus:border-[var(--brand-black)] focus:bg-white"></div>
                    <button type="submit" class="w-full bg-[var(--brand-black)] text-white py-3 rounded-full text-sm font-semibold uppercase tracking-wider hover:bg-neutral-800 transition-colors">Change Password</button>
                </form>
            </div>
        </section>

        <style>
            .acc-tab { color: rgba(17, 17, 17, 0.5); border-bottom: 2px solid transparent; transition: all 0.3s; margin-bottom: -1px; }
