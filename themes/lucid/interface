        <div class="max-w-[1440px] mx-auto px-6 h-20 flex items-center justify-between">
            
            <a href="#home" onclick="app.router.navigate('home')" class="flex items-center space-x-2">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M2 22L12 2L22 22H16L12 14L8 22H2Z" fill="#111111"/>
                </svg>
                <span class="font-display font-bold text-2xl tracking-tighter hidden sm:block mt-1">LUCID</span>
            </a>

            <nav class="hidden md:flex items-center space-x-8 font-medium text-[15px]">
                <a href="#shop" onclick="app.router.navigate('shop')" class="hover:text-neutral-500 transition-colors">New Releases</a>
                <a href="#shop" onclick="app.router.navigate('shop')" class="hover:text-neutral-500 transition-colors">Men</a>
                <a href="#shop" onclick="app.router.navigate('shop')" class="hover:text-neutral-500 transition-colors">Women</a>
                <a href="#shop" onclick="app.router.navigate('shop')" class="hover:text-neutral-500 transition-colors">SNKRS</a>
            </nav>

            <div class="flex items-center space-x-5">
                <button class="hover:text-neutral-500 transition-colors bg-[#F5F5F5] p-2 rounded-full" onclick="app.ui.toggleSearchOverlay()" aria-label="Search">
                    <i data-lucide="search" class="w-5 h-5"></i>
