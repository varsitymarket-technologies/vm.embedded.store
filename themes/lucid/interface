        </section>

        <section id="view-shop" class="view-section max-w-[1440px] mx-auto px-6 py-12">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-10 sticky top-20 bg-white/95 backdrop-blur z-30 py-4">
                <h2 class="text-2xl font-medium mb-4 md:mb-0">New Releases (4)</h2>
                <div class="flex items-center space-x-6">
                    <button class="flex items-center space-x-2 font-medium hover:text-neutral-500">
                        <span>Hide Filters</span>
                        <i data-lucide="sliders-horizontal" class="w-5 h-5"></i>
                    </button>
                    <select id="catalog-sort" onchange="app.store.sortCatalog(this.value)" class="bg-transparent font-medium cursor-pointer focus:outline-none">
                        <option value="featured">Sort By</option>
                        <option value="price-low">Price: Low-High</option>
                        <option value="price-high">Price: High-Low</option>
                    </select>
                </div>
            </div>

            <div class="flex">
                <aside class="w-64 hidden lg:block pr-8 shrink-0">
                    <div class="border-t border-neutral-200 py-4 font-medium cursor-pointer flex justify-between"><span>Gender</span> <i data-lucide="chevron-up" class="w-5 h-5"></i></div>
                    <div class="pb-6 space-y-2 text-neutral-600">
                        <label class="flex items-center space-x-2 cursor-pointer"><input type="checkbox" class="accent-black w-4 h-4"><span>Men</span></label>
                        <label class="flex items-center space-x-2 cursor-pointer"><input type="checkbox" class="accent-black w-4 h-4"><span>Women</span></label>
