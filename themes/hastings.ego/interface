        .main-nav-btn{
            display:none;
        }

        @media screen and (max-width: 768px) {
  
            /* Hide Desktop Navigation */
            .main-nav {
                display: none;
            }

            .main-nav-btn{
                display:block; 
            }

            .container {
                display:block !important; 
            }
        }

        .hero-nav{
            /* position: fixed; */
            top: 0;
            right: 0;
            bottom: 0;
            left: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 400px;
            min-height: 105px;
            background-image: url(e(__ABOUT_BACKGROUNG_IMAGE__););
            background-size: cover;
            background-position: center;
            overflow: hidden;
            border-radius: 1.5rem;
            border-style: solid;
            border-width: 2px;

            h1{
                color: #efefef;
                font-size: 10vw;
            }
            &:before{
                content: "";
                background: rgba(#000, 0);
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                transition: background 400ms;
            }
            &.fixme{
                &:before{
                    background: rgba(#000, 0.8);
                }
            }
        }
        .page-content{
            width: 30em;
            margin: 0 auto;
            line-height: 1.625;
        }
    </style>
