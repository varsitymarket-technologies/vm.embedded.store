    <script>
        /**
         * Luxury product dataset
         */
        const __SEED = [
            { id: 'aura-01', name: 'Bergamot & Santal', price: 210.00, category: 'EAU DE PARFUM', images: ['https://images.unsplash.com/photo-1594035910387-fea47794261f?q=80&w=800&auto=format&fit=crop'], desc: 'A crisp opening of Calabrian bergamot gives way to a profound, creamy heart of Australian sandalwood. A scent of quiet confidence and extreme clarity.', notes: 'Bergamot, Violet Leaf, Sandalwood, Ambergris' },
            { id: 'aura-02', name: 'Fig Tree', price: 85.00, category: 'BOUGIE', images: ['https://images.unsplash.com/photo-1603006905003-be475563bc59?q=80&w=800&auto=format&fit=crop'], desc: 'Hand-poured vegan wax infused with the essence of a sun-baked Mediterranean fig grove. Green leaves, milky sap, and warm bark.', notes: 'Fig Leaf, Cedarwood, Vetiver' },
            { id: 'aura-03', name: 'Hinoki Body Wash', price: 45.00, category: 'ESSENTIALS', images: ['https://images.unsplash.com/photo-1620916566398-39f1143ab7be?q=80&w=800&auto=format&fit=crop'], desc: 'A gentle, sulfate-free lather designed to cleanse while leaving a trace of Japanese cypress and crushed pine needles on the skin.', notes: 'Hinoki Wood, Frankincense, Oakmoss' },
            { id: 'aura-04', name: 'Rose Absolute', price: 160.00, category: 'EAU DE PARFUM', images: ['https://images.unsplash.com/photo-1588405748880-12d1d2a59f75?q=80&w=800&auto=format&fit=crop'], desc: 'Not your traditional floral. A dark, slightly metallic Damask rose anchored by heavy oud and black pepper. Unapologetic and deeply sensual.', notes: 'Black Pepper, Damascena Rose, Oud, Patchouli' }
        ];

        /* ════════════════════
           CANONICAL DATA LAYER — fetchStore → api.php?state=X, getMockData fallback, MOCK shape
        ════════════════════ */
        const __CATS = [...new Set(__SEED.map(p => p.category).filter(Boolean))].map((name, i) => ({ id: i + 1, name }));
        const MOCK = {
            site: { name: "AURA", currency: "R", domain: window.location.hostname },
            categories: __CATS,
            products: __SEED.map((p, i) => ({
                ...p,
                id: p.id != null ? p.id : i + 1,
                image: p.image || (Array.isArray(p.images) ? p.images[0] : "") || "",
                description: p.description || p.desc || "",
                stock: p.stock != null ? p.stock : 12,
                category_id: (__CATS.find(c => c.name === p.category) || {}).id || null
            })),
            discounts: [
                { id: 1, code: "WELCOME10", percentage: 10, active: 1 },
                { id: 2, code: "DROP20", percentage: 20, active: 1 }
            ]
        };

        async function fetchStore(state, params = {}) {
            const url = new URL("api.php", window.location.href);
            url.searchParams.set("state", state);
            for (const [k, v] of Object.entries(params)) url.searchParams.set(k, v);
            try {
                const res = await fetch(url, { signal: AbortSignal.timeout(4000) });
                if (!res.ok) throw new Error(res.status);
                return await res.json();
            } catch {
                return getMockData(state, params);
            }
        }

        function getMockData(state, params = {}) {
            switch (state) {
                case "site": return MOCK.site;
                case "products": return MOCK.products;
                case "product": return MOCK.products.find(p => p.id == params.id) || null;
                case "categories": return MOCK.categories;
                case "products_by_category": return MOCK.products.filter(p => p.category_id == params.category_id);
                case "search": {
                    const q = (params.q || "").toLowerCase();
                    return MOCK.products.filter(p => (p.name || "").toLowerCase().includes(q) || (p.description || "").toLowerCase().includes(q));
                }
                case "discounts": return MOCK.discounts;
                case "orders": return [];
                default: return [];
            }
        }

        let INVENTORY_DB = [];

        const app = {
            state: { cart: [], activeFilter: 'all', currentSort: 'featured', activeCheckoutStep: 1 },
            init: async function() {
                const __d = await fetchStore('products');
                INVENTORY_DB = __d.map(p => ({ ...p, images: p.images || (p.image ? [p.image] : []), desc: p.desc || p.description || '', category: p.category || ((MOCK.categories.find(c => c.id == p.category_id) || {}).name) || '' }));
                this.router.init(); this.store.renderCatalog(); this.cart.loadAndSync(); lucide.createIcons();
            }
        };

        // --- ROUTER ---
        app.router = {
            init: function() {
                window.addEventListener('popstate', () => this.evalRoute(window.location.hash));
                this.evalRoute(window.location.hash || '#home');
            },
            navigate: function(view, params = null) {
                let hash = `#${view}`;
                if (params) hash += `?${new URLSearchParams(params).toString()}`;
                history.pushState(null, null, hash);
                this.evalRoute(hash);
            },
            evalRoute: function(hashString) {
                const parts = hashString.split('?');
                const view = parts[0] || '#home';
                const queryParams = parts[1] ? Object.fromEntries(new URLSearchParams(parts[1])) : {};
                document.querySelectorAll('.view-section').forEach(el => el.classList.remove('active'));
                const targetView = document.getElementById(`view-${view.replace('#', '')}`);
                if (targetView) targetView.classList.add('active');
                if (view === '#shop') { app.store.filterCatalog('all'); } 
                else if (view === '#product' && queryParams.id) { app.store.renderProductDetail(queryParams.id); } 
                else if (view === '#checkout') { app.checkout.renderCurrentStep(); }
                window.scrollTo({top:0, behavior: 'smooth'});
            }
        };

        // --- STORE / CATALOG ---
        app.store = {
            renderCatalog: function(itemsToRender = INVENTORY_DB) {
                const grid = document.getElementById('shop-items-grid');
                if (!grid) return;
                grid.innerHTML = itemsToRender.map(item => `
                    <div class="product-card group cursor-pointer" onclick="app.router.navigate('product', {id: '${item.id}'})">
                        <div class="aspect-[3/4] w-full overflow-hidden bg-neutral-50 mb-6 relative">
                            <img src="${item.images[0]}" alt="${item.name}" class="w-full h-full object-cover">
                        </div>
                        <div class="text-center space-y-2">
                            <h3 class="font-serif text-xl text-black">${item.name}</h3>
                            <p class="text-[11px] text-neutral-400 uppercase tracking-[0.15em]">${item.category}</p>
                            <p class="text-[13px] text-black font-light">$${item.price.toFixed(2)}</p>
                        </div>
                    </div>`).join('');
                document.getElementById('catalog-count-string').innerText = `${itemsToRender.length} objects`;
            },
            filterCatalog: function(cat) { app.state.activeFilter = cat; this.renderCatalog(cat === 'all' ? INVENTORY_DB : INVENTORY_DB.filter(i => i.category === cat)); },
            sortCatalog: function(criteria) {
                let sorted = [...INVENTORY_DB];
                if (criteria === 'price-low') sorted.sort((a,b) => a.price - b.price);
                if (criteria === 'price-high') sorted.sort((a,b) => b.price - a.price);
                this.renderCatalog(sorted);
            },
            renderProductDetail: function(id) {
                const item = INVENTORY_DB.find(p => p.id === id);
                if (!item) return;
                document.getElementById('product-detail-target').innerHTML = `
                    <div class="aspect-[4/5] w-full bg-neutral-50 overflow-hidden">
                        <img src="${item.images[0]}" alt="${item.name}" class="w-full h-full object-cover">
                    </div>
                    <div class="flex flex-col pt-8 md:pt-16">
                        <span class="text-[10px] text-neutral-400 uppercase tracking-[0.2em] mb-4">${item.category}</span>
                        <h1 class="font-serif text-4xl sm:text-5xl text-black mb-4">${item.name}</h1>
                        <p class="text-xl font-serif text-black mb-10">$${item.price.toFixed(2)}</p>
                        
                        <p class="text-[13px] text-neutral-500 leading-relaxed font-light mb-12">${item.desc}</p>
                        
                        <div class="border-t border-[#E5E5E5] mb-12">
                            <div class="py-4 border-b border-[#E5E5E5] flex justify-between text-[11px] uppercase tracking-[0.1em]">
                                <span class="text-neutral-400">Olfactory Notes</span>
                                <span class="text-black text-right">${item.notes}</span>
                            </div>
                            <div class="py-4 border-b border-[#E5E5E5] flex justify-between text-[11px] uppercase tracking-[0.1em]">
                                <span class="text-neutral-400">Volume</span>
                                <span class="text-black">50 ML / 1.7 FL OZ</span>
                            </div>
                        </div>

                        <button onclick="app.cart.addItem('${item.id}')" class="w-full py-4 border border-black text-black text-[11px] uppercase tracking-[0.2em] hover:bg-black hover:text-white transition-colors duration-500">
                            Add to Tote
                        </button>
                    </div>`;
            },
            handleSearch: function(term) {
                const out = document.getElementById('search-results-output');
                if (!term) { out.innerHTML = ''; return; }
                out.innerHTML = INVENTORY_DB.filter(i => i.name.toLowerCase().includes(term.toLowerCase())).map(i => `
                    <div onclick="app.ui.toggleSearchOverlay(); app.router.navigate('product', {id: '${i.id}'})" class="flex items-center justify-between cursor-pointer border-b border-[#E5E5E5] pb-4 group">
                        <div class="flex items-center space-x-6">
                            <img src="${i.images[0]}" class="w-16 h-20 object-cover bg-neutral-50">
                            <div>
                                <span class="block font-serif text-xl text-black group-hover:text-neutral-500 transition-colors">${i.name}</span>
                                <span class="block text-[10px] text-neutral-400 uppercase tracking-[0.1em] mt-1">${i.category}</span>
                            </div>
                        </div>
                        <span class="text-[13px] text-black font-light">$${i.price}</span>
                    </div>`).join('');
            }
        };

        // --- CART ---
        app.cart = {
            loadAndSync: function() { const stored = localStorage.getItem('aura_cart'); if (stored) app.state.cart = JSON.parse(stored); this.updateUI(); },
            addItem: function(id) {
                const prod = INVENTORY_DB.find(p => p.id === id);
                const exist = app.state.cart.find(item => item.product.id === id);
                if (exist) exist.qty += 1; else app.state.cart.push({ product: prod, qty: 1 });
                this.sync(); app.ui.triggerToast(`${prod.name} added`); app.ui.toggleCartDrawer(true);
            },
            updateQty: function(id, val) { const item = app.state.cart.find(i => i.product.id === id); if (!item) return; item.qty += val; if (item.qty <= 0) app.state.cart = app.state.cart.filter(i => i.product.id !== id); this.sync(); },
            sync: function() { localStorage.setItem('aura_cart', JSON.stringify(app.state.cart)); this.updateUI(); },
            updateUI: function() {
                const drawerContainer = document.getElementById('cart-drawer-items');
                const badgeMobile = document.getElementById('global-cart-count');
                const badgeText = document.getElementById('global-cart-count-text');
                const subtotalText = document.getElementById('cart-drawer-subtotal');
                const totalItems = app.state.cart.reduce((sum, i) => sum + i.qty, 0);
                const subtotal = app.state.cart.reduce((sum, i) => sum + (i.product.price * i.qty), 0);
                
                badgeText.innerText = totalItems;
                if (totalItems > 0) { badgeMobile.classList.remove('scale-0'); badgeMobile.innerText = totalItems; } else { badgeMobile.classList.add('scale-0'); }
                
                subtotalText.innerText = `$${subtotal.toFixed(2)}`;
                if (app.state.cart.length === 0) { 
                    drawerContainer.innerHTML = `<div class="text-center text-neutral-400 py-12 text-[11px] uppercase tracking-[0.15em]">Your tote is empty.</div>`; 
                } else {
                    drawerContainer.innerHTML = app.state.cart.map(item => `
                        <div class="flex space-x-6">
                            <img src="${item.product.images[0]}" class="w-20 h-24 object-cover bg-neutral-50">
                            <div class="flex flex-col justify-between py-1 flex-grow">
                                <div>
                                    <h4 class="font-serif text-lg text-black leading-none">${item.product.name}</h4>
                                    <p class="text-[10px] text-neutral-400 uppercase tracking-[0.1em] mt-2">${item.product.category}</p>
                                </div>
                                <div class="flex items-center justify-between mt-4">
                                    <div class="flex items-center space-x-4 border border-[#E5E5E5] px-3 py-1">
                                        <button onclick="app.cart.updateQty('${item.product.id}', -1)" class="text-neutral-400 hover:text-black text-[12px]">&minus;</button>
                                        <span class="text-[11px] text-black w-3 text-center">${item.qty}</span>
                                        <button onclick="app.cart.updateQty('${item.product.id}', 1)" class="text-neutral-400 hover:text-black text-[12px]">&plus;</button>
                                    </div>
                                    <span class="text-[13px] text-black font-light">$${(item.product.price * item.qty).toFixed(2)}</span>
                                </div>
                            </div>
                        </div>`).join('');
                }
            }
        };

        // --- CHECKOUT ---
        app.checkout = {
            initiateCheckout: function() { if(!app.state.cart.length) return; app.ui.toggleCartDrawer(false); app.router.navigate('checkout'); },
            renderCurrentStep: function() {
                const container = document.getElementById('checkout-step-container');
                const sub = app.state.cart.reduce((sum, i) => sum + (i.product.price * i.qty), 0);
                document.getElementById('chk-total').innerText = `$${sub.toFixed(2)}`;
                document.getElementById('checkout-summary-items').innerHTML = app.state.cart.map(i => `
                    <div class="flex space-x-4">
                        <img src="${i.product.images[0]}" class="w-16 h-20 object-cover bg-white">
                        <div class="flex-grow flex justify-between py-1">
                            <div>
                                <span class="block font-serif text-lg text-black">${i.product.name}</span>
                                <span class="block text-[10px] text-neutral-400 uppercase tracking-[0.1em] mt-1">QTY: ${i.qty}</span>
                            </div>
                            <span class="text-[13px] text-black font-light">$${(i.product.price * i.qty).toFixed(2)}</span>
                        </div>
                    </div>`).join('');
                
                document.getElementById('step-nav-1').className = app.state.activeCheckoutStep === 1 ? "text-black" : "text-neutral-400";
                document.getElementById('step-nav-2').className = app.state.activeCheckoutStep === 2 ? "text-black" : "text-neutral-400";

                if (app.state.activeCheckoutStep === 1) { 
                    container.innerHTML = `
                        <input type="email" required placeholder="Email Address" class="w-full py-4 text-[13px] mb-6 shopify-input">
                        <input type="text" required placeholder="Full Name" class="w-full py-4 text-[13px] mb-6 shopify-input"/>
                        <input type="text" required placeholder="Shipping Address" class="w-full py-4 text-[13px] shopify-input"/>
                    `; 
                } else if (app.state.activeCheckoutStep === 2) { 
                    container.innerHTML = `
                        <p class="text-[11px] uppercase tracking-[0.15em] text-neutral-500 mb-6">Payment Information</p>
                        <input type="text" required placeholder="Card Number" class="w-full py-4 text-[13px] mb-6 shopify-input">
                        <div class="grid grid-cols-2 gap-6">
                            <input type="text" required placeholder="MM/YY" class="w-full py-4 text-[13px] shopify-input">
                            <input type="text" required placeholder="CVC" class="w-full py-4 text-[13px] shopify-input">
                        </div>
                    `; 
                }
            },
            handleStepSubmit: function(e) { 
                e.preventDefault(); 
                if(app.state.activeCheckoutStep < 2) { 
                    app.state.activeCheckoutStep += 1; 
                    this.renderCurrentStep(); 
                } else { 
                    app.state.cart = []; 
                    app.cart.sync(); 
                    app.state.activeCheckoutStep = 1; 
                    app.ui.triggerToast("Order Placed Successfully"); 
                    app.router.navigate('home'); 
                } 
            }
        };

        // --- UI UTILS ---
        app.ui = {
            toggleCartDrawer: function(forceOpen = null) {
                const overlay = document.getElementById('cart-drawer-overlay');
                const inner = overlay.firstElementChild;
                if (forceOpen === true) { 
                    overlay.classList.remove('opacity-0', 'pointer-events-none'); 
                    inner.classList.remove('translate-x-full'); 
                    return; 
                }
                if (forceOpen === false) { 
                    overlay.classList.add('opacity-0', 'pointer-events-none'); 
                    inner.classList.add('translate-x-full'); 
                    return; 
                }
                overlay.classList.toggle('opacity-0'); 
                overlay.classList.toggle('pointer-events-none');
                inner.classList.toggle('translate-x-full');
            },
            toggleSearchOverlay: function() { 
                const s = document.getElementById('search-overlay'); 
                s.classList.toggle('hidden'); 
                s.classList.toggle('flex'); 
                if(!s.classList.contains('hidden')) {
                    setTimeout(() => document.getElementById('live-search-input').focus(), 100);
                }
            },
            toggleAccordion: function(btn) { 
                const icon = btn.querySelector('i');
                const panel = btn.nextElementSibling; 
                if (panel.style.maxHeight && panel.style.maxHeight !== '0px') { 
                    panel.style.maxHeight = '0px'; 
                    icon.style.transform = 'rotate(0deg)';
                } else { 
                    panel.style.maxHeight = panel.scrollHeight + "px"; 
                    icon.style.transform = 'rotate(45deg)';
                } 
            },
            handleContactSubmit: function(e) { 
                e.preventDefault(); 
                e.target.reset(); 
                this.triggerToast("Message Sent"); 
            },
            triggerToast: function(msg) {
                const t = document.getElementById('toast-notif'); 
                document.getElementById('toast-notif-message').innerText = msg;
                t.classList.remove('opacity-0', 'translate-y-10', 'pointer-events-none');
                setTimeout(() => { 
                    t.classList.add('opacity-0', 'translate-y-10', 'pointer-events-none'); 
                }, 3000);
            }
        };

        // Change header background on scroll
        window.addEventListener('scroll', () => {
            const header = document.querySelector('header');
            if(window.scrollY > 10) {
                header.classList.add('shadow-sm');
            } else {
                header.classList.remove('shadow-sm');
            }
        });

        window.addEventListener('DOMContentLoaded', () => app.init());
    </script>
</body>
</html>
