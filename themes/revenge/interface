<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>REVENGE | No Forgiveness</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@400;600;700&family=Permanent+Marker&display=swap" rel="stylesheet">
    <style>
        :root {
            --rvg-black: #030303;
            --rvg-dark: #111111;
            --rvg-red: #D90429;
            --rvg-blood: #8B0000;
            --rvg-white: #EAEAEA;
            --rvg-gray: #333333;
        }
        
        body { 
            font-family: 'Chakra Petch', sans-serif; 
            background-color: var(--rvg-black); 
            color: var(--rvg-white); 
            -webkit-font-smoothing: antialiased;
            background-image: 
                radial-gradient(circle at 50% 50%, rgba(217, 4, 41, 0.03) 0%, transparent 60%),
                url('data:image/svg+xml,%3Csvg width="60" height="60" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg"%3E%3Cg fill="none" fill-rule="evenodd"%3E%3Cg fill="%23222222" fill-opacity="0.4"%3E%3Cpath d="M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z"/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');
        }
        
        .font-graffiti { 
            font-family: 'Permanent Marker', cursive; 
        }

        /* Spray Paint Effect */
        .spray-text {
            color: var(--rvg-red);
            text-shadow: 0 0 10px rgba(217, 4, 41, 0.8), 0 0 20px rgba(217, 4, 41, 0.5), 0 0 30px rgba(139, 0, 0, 0.5);
            transform: rotate(-3deg);
            display: inline-block;
        }
        
        .view-section { display: none; }
        .view-section.active { display: block; animation: bloodFade 0.4s ease-out forwards; }
        
        @keyframes bloodFade {
            from { opacity: 0; filter: blur(4px); transform: scale(1.02); }
            to { opacity: 1; filter: blur(0); transform: scale(1); }
        }

        @keyframes flicker {
            0% { opacity: 1; }
            3% { opacity: 0.4; }
            6% { opacity: 1; }
            7% { opacity: 0.4; }
            8% { opacity: 1; }
            9% { opacity: 1; }
            10% { opacity: 0.1; }
            11% { opacity: 1; }
            100% { opacity: 1; }
        }

        .glitch-hover:hover {
            animation: flicker 0.15s infinite;
            color: var(--rvg-red);
        }

        /* Gritty Inputs */
        .rvg-input { 
            border: 1px solid var(--rvg-gray); 
            background-color: var(--rvg-dark);
            color: var(--rvg-white);
            border-radius: 0px;
            padding: 14px;
            font-size: 14px;
            font-family: 'Chakra Petch', sans-serif;
            transition: all 0.2s ease;
        }
        .rvg-input:focus { 
            outline: none; 
            border-color: var(--rvg-red);
            box-shadow: 0 0 8px rgba(217, 4, 41, 0.3);
        }
        
        /* Aggressive Buttons */
        .btn-blood {
            background-color: var(--rvg-red);
            color: #ffffff;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            border: 1px solid transparent;
            transition: all 0.2s ease;
            position: relative;
            overflow: hidden;
        }
        .btn-blood:hover {
            background-color: var(--rvg-blood);
            border-color: var(--rvg-red);
            box-shadow: 0 0 15px rgba(217, 4, 41, 0.6);
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: var(--rvg-black); border-left: 1px solid var(--rvg-gray); }
        ::-webkit-scrollbar-thumb { background: var(--rvg-gray); }
        ::-webkit-scrollbar-thumb:hover { background: var(--rvg-red); }

        /* Image filter hack for dark/red vibe */
        .img-revenge {
            filter: grayscale(100%) contrast(1.2) brightness(0.8);
            transition: all 0.4s ease;
        }
        .group:hover .img-revenge {
            filter: grayscale(80%) sepia(50%) hue-rotate(315deg) saturate(300%) contrast(1.4) brightness(0.7);
        }
    </style>

    <!-- D.3.x: customer auth helper (vm-customer.js from same dir as api.php) -->
    <script src="vm-customer.js" defer></script>
    <script>
        window.addEventListener('vm:customer-loaded', function () {
            document.body.dataset.customer = 'logged-in';
            if (window.app && app.auth && typeof app.auth.updateIcon === 'function') app.auth.updateIcon();
        });
        window.addEventListener('vm:customer-login', function () {
            document.body.dataset.customer = 'logged-in';
            if (window.app && app.auth && typeof app.auth.updateIcon === 'function') app.auth.updateIcon();
        });
        window.addEventListener('vm:customer-logout', function () {
            document.body.dataset.customer = 'logged-out';
            if (window.app && app.auth && typeof app.auth.updateIcon === 'function') app.auth.updateIcon();
        });
    </script>
</head>
